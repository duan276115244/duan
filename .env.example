# ============================================================
#  段先生 AI Agent 环境配置
#  复制此文件为 .env 并填入你的 API Key
# ============================================================

# ============ 服务配置 ============
# 服务端口
PORT=3001
# 数据存储目录
DATA_DIR=./.duan
# 运行环境 (development | production)
NODE_ENV=production

# ============ 🇨🇳 国内主流提供商 ============

# DeepSeek（推荐，性价比最高）
# 获取: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# 阿里通义千问 Qwen
# 获取: https://help.aliyun.com/zh/model-studio/developer-reference/get-api-key
ALIYUN_API_KEY=your_aliyun_api_key_here

# 智谱 GLM-4
# 获取: https://open.bigmodel.cn/usercenter/apikeys
ZHIPU_API_KEY=your_zhipu_api_key_here

# Moonshot 月之暗面
# 获取: https://platform.moonshot.cn/console/api-keys
MOONSHOT_API_KEY=your_moonshot_api_key_here

# 字节豆包 Doubao
# 获取: https://console.volcengine.com/ark
BYTEDANCE_API_KEY=your_bytedance_api_key_here

# SiliconFlow 硅基流动（注册送2000万token）
# 获取: https://cloud.siliconflow.cn/account/ak
SILICONFLOW_API_KEY=your_siliconflow_api_key_here

# MiniMax
# 获取: https://www.minimaxi.com/
MINIMAX_API_KEY=your_minimax_api_key_here

# ============ 🌍 国际一线提供商 ============

# OpenAI (GPT-4o, GPT-4o-mini, o1, o3)
# 获取: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (Claude 3.5 Sonnet, Claude 3 Opus, Claude 3 Haiku)
# 获取: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_claude_api_key_here

# Google (Gemini 2.0 Flash, Gemini 2.0 Pro)
# 获取: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ============ 🔗 聚合平台 ============

# OpenRouter（聚合200+模型）
# 获取: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Groq（极速免费推理）
# 获取: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Together AI
# 获取: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=your_together_api_key_here

# Fireworks AI
# 获取: https://app.fireworks.ai/
FIREWORKS_API_KEY=your_fireworks_api_key_here

# Perplexity (Sonar Pro)
# 获取: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# xAI (Grok)
# 获取: https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here

# ============ 🎯 本地模型 ============

# Ollama 本地模型（无需 API Key）
# 安装: https://ollama.com/
OLLAMA_BASE_URL=http://localhost:11434

# ============ 默认模型 ============
# 可选: deepseek | openai | anthropic | google | ollama | openrouter
DEFAULT_MODEL=deepseek

# ============ 安全配置 ============
# 是否启用 API 认证
AUTH_ENABLED=true
# API 认证密钥（多个用逗号分隔）
AUTH_API_KEYS=your-api-key-1,your-api-key-2
# API Key 加密主密钥
ENCRYPTION_MASTER_KEY=your-master-key-for-encrypting-api-keys
# 速率限制：最大请求数
RATE_LIMIT_MAX=100
# 速率限制：时间窗口（毫秒）
RATE_LIMIT_WINDOW=60000

# ============ 📡 消息通道配置 ============
# 推荐通过 ~/.duan/config.json 的 channels.* 结构配置，
# 以下环境变量作为向后兼容的备用（对标 OpenClaw 设计）：
#
# channels 配置示例 (~/.duan/config.json):
#   {
#     "channels": {
#       "telegram": {
#         "enabled": true,
#         "botToken": "123:abc",
#         "dmPolicy": "pairing",
#         "allowFrom": ["*"],
#         "groups": { "*": { "requireMention": true } }
#       },
#       "discord": {
#         "enabled": true,
#         "botToken": "xxx",
#         "dmPolicy": "allowlist",
#         "allowFrom": ["user_id_1"]
#       },
#       "slack": {
#         "enabled": true,
#         "botToken": "xoxb-xxx",
#         "appToken": "xapp-xxx"
#       },
#       "wecom": {
#         "enabled": true,
#         "botToken": "xxx",
#         "apiUrl": "https://qyapi.weixin.qq.com"
#       },
#       "email": {
#         "enabled": true,
#         "smtpHost": "smtp.example.com",
#         "smtpPort": 465,
#         "smtpUser": "user",
#         "smtpPass": "pass",
#         "smtpFrom": "bot@example.com"
#       }
#     }
#   }
#
# 环境变量（向后兼容）：
SLACK_BOT_TOKEN=
DISCORD_WEBHOOK=
TELEGRAM_BOT_TOKEN=
WECOM_KEY=
FEISHU_WEBHOOK=
DINGTALK_WEBHOOK=
WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ---- WhatsApp Business Cloud API ----
# 获取: https://developers.facebook.com/apps → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# ---- Microsoft Teams ----
# 获取: Teams 频道 → 连接器 → Incoming Webhook
TEAMS_WEBHOOK_URL=
TEAMS_BOT_TOKEN=

# ---- SMS 短信 ----
# 服务商: twilio | aliyun
SMS_PROVIDER=twilio
# Twilio: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# 阿里云短信: https://dysms.console.aliyun.com/
ALIYUN_SMS_ACCESS_KEY=
ALIYUN_SMS_SECRET=
ALIYUN_SMS_SIGN_NAME=

# ---- QQ 机器人 ----
# 获取: https://q.qq.com/ (QQ 开放平台)
QQ_BOT_TOKEN=
QQ_WEBHOOK_URL=

# ---- 微信公众号 ----
# 获取: https://mp.weixin.qq.com/ → 基本配置
WECHAT_OA_APP_ID=
WECHAT_OA_APP_SECRET=
WECHAT_OA_TOKEN=
WECHAT_OA_ENCODING_AES_KEY=

# ============ 日志配置 ============
# 日志级别 (debug | info | warn | error)
LOG_LEVEL=info
# 日志文件路径
LOG_FILE=./logs/duan.log
