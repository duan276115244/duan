      { key: 'botUsername', label: '机器人用户名', type: 'text', required: false, help: '机器人用户名（不带@）' },
    ], accessControl: true },
    imessage: { type: 'imessage', label: 'iMessage', description: 'iMessage 机器人，通过邮件桥接接入（仅 macOS）', fields: [
      { key: 'bridgeEmail', label: '桥接邮箱', type: 'text', required: true, placeholder: 'bot@icloud.com', help: '用于收发 iMessage 的邮箱地址' },
      { key: 'appPassword', label: '应用专用密码', type: 'password', required: true, help: 'Apple ID→应用专用密码（非登录密码）' },
      { key: 'imapServer', label: 'IMAP 服务器', type: 'text', required: false, default: 'imap.mail.me.com', help: 'iCloud IMAP 服务器地址' },
      { key: 'smtpServer', label: 'SMTP 服务器', type: 'text', required: false, default: 'smtp.mail.me.com', help: 'iCloud SMTP 服务器地址' },
