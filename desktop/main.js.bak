        'fi-FI': 'Hei, olen Duan, älykäs avustajasi. Kuinka voin auttaa sinua?',
        'da-DK': 'Hej, jeg er Duan, din intelligente assistent. Hvordan kan jeg hjælpe dig?',
        'ro-RO': 'Salut, sunt Duan, asistentul tău inteligent. Cum te pot ajuta?',
        'hu-HU': 'Helló, Duan vagyok, az intelligens asszisztensed. Hogyan segíthetek?',
        'he-IL': 'שלום, אני דואן, העוזר החכם שלך. איך אוכל לעזור לך?',
        'ms-MY': 'Helo, saya Duan, pembantu pintar anda. Bagaimana saya boleh membantu anda?',
        'nb-NO': 'Hei, jeg er Duan, din intelligente assistent. Hvordan kan jeg hjelpe deg?',
      };
      // 如果前端传了 text 且语言匹配，直接使用；否则根据语音语言选择默认测试文本
      let testText = text || DEFAULT_TEST_TEXTS[langPrefix] || DEFAULT_TEST_TEXTS['zh-CN'];
      // 如果传了中文文本但语音是英文/日文等，自动切换为对应语言的测试文本
      if (!text && langPrefix && DEFAULT_TEST_TEXTS[langPrefix]) {
        testText = DEFAULT_TEST_TEXTS[langPrefix];
      }

      // 校验语音名称是否在可用列表中，无效则回退到默认语音
      const validVoiceNames = new Set(BUILTIN_VOICES.map(v => v.name));
      let validatedVoiceName = voiceName;
      if (!validVoiceNames.has(validatedVoiceName)) {
        debugLog.push(`语音 "${validatedVoiceName}" 不在可用列表中，回退到默认语音`);
        validatedVoiceName = 'zh-CN-XiaoxiaoNeural';
      }
      const speed = typeof rate === 'number' ? rate : 1.0;
      const pitchVal = typeof pitch === 'number' ? pitch : 0;

      // 方案 1（优先）：通过 Agent 服务器的 TTS API（使用 WebSocket，速度最快）
      try {
        const postData = JSON.stringify({ text: testText, voice: validatedVoiceName, speed, format: 'mp3' });
        const result = await new Promise((resolve) => {
          const req = http.request({
            hostname: 'localhost', port: agentPort,
            path: '/api/voice/speak', method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Content-Length': Buffer.byteLength(postData) },
            timeout: 15000,
          }, (res) => {
            let body = '';
            res.on('data', (chunk) => { body += chunk; });
            res.on('end', () => {
              try { resolve(JSON.parse(body)); } catch { resolve(null); }
            });
          });
          req.on('error', () => resolve(null));
          req.on('timeout', () => { req.destroy(); resolve(null); });
          req.write(postData);
          req.end();
        });
        if (result && result.success && result.audio) {
          return { success: true, audio: result.audio, mime: result.mime || 'audio/mpeg' };
        }
        debugLog.push(`方案1(Agent服务器)失败: ${result?.error || 'TTS 返回 500'}`);
      } catch (e1) { debugLog.push(`方案1(Agent服务器)异常: ${e1.message}`); }

      // 方案 2（备选）：使用 Python edge-tts 模块
      const pythonCmd = findPythonExecutable();
      if (pythonCmd) {
        // 辅助函数：用指定语音合成音频，返回 Buffer 或 null（异步，不阻塞主进程）
        const synthesizeWithEdgeTTS = async (vName, txt) => {
          try {
            const tmpDir = path.join(os.tmpdir(), 'duan-voice');
            if (!fs.existsSync(tmpDir)) fs.mkdirSync(tmpDir, { recursive: true });
            const outputFile = path.join(tmpDir, `tts_test_${Date.now()}.mp3`);
            const rateDelta = Math.round((speed - 1) * 100);
            const ratePercent = `${rateDelta >= 0 ? '+' : '-'}${Math.abs(rateDelta)}%`;
            const pitchDelta = pitchVal * 10;
            const pitchHz = `${pitchDelta >= 0 ? '+' : '-'}${Math.abs(pitchDelta)}Hz`;
            // 使用 -t 直传文本（避免临时文件路径在 shell 模式下被反斜杠/空格破坏）
            const args = ['-m', 'edge_tts', '-t', txt, '-v', vName,
                          '--rate', ratePercent, '--pitch', pitchHz,
                          '--write-media', outputFile];
            // shell: false 避免 Windows cmd.exe 对路径和参数的二次解析
            const result = await runProcessAsync(pythonCmd, args, { timeout: 30000, shell: false });
            if (result.code === 0 && fs.existsSync(outputFile)) {
              const audioBuffer = fs.readFileSync(outputFile);
              try { fs.unlinkSync(outputFile); } catch { /* ignore */ }
              if (audioBuffer.length > 0) return audioBuffer;
            }
            return { error: result.stderr ? result.stderr.substring(0, 800) : '合成失败' };
          } catch (e) {
            return { error: e.message };
          }
        };

        // 第一次尝试：用用户选择的语音
        let result1 = await synthesizeWithEdgeTTS(validatedVoiceName, testText);
        if (result1 && !result1.error) {
          return { success: true, audio: result1.toString('base64'), mime: 'audio/mpeg' };
        }
        if (result1?.error) {
          debugLog.push(`方案2(Python edge-tts)失败: ${result1.error}`);
        } else {
          debugLog.push('方案2(Python edge-tts): 生成的音频文件为空');
        }

        // 第二次尝试：如果第一次失败（可能是语音语言与文本语言不匹配），
        // 用默认中文语音重试（使用相同的文本，适用于 AI 回复和试听）
        if (validatedVoiceName !== 'zh-CN-XiaoxiaoNeural') {
          let result2 = await synthesizeWithEdgeTTS('zh-CN-XiaoxiaoNeural', testText);
          if (result2 && !result2.error) {
            debugLog.push(`原语音 "${validatedVoiceName}" 合成失败，已回退到默认中文语音`);
            return { success: true, audio: result2.toString('base64'), mime: 'audio/mpeg' };
          }
        }
      } else {
        debugLog.push('方案2(Python edge-tts): 未找到 Python 可执行文件');
      }

      // 方案 3：直接使用 edge-tts 命令行工具（如果已添加到 PATH）
      try {
        const tmpDir = path.join(os.tmpdir(), 'duan-voice');
        if (!fs.existsSync(tmpDir)) fs.mkdirSync(tmpDir, { recursive: true });
        const outputFile = path.join(tmpDir, `tts_test_${Date.now()}.mp3`);
        const rateDelta = Math.round((speed - 1) * 100);
        const ratePercent = `${rateDelta >= 0 ? '+' : '-'}${Math.abs(rateDelta)}%`;
        const pitchDelta = pitchVal * 10;
        const pitchHz = `${pitchDelta >= 0 ? '+' : '-'}${Math.abs(pitchDelta)}Hz`;
        // 使用 -t 直传文本，shell: false 避免路径问题
        const cliArgs = ['-t', testText, '-v', validatedVoiceName,
                        '--rate', ratePercent, '--pitch', pitchHz,
                        '--write-media', outputFile];
        const cliResult = await runProcessAsync('edge-tts', cliArgs, { timeout: 30000, shell: false });
        if (cliResult.code === 0 && fs.existsSync(outputFile)) {
          const audioBuffer = fs.readFileSync(outputFile);
          try { fs.unlinkSync(outputFile); } catch { /* ignore */ }
          if (audioBuffer.length > 0) {
            return { success: true, audio: audioBuffer.toString('base64'), mime: 'audio/mpeg' };
          }
          debugLog.push('方案3: 生成的音频文件为空');
        } else {
          debugLog.push(`方案3: 未生成音频文件${cliResult.stderr ? ' (' + cliResult.stderr.substring(0, 200) + ')' : ''}`);
        }
      } catch (e3) { debugLog.push(`方案3(edge-tts CLI)失败: ${e3.message}`); }

      return { success: false, error: `语音合成失败。调试信息: ${debugLog.join(' | ')}` };
    } catch (e) {
      return { success: false, error: e.message };
    }
  });

  // 语音转文字 (ASR)
  // 支持两种模式：
  // 1. record 模式（推荐）：直接使用 PyAudio 录音，无需格式转换，最可靠
  //    参数: { record: true, maxDuration?: 30, silenceTimeout?: 2 }
  // 2. audio 模式：接收 base64 音频数据（MediaRecorder 录制的 webm/mp4）
  //    参数: { audio: 'base64...', format: 'webm' }
  safeHandle('voice:transcribe', async (_event, args) => {
    const debugLog = [];
    try {
      const { audio, format, record, maxDuration, silenceTimeout } = args || {};
      const pythonCmd = findPythonExecutable();
      if (!pythonCmd) {
        return { success: false, error: '未找到 Python，无法进行语音识别' };
      }

      const tmpDir = path.join(os.tmpdir(), 'duan-voice');
      if (!fs.existsSync(tmpDir)) fs.mkdirSync(tmpDir, { recursive: true });

      if (record) {
        // ===== 模式 1：直接录音（PyAudio + 能量检测，支持手动停止）=====
        const maxDur = maxDuration || 30;
        const silenceTimeoutVal = silenceTimeout || 0.8; // 从 1.5s 降到 0.8s，减少对话延迟
        const stopFile = path.join(tmpDir, `stop_${Date.now()}.signal`);
        const wavFile = path.join(tmpDir, `recording_${Date.now()}.wav`);
        const scriptCode = `
import sys, os, time, wave, struct, math
try:
    import pyaudio
    import speech_recognition as sr

    stop_file = sys.argv[1] if len(sys.argv) > 1 else ''
    wav_output = sys.argv[2] if len(sys.argv) > 2 else ''
    max_duration = ${maxDur}
    silence_limit = ${silenceTimeoutVal}

    # 录音参数
    CHUNK = 1024
    FORMAT = pyaudio.paInt16
    CHANNELS = 1
    RATE = 16000
    RECORD_SECONDS = max_duration

    audio = pyaudio.PyAudio()
    stream = audio.open(format=FORMAT, channels=CHANNELS, rate=RATE, input=True, frames_per_buffer=CHUNK)
    frames = []

    # 环境噪声校准（前 0.2 秒，从 0.5s 优化以减少延迟）
    noise_samples = []
    for _ in range(int(RATE / CHUNK * 0.2)):
        data = stream.read(CHUNK, exception_on_overflow=False)
        noise_samples.append(data)
    # 计算环境噪声能量
    noise_energy = 0
    for data in noise_samples:
        count = len(data) // 2
        shorts = struct.unpack('<' + 'h' * count, data)
        noise_energy = max(noise_energy, max(abs(s) for s in shorts) if shorts else 0)
    energy_threshold = max(noise_energy * 3, 500)  # 动态阈值

    silence_duration = 0
    has_speech = False
    start_time = time.time()
    frames = noise_samples  # 保留校准数据

    # 录音循环：检测语音 + 静音 + 手动停止
    while time.time() - start_time < RECORD_SECONDS:
        # 检查停止信号文件
        if stop_file and os.path.exists(stop_file):
            break
        data = stream.read(CHUNK, exception_on_overflow=False)
        frames.append(data)
        # 计算当前 chunk 的能量
        count = len(data) // 2
        shorts = struct.unpack('<' + 'h' * count, data)
        current_energy = max(abs(s) for s in shorts) if shorts else 0
        if current_energy > energy_threshold:
            has_speech = True
            silence_duration = 0
        elif has_speech:
            silence_duration += CHUNK / RATE
            if silence_duration >= silence_limit:
                break  # 静音超过阈值，停止录音

    stream.stop_stream()
    stream.close()
    audio.terminate()

    if not has_speech:
        # 清理停止文件
        try: os.remove(stop_file)
        except: pass
        print('ERROR:未检测到语音内容')
        sys.exit(0)

    # 保存 WAV 文件
    wf = wave.open(wav_output, 'wb')
    wf.setnchannels(CHANNELS)
    wf.setsampwidth(audio.get_sample_size(FORMAT))
    wf.setframerate(RATE)
    wf.writeframes(b''.join(frames))
    wf.close()

    # 清理停止文件
    try: os.remove(stop_file)
    except: pass

    # 使用 Google Web Speech API 转写
    r = sr.Recognizer()
    with sr.AudioFile(wav_output) as source:
        audio_data = r.record(source)
    try:
        text = r.recognize_google(audio_data, language='zh-CN')
        print('SUCCESS:' + text)
    except sr.UnknownValueError:
        print('ERROR:无法识别语音内容，请重试')
    except sr.RequestError as e:
        print('ERROR:语音服务请求失败: ' + str(e) + '（可能需要网络连接）')

    # 清理 WAV 文件
    try: os.remove(wav_output)
    except: pass

except ImportError as ie:
    print('ERROR:缺少依赖库: ' + str(ie) + '，请运行 pip install SpeechRecognition pyaudio')
except Exception as e:
    print('ERROR:处理失败: ' + str(e))
    import traceback
    traceback.print_exc(file=sys.stderr)
`;
        const scriptFile = path.join(tmpDir, `asr_record_${Date.now()}.py`);
        fs.writeFileSync(scriptFile, scriptCode, 'utf-8');

        try {
          // 异步执行，不阻塞主进程；存储进程引用以支持手动停止
          const result = await runProcessAsync(pythonCmd, [scriptFile, stopFile, wavFile], {
            timeout: (maxDur + 15) * 1000,
            onSpawn: (child) => { currentRecordingProcess = child; },
          });
          currentRecordingProcess = null;  // 录音结束，清除引用
          const trimmed = result.stdout.trim();
          try { fs.unlinkSync(scriptFile); } catch { /* ignore */ }

          if (trimmed.startsWith('SUCCESS:')) {
            const text = trimmed.substring(8).trim();
            if (text) {
              return { success: true, text, confidence: 0.9, language: 'zh-CN' };
            }
            return { success: false, error: '识别结果为空' };
          } else if (trimmed.startsWith('ERROR:')) {
            return { success: false, error: trimmed.substring(6).trim() };
          }
          return { success: false, error: '识别失败: ' + (trimmed || result.stderr.substring(0, 200)) };
        } catch (e) {
          debugLog.push(`Python 录音执行失败: ${e.message}`);
          const stderr = e.stderr ? e.stderr.toString().trim() : '';
          if (stderr) debugLog.push(`stderr: ${stderr.substring(0, 300)}`);
          try { fs.unlinkSync(scriptFile); } catch { /* ignore */ }
        }

        return { success: false, error: `语音识别失败。调试信息: ${debugLog.join(' | ')}` };

      } else if (audio) {
        // ===== 模式 2：接收 base64 音频数据 =====
        const ext = format || 'webm';
        const audioFile = path.join(tmpDir, `asr_${Date.now()}.${ext}`);
        const wavFile = path.join(tmpDir, `asr_${Date.now()}.wav`);

        const audioBuffer = Buffer.from(audio, 'base64');
        if (audioBuffer.length === 0) return { success: false, error: '音频数据为空' };
        fs.writeFileSync(audioFile, audioBuffer);
        debugLog.push(`音频已保存: ${audioFile} (${audioBuffer.length} bytes)`);

        const scriptCode = `
import sys, os, subprocess
try:
    import speech_recognition as sr
    audio_file = sys.argv[1]
    wav_file = sys.argv[2]
    r = sr.Recognizer()
    try:
        audio_data = sr.AudioFile(audio_file)
        with audio_data as source:
            audio = r.record(source)
    except Exception:
        subprocess.run(['ffmpeg', '-y', '-i', audio_file, '-ar', '16000', '-ac', '1', wav_file],
                     capture_output=True, timeout=15)
        audio_data = sr.AudioFile(wav_file)
        with audio_data as source:
            audio = r.record(source)
    try:
        text = r.recognize_google(audio, language='zh-CN')
        print('SUCCESS:' + text)
    except sr.UnknownValueError:
        print('ERROR:无法识别语音内容')
    except sr.RequestError as e:
        print('ERROR:语音服务请求失败: ' + str(e))
except Exception as e:
    print('ERROR:处理失败: ' + str(e))
`;
        const scriptFile = path.join(tmpDir, `asr_script_${Date.now()}.py`);
        fs.writeFileSync(scriptFile, scriptCode, 'utf-8');

        try {
          // 异步执行，不阻塞主进程
          const result = await runProcessAsync(pythonCmd, [scriptFile, audioFile, wavFile], {
            timeout: 30000,
          });
          const trimmed = result.stdout.trim();
          try { fs.unlinkSync(audioFile); } catch { /* ignore */ }
          try { fs.unlinkSync(wavFile); } catch { /* ignore */ }
          try { fs.unlinkSync(scriptFile); } catch { /* ignore */ }

          if (trimmed.startsWith('SUCCESS:')) {
            const text = trimmed.substring(8).trim();
            if (text) {
              return { success: true, text, confidence: 0.9, language: 'zh-CN' };
            }
            return { success: false, error: '识别结果为空' };
          } else if (trimmed.startsWith('ERROR:')) {
            return { success: false, error: trimmed.substring(6).trim() };
          }
          return { success: false, error: '识别失败: ' + trimmed };
        } catch (e) {
          debugLog.push(`Python 执行失败: ${e.message}`);
          const stderr = e.stderr ? e.stderr.toString().trim() : '';
          if (stderr) debugLog.push(`stderr: ${stderr.substring(0, 200)}`);
        }

        try { fs.unlinkSync(audioFile); } catch { /* ignore */ }
        try { fs.unlinkSync(wavFile); } catch { /* ignore */ }
        try { fs.unlinkSync(scriptFile); } catch { /* ignore */ }

        return { success: false, error: `语音识别失败。调试信息: ${debugLog.join(' | ')}` };
      }

      return { success: false, error: '未指定录音模式或音频数据' };
    } catch (e) {
      return { success: false, error: e.message };
    }
  });

  safeHandle('config:load', async () => {
    const config = loadConfig();
    // 从 ~/.duan/config.json 读取已配置的 API Keys 状态
    const duanConfig = loadDuanConfig();
    let profiles = duanConfig.profiles || [];
    // 兼容 v2.0 对象格式：转换为数组
    if (!Array.isArray(profiles)) {
      profiles = Object.entries(profiles).map(([id, p]) => ({
        id: id,
        provider: p.provider || '',
        apiKey: p.apiKey || '',
        model: p.model || '',
        baseURL: p.baseUrl || p.baseURL || '',
        label: p.label || '',
      }));
    }
    const apiKeys = {};
    const pModels = {};
    for (const profile of profiles) {
      if (profile.apiKey && profile.provider) {
        apiKeys[profile.provider] = '已配置';
        // 别名映射：coding_plan 和 doubao-coding 互通
        if (profile.provider === 'coding_plan') apiKeys['doubao-coding'] = '已配置';
        if (profile.provider === 'doubao-coding') apiKeys['coding_plan'] = '已配置';
      }
      if (profile.model && profile.provider) {
        pModels[profile.provider] = profile.model;
        if (profile.provider === 'coding_plan') pModels['doubao-coding'] = profile.model;
        if (profile.provider === 'doubao-coding') pModels['coding_plan'] = profile.model;
      }
    }
    config.apiKeys = { ...config.apiKeys, ...apiKeys };
    config.providerModels = { ...config.providerModels, ...pModels };
    // 优先使用活跃 profile 的 model
    const activeProfileId = duanConfig.activeProfile || duanConfig.defaultProfileId;
    const activeProfile = profiles.find(p => p.id === activeProfileId || p.provider === activeProfileId) || profiles[0];
    if (activeProfile?.model) {
      config.model = activeProfile.model;
      config.defaultModel = duanConfig.defaultModel || activeProfile.model;
    }
    if (duanConfig.defaultModel) config.defaultModel = duanConfig.defaultModel;
    if (duanConfig.defaultProvider) config.defaultProvider = duanConfig.defaultProvider;
    config.profiles = profiles;
    config.defaultProfileId = duanConfig.activeProfile || duanConfig.defaultProfileId || '';
    config.configured = duanConfig.configured || config.configured || false;
    return config;
  });

  // ===== 自我改进配置 IPC =====
  // 读取自我改进启用状态
  ipcMain.handle('self-improve:get', async () => {
    try {
      const enabled = isSelfImproveEnabled();
      // 同时返回历史记录数量
      const historyPath = path.join(os.homedir(), '.duan', 'self-improve', 'history.jsonl');
      let historyCount = 0;
      if (fs.existsSync(historyPath)) {
        historyCount = fs.readFileSync(historyPath, 'utf-8').trim().split('\n').filter(Boolean).length;
      }
      // 备份文件数量
      const backupDir = path.join(os.homedir(), '.duan', 'self-improve', 'backups');
      let backupCount = 0;
      if (fs.existsSync(backupDir)) {
        backupCount = fs.readdirSync(backupDir).filter(f => f.endsWith('.bak')).length;
      }
      return { success: true, enabled, historyCount, backupCount };
    } catch (err) {
      return { success: false, error: err.message };
    }
  });

  // 设置自我改进启用状态
  ipcMain.handle('self-improve:set', async (_event, { enabled }) => {
    try {
      const ok = setSelfImproveEnabled(!!enabled);
      return { success: ok };
    } catch (err) {
      return { success: false, error: err.message };
    }
  });

  // 读取自我改进历史记录
  ipcMain.handle('self-improve:history', async (_event, { limit } = {}) => {
    try {
      const historyPath = path.join(os.homedir(), '.duan', 'self-improve', 'history.jsonl');
      if (!fs.existsSync(historyPath)) return { success: true, history: [] };
      const lines = fs.readFileSync(historyPath, 'utf-8').trim().split('\n').filter(Boolean);
      const max = Math.min(limit || 50, 200);
      const recent = lines.slice(-max).map(l => {
        try { return JSON.parse(l); } catch { return null; }
      }).filter(Boolean);
      return { success: true, history: recent };
    } catch (err) {
      return { success: false, error: err.message };
    }
  });

  // 列出备份文件（用于回滚）
  ipcMain.handle('self-improve:backups', async () => {
    try {
      const backupDir = path.join(os.homedir(), '.duan', 'self-improve', 'backups');
      if (!fs.existsSync(backupDir)) return { success: true, backups: [] };
      const files = fs.readdirSync(backupDir)
        .filter(f => f.endsWith('.bak'))
        .map(f => {
          const fullPath = path.join(backupDir, f);
          const stat = fs.statSync(fullPath);
          return { name: f, path: fullPath, size: stat.size, mtime: stat.mtimeMs };
        })
        .sort((a, b) => b.mtime - a.mtime);
      return { success: true, backups: files };
    } catch (err) {
      return { success: false, error: err.message };
    }
  });

  // 回滚：用备份文件恢复
  ipcMain.handle('self-improve:rollback', async (_event, { backupPath }) => {
    try {
      if (!backupPath || !fs.existsSync(backupPath)) {
        return { success: false, error: '备份文件不存在' };
      }

      // V17 安全修复：验证 backupPath 在备份目录内，防止读取任意文件
      const backupDir = path.join(os.homedir(), '.duan', 'self-improve', 'backups');
      const resolvedBackup = path.resolve(backupPath);
      const resolvedBackupDir = path.resolve(backupDir);
      if (!resolvedBackup.startsWith(resolvedBackupDir + path.sep) && resolvedBackup !== resolvedBackupDir) {
        return { success: false, error: '安全限制: 备份文件路径不在备份目录内' };
      }

      const { dialog } = require('electron');
      const backupName = path.basename(backupPath);
      // 从备份名解析原文件路径（格式: <timestamp>_<file_with_underscores>.bak）
      const nameWithoutExt = backupName.replace(/\.bak$/, '');
      const tsMatch = nameWithoutExt.match(/^(\d+)_(.+)$/);
      const originalFile = tsMatch ? tsMatch[2].replace(/_/g, '/') : nameWithoutExt;
      const targetPath = path.join(ROOT_DIR, originalFile);

      // V17 安全修复：验证 targetPath 解析后仍在 ROOT_DIR 内（防止 ../ 路径遍历）
      const resolvedTarget = path.resolve(targetPath);
      const resolvedRoot = path.resolve(ROOT_DIR);
      if (!resolvedTarget.startsWith(resolvedRoot + path.sep) && resolvedTarget !== resolvedRoot) {
        return { success: false, error: '安全限制: 目标路径解析越界，拒绝回滚' };
      }

      // V17 安全修复：验证目标文件在自我改进白名单内
      const SELF_IMPROVE_WHITELIST = ['desktop/main.js', 'desktop/tool-executor.js', 'desktop/preload.js', 'desktop/package.json', 'desktop/index.html'];
      const normalizedFile = originalFile.replace(/\\/g, '/');
      if (!SELF_IMPROVE_WHITELIST.includes(normalizedFile)) {
        return { success: false, error: `安全限制: 文件 "${normalizedFile}" 不在自我改进白名单中` };
      }

      const result = dialog.showMessageBoxSync(mainWindow, {
        type: 'question',
        title: '自我改进 — 回滚确认',
        message: '确认要回滚此文件吗？',
        detail: `备份文件: ${backupName}\n将恢复到: ${originalFile}\n\n当前文件内容将被备份文件覆盖。`,
        buttons: ['取消', '确认回滚'],
        defaultId: 0,
        cancelId: 0,
      });
      if (result !== 1) return { success: false, error: '用户取消回滚' };

      const backupContent = fs.readFileSync(backupPath, 'utf-8');
      fs.writeFileSync(targetPath, backupContent, 'utf-8');
      console.log(`[self_improve] 已回滚: ${originalFile} <- ${backupName}`);
      return { success: true, restoredFile: originalFile };
    } catch (err) {
      return { success: false, error: err.message };
    }
  });

  // F2 修复：self-improve:run — 前端触发执行一次 evolve cycle
  // 通过 HTTP 调用后端 /api/self-evolve/run，后端执行 SelfEvolve.runCycle()（含 tsc + vitest 护栏）
  ipcMain.handle('self-improve:run', async (_event, { focus } = {}) => {
    try {
      const postData = JSON.stringify({ focus: focus || undefined });
      const result = await new Promise((resolve) => {
        const req = http.request({
          hostname: 'localhost', port: agentPort,
          path: '/api/self-evolve/run', method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Content-Length': Buffer.byteLength(postData) },
          timeout: 300000, // 5 分钟超时（evolve 含 tsc + vitest 可能较慢）
        }, (res) => {
          let body = '';
          res.on('data', (chunk) => { body += chunk.toString(); });
          res.on('end', () => {
            try {
              const json = JSON.parse(body);
              if (res.statusCode === 200) {
                resolve({ success: true, cycle: json.cycle || json, message: json.message || '自我改进完成' });
              } else {
                resolve({ success: false, error: json.error || json.message || `服务器返回 ${res.statusCode}` });
              }
            } catch (e) {
              resolve({ success: false, error: `解析响应失败: ${e.message}` });
            }
          });
        });
        req.on('error', (e) => resolve({ success: false, error: `无法连接 Agent 服务器: ${e.message}` }));
        req.on('timeout', () => { req.destroy(); resolve({ success: false, error: '自我改进超时（5分钟），请检查项目规模' }); });
        req.write(postData);
        req.end();
      });
      return result;
    } catch (e) {
      return { success: false, error: e.message };
    }
  });

  // P0 自我改进接通：获取进化历史（桥接 GET /api/self-evolve/history）
  ipcMain.handle('self-improve:evolutionHistory', async () => {
    try {
      const result = await new Promise((resolve) => {
        const req = http.request({
          hostname: 'localhost', port: agentPort,
          path: '/api/self-evolve/history', method: 'GET',
          timeout: 15000,
        }, (res) => {
          let body = '';
          res.on('data', (chunk) => { body += chunk.toString(); });
          res.on('end', () => {
            try {
              const json = JSON.parse(body);
              if (res.statusCode === 200) {
                resolve({ success: true, ...json });
              } else {
                resolve({ success: false, error: json.error || `服务器返回 ${res.statusCode}` });
              }
            } catch (e) {
              resolve({ success: false, error: `解析响应失败: ${e.message}` });
            }
          });
        });
        req.on('error', (e) => resolve({ success: false, error: `无法连接 Agent 服务器: ${e.message}` }));
        req.on('timeout', () => { req.destroy(); resolve({ success: false, error: '请求超时' }); });
        req.end();
      });
      return result;
    } catch (e) {
      return { success: false, error: e.message };
    }
  });

  ipcMain.handle('config:save', async (_event, config) => {
    try {
      // ===== 合并 API Keys：新输入的 key + 已存在的 key =====
      const duanConfig = loadDuanConfig();
      let profiles = duanConfig.profiles || [];
      // 兼容 v2.0 对象格式
      if (!Array.isArray(profiles)) {
        profiles = Object.entries(profiles).map(([id, p]) => ({
          id: id,
          provider: p.provider || '',
          apiKey: p.apiKey || '',
          model: p.model || '',
          baseURL: p.baseUrl || p.baseURL || '',
          label: p.label || '',
        }));
      }

      // 构建完整的 apiKeys：从前端传入的新 key + 从已有 profiles 中读取的旧 key
      const mergedApiKeys = { ...(config.apiKeys || {}) };
      for (const profile of profiles) {
        if (profile.apiKey && profile.provider) {
          // 如果前端没有传入该 provider 的新 key，使用已有的 key
          if (!mergedApiKeys[profile.provider] || mergedApiKeys[profile.provider].length < 8 || mergedApiKeys[profile.provider] === '已配置') {
            mergedApiKeys[profile.provider] = profile.apiKey;
          }
          // 别名映射：doubao-coding 和 coding_plan 互通
          if (profile.provider === 'coding_plan' && (!mergedApiKeys['doubao-coding'] || mergedApiKeys['doubao-coding'] === '已配置')) {
            mergedApiKeys['doubao-coding'] = profile.apiKey;
          }
          if (profile.provider === 'doubao-coding' && (!mergedApiKeys['coding_plan'] || mergedApiKeys['coding_plan'] === '已配置')) {
            mergedApiKeys['coding_plan'] = profile.apiKey;
          }
        }
      }
      // 过滤掉无效key
      const validApiKeys = {};
      for (const [provider, key] of Object.entries(mergedApiKeys)) {
        if (key && typeof key === 'string' && key.length > 8 && !key.startsWith('your_') && key !== '已配置') {
          validApiKeys[provider] = key;
        }
      }

      // 保存 Electron 桌面配置
      const configToSave = { ...config, apiKeys: validApiKeys };
      saveConfig(configToSave);
      // 同时保存 API Keys 到 duan-config.json profiles 格式
      if (Object.keys(validApiKeys).length > 0) {
        saveApiKeysToProfiles(validApiKeys, config.defaultModel, config.defaultProvider, config.providerModels);
      }
      return { success: true };
    } catch (err) {
      console.error('[Config] IPC 保存失败:', err.message);
      return { success: false, error: err.message };
    }
  });

  // ----- 统一配置 API（三端互通）-----

  /** 获取统一配置（脱敏，apiKey 显示为 ****） */
  ipcMain.handle('config:unified:load', async () => {
    try {
      const duanConfig = loadDuanConfig();
      // 脱敏处理
      const masked = JSON.parse(JSON.stringify(duanConfig));
      if (masked.profiles) {
        const profiles = masked.profiles;
        // 兼容 v1.x（数组）和 v2.0（对象）格式
        if (Array.isArray(profiles)) {
          for (const p of profiles) {
            if (p.apiKey) {
              p.apiKey = p.apiKey.length > 8
                ? p.apiKey.substring(0, 4) + '****' + p.apiKey.substring(p.apiKey.length - 4)
                : '****';
            }
          }
        } else if (typeof profiles === 'object') {
          for (const key of Object.keys(profiles)) {
            if (profiles[key].apiKey) {
              const ak = profiles[key].apiKey;
              profiles[key].apiKey = ak.length > 8
                ? ak.substring(0, 4) + '****' + ak.substring(ak.length - 4)
                : '****';
            }
          }
        }
      }
      return masked;
    } catch (err) {
      console.error('[IPC] config:unified:load 失败:', err.message);
      return { profiles: [], error: '配置加载失败' };
    }
  });

  /** 获取同步状态 */
  ipcMain.handle('config:unified:status', async () => {
    const duanConfig = loadDuanConfig();
    const duanConfigPath = path.join(os.homedir(), '.duan', 'config.json');
    const profileCount = duanConfig.profiles
      ? (Array.isArray(duanConfig.profiles) ? duanConfig.profiles.length : Object.keys(duanConfig.profiles).length)
      : 0;
    return {
      lastModified: duanConfig.sync?.lastModified || duanConfig.lastRun || 0,
      deviceId: duanConfig.sync?.deviceId || '',
      watching: configWatcher !== null,
      configPath: duanConfigPath,
      profileCount,
      activeProfile: duanConfig.activeProfile || duanConfig.defaultProfileId || '',
      version: duanConfig.version || '1.x',
    };
  });

  /** 新增/更新单个配置（写入统一配置源，API Key 加密存储） */
  ipcMain.handle('config:unified:profile:upsert', async (_event, params) => {
    const { profileId, provider, apiKey, model, baseUrl, label } = params;
    if (!provider || !apiKey || !model) {
      return { success: false, message: '缺少必要字段: provider, apiKey, model' };
    }
    const duanConfigPath = path.join(os.homedir(), '.duan', 'config.json');
    const duanDir = path.join(os.homedir(), '.duan');
    try {
      if (!fs.existsSync(duanDir)) fs.mkdirSync(duanDir, { recursive: true });
      let duanConfig = {};
      if (fs.existsSync(duanConfigPath)) {
        duanConfig = JSON.parse(fs.readFileSync(duanConfigPath, 'utf-8'));
      }
      // 强制使用 v2.0 格式（统一配置源）
      if (!duanConfig.version) duanConfig.version = '2.0';
      if (duanConfig.version !== '2.0') {
        // 迁移 v1.x 数组格式到 v2.0 对象格式
        if (Array.isArray(duanConfig.profiles)) {
          const oldProfiles = duanConfig.profiles;
          duanConfig.profiles = {};
          for (const p of oldProfiles) {
            const pid = p.id || p.provider || `profile-${Date.now()}`;
            duanConfig.profiles[pid] = {
              provider: p.provider || '',
              apiKey: encryptApiKey(p.apiKey || ''), // 迁移时加密（encryptApiKey 会跳过已加密的）
              model: p.model || '',
              baseUrl: p.baseURL || p.baseUrl || '',
              label: p.label || p.provider || pid,
            };
          }
          if (!duanConfig.activeProfile && duanConfig.defaultProfileId) {
            duanConfig.activeProfile = duanConfig.defaultProfileId;
          }
        }
        duanConfig.version = '2.0';
      }

      const id = profileId || `profile-${provider}-${Date.now()}`;
      // 加密 API Key 后存储
      const encryptedApiKey = encryptApiKey(apiKey);
      const profile = {
        provider,
        apiKey: encryptedApiKey,
        model,
        baseUrl: baseUrl || '',
        label: label || provider,
      };

      if (!duanConfig.profiles) duanConfig.profiles = {};
      duanConfig.profiles[id] = profile;
      if (!duanConfig.activeProfile) duanConfig.activeProfile = id;
      if (!duanConfig.sync) duanConfig.sync = {};
      duanConfig.sync.lastModified = Date.now();
      duanConfig.sync.deviceId = crypto.createHash('sha256')
        .update(`${os.hostname()}:${os.userInfo().username}`).digest('hex').substring(0, 16);

      markConfigSelfWrite();
      fs.writeFileSync(duanConfigPath, JSON.stringify(duanConfig, null, 2), 'utf-8');
      console.log('[Config] 配置已保存(加密):', id);
      return { success: true, profileId: id };
    } catch (err) {
      return { success: false, message: err.message };
    }
  });

  /** 删除指定配置 */
  ipcMain.handle('config:unified:profile:remove', async (_event, profileId) => {
    const duanConfigPath = path.join(os.homedir(), '.duan', 'config.json');
    try {
      if (!fs.existsSync(duanConfigPath)) return { success: false, message: '配置文件不存在' };
      const duanConfig = JSON.parse(fs.readFileSync(duanConfigPath, 'utf-8'));
      const isV2 = duanConfig.version === '2.0';
      if (isV2) {
        if (!duanConfig.profiles || !duanConfig.profiles[profileId]) {
          return { success: false, message: '配置不存在' };
        }
        delete duanConfig.profiles[profileId];
        if (duanConfig.activeProfile === profileId) {
          duanConfig.activeProfile = Object.keys(duanConfig.profiles)[0] || '';
        }
        if (!duanConfig.sync) duanConfig.sync = {};
        duanConfig.sync.lastModified = Date.now();
      } else {
        if (!Array.isArray(duanConfig.profiles)) return { success: false, message: '配置不存在' };
        const idx = duanConfig.profiles.findIndex(p => p.id === profileId);
        if (idx < 0) return { success: false, message: '配置不存在' };
        duanConfig.profiles.splice(idx, 1);
        if (duanConfig.defaultProfileId === profileId) {
          duanConfig.defaultProfileId = duanConfig.profiles[0]?.id || '';
        }
        duanConfig.lastRun = Date.now();
      }
      markConfigSelfWrite();
      fs.writeFileSync(duanConfigPath, JSON.stringify(duanConfig, null, 2), 'utf-8');
      console.log('[Config] 配置已删除:', profileId);
      return { success: true };
    } catch (err) {
      return { success: false, message: err.message };
    }
  });

  /** 设置激活的配置 */
  ipcMain.handle('config:unified:active:set', async (_event, profileId) => {
    const duanConfigPath = path.join(os.homedir(), '.duan', 'config.json');
    try {
      if (!fs.existsSync(duanConfigPath)) return { success: false, message: '配置文件不存在' };
      const duanConfig = JSON.parse(fs.readFileSync(duanConfigPath, 'utf-8'));
      const isV2 = duanConfig.version === '2.0';
      if (isV2) {
        if (!duanConfig.profiles || !duanConfig.profiles[profileId]) {
          return { success: false, message: '配置不存在' };
        }
        duanConfig.activeProfile = profileId;
        if (!duanConfig.sync) duanConfig.sync = {};
        duanConfig.sync.lastModified = Date.now();
      } else {
        if (!Array.isArray(duanConfig.profiles) || !duanConfig.profiles.find(p => p.id === profileId)) {
          return { success: false, message: '配置不存在' };
        }
        duanConfig.defaultProfileId = profileId;
        duanConfig.lastRun = Date.now();
      }
      markConfigSelfWrite();
      fs.writeFileSync(duanConfigPath, JSON.stringify(duanConfig, null, 2), 'utf-8');
      console.log('[Config] 已设置激活配置:', profileId);

      // P0 供应商热切换：主动调后端 PUT /api/config/active/:id 触发 ModelLibrary 重载。
      // 后端 unified.setActiveProfile 会 emit config.external.changed 事件，
      // ModelLibrary 监听器自动 reloadFromUnifiedConfig() 清理客户端缓存，下次调用用新 apiKey。
      // 异步 fire-and-forget，不阻塞前端响应（失败时文件监听器兜底）。
      try {
        const req = http.request({
          hostname: 'localhost', port: agentPort,
          path: `/api/config/active/${encodeURIComponent(profileId)}`, method: 'PUT', timeout: 3000,
        }, (res) => { res.resume(); });
        req.on('error', () => { /* 后端不可用时静默，文件监听器兜底 */ });
        req.on('timeout', () => { req.destroy(); });
        req.end();
      } catch { /* 异步调用失败不影响主流程 */ }

      // 通知前端供应商已切换（TitleBar 可触发 UI 刷新）
      if (mainWindow && !mainWindow.isDestroyed()) {
        mainWindow.webContents.send('provider:changed', profileId);
      }
      return { success: true };
    } catch (err) {
      return { success: false, message: err.message };
    }
  });

  // ============================================================
  // ----- 消息通道管理 (channel:*) -----
  // 对标 OpenClaw channels.* 配置模式
  // ============================================================

  /** 读取 ~/.duan/config.json 中的 channels 配置 */
  function loadChannelsConfig() {
    const duanConfigPath = path.join(os.homedir(), '.duan', 'config.json');
    try {
      if (!fs.existsSync(duanConfigPath)) return {};
      const raw = JSON.parse(fs.readFileSync(duanConfigPath, 'utf-8'));
      return raw.channels || {};
    } catch { return {}; }
  }

  /** 写入 channels 配置到 ~/.duan/config.json */
  function saveChannelsConfig(channels) {
    const duanConfigPath = path.join(os.homedir(), '.duan', 'config.json');
    try {
      let existing = {};
      if (fs.existsSync(duanConfigPath)) {
        existing = JSON.parse(fs.readFileSync(duanConfigPath, 'utf-8'));
      }
      existing.channels = channels;
      if (!existing.sync) existing.sync = {};
      existing.sync.lastModified = Date.now();
      markConfigSelfWrite();
      fs.writeFileSync(duanConfigPath, JSON.stringify(existing, null, 2), 'utf-8');
      return true;
    } catch (err) {
      console.error('[Channels] 保存失败:', err.message);
      return false;
    }
  }

