  // 模型到provider的映射
  function getProviderForModel(modelId) {
    if (!modelId) return 'deepseek';
    if (modelId.startsWith('gpt') || modelId.startsWith('o1') || modelId.startsWith('o3') || modelId.startsWith('chatgpt')) return 'openai';
    if (modelId.startsWith('claude')) return 'anthropic';
    if (modelId.startsWith('deepseek-chat') || modelId.startsWith('deepseek-reasoner')) return 'deepseek';
    if (modelId.startsWith('deepseek-v')) return 'doubao-coding'; // deepseek-v4-flash 等是 Coding Plan 模型
    if (modelId.startsWith('deepseek')) return 'deepseek';
    if (modelId.startsWith('glm-5.1')) return 'doubao-coding'; // glm-5.1 是 Coding Plan 模型
    if (modelId.startsWith('glm')) return 'zhipu';
    if (modelId.startsWith('qwen') || modelId.startsWith('qwq')) return 'qwen';
    if (modelId.startsWith('moonshot')) return 'moonshot';
    if (modelId.startsWith('kimi')) return 'doubao-coding'; // kimi-k2.6 是 Coding Plan 模型
    if (modelId.startsWith('gemini')) return 'gemini';
    if (modelId.startsWith('ernie')) return 'ernie';
    if (modelId.startsWith('MiniMax') || modelId.startsWith('minimax-m')) return 'doubao-coding'; // minimax-m2.7 等是 Coding Plan 模型
    if (modelId.startsWith('minimax')) return 'minimax';
    if (modelId.startsWith('llama') || modelId.startsWith('mixtral') || modelId.startsWith('gemma')) return 'groq';
    // 火山引擎 Coding Plan 模型（官方文档支持的全部模型）
    const CODING_PLAN_MODELS = ['ark-code-latest', 'doubao-seed-code-preview-latest', 'doubao-seed-2.0-code', 'doubao-seed-2.0-pro', 'doubao-seed-2.0-lite', 'doubao-seed-code', 'doubao-seed-2.0-mini', 'glm-5.1', 'deepseek-v4-flash', 'deepseek-v4-pro', 'kimi-k2.6', 'minimax-m2.7', 'minimax-m3'];
    if (CODING_PLAN_MODELS.includes(modelId)) return 'doubao-coding';
    // 字节豆包标准API模型（doubao-seed-2-0-xxx 格式）
    if (modelId.startsWith('doubao-seed-2-0') || modelId.startsWith('doubao-seed-1')) return 'doubao';
    if (modelId.startsWith('doubao') || modelId.startsWith('ep-')) return 'doubao';
    // 默认回退
    const dc = loadDuanConfig();
    return dc.defaultProvider || 'deepseek';
  }

  safeHandle('model:switch', async (_event, modelId) => {
    const config = loadConfig();
    config.model = modelId;
    saveConfig(config);
    // 根据模型推断provider
    const targetProvider = getProviderForModel(modelId);
    // 同步更新 ~/.duan/config.json 的 defaultModel 和 activeProfile 的 model
    try {
      const duanDir = path.join(os.homedir(), '.duan');
      const duanConfigPath = path.join(duanDir, 'config.json');
      let duanConfig = safeJsonRead(duanConfigPath, {});
      duanConfig.defaultModel = modelId;
      duanConfig.defaultProvider = targetProvider;
      // 更新当前活跃 profile 的 model 和 provider
      let profiles = duanConfig.profiles || [];
      if (!Array.isArray(profiles) && typeof profiles === 'object') {
        profiles = Object.entries(profiles).map(([id, p]) => ({ id, ...p }));
      }
      const activeProfileId = duanConfig.activeProfile || duanConfig.defaultProfileId;
      if (activeProfileId && profiles.length > 0) {
        const idx = profiles.findIndex(p => p.id === activeProfileId || p.provider === activeProfileId);
        if (idx >= 0) {
          profiles[idx].model = modelId;
          profiles[idx].provider = targetProvider;
        }
      }
      // 如果没有找到活跃 profile，更新 targetProvider 对应的 profile
      if (profiles.length > 0) {
        const idx = profiles.findIndex(p => p.provider === targetProvider);
        if (idx >= 0) {
          profiles[idx].model = modelId;
        } else {
          // 如果没有对应provider的profile，尝试从相同baseURL的其他provider复制apiKey
          const mapping = PROVIDER_MAP[targetProvider];
          let copiedKey = '';
          if (mapping && mapping.baseURL) {
            for (const p of profiles) {
              if (p.baseURL === mapping.baseURL && p.apiKey) {
                copiedKey = p.apiKey;
                break;
              }
            }
          }
          // 如果还是找不到，尝试从环境变量获取
          if (!copiedKey && mapping && mapping.envKey) {
            copiedKey = process.env[mapping.envKey] || '';
          }
          profiles.push({
            id: `${targetProvider}_${Date.now()}`,
            provider: targetProvider,
            label: targetProvider.charAt(0).toUpperCase() + targetProvider.slice(1),
            apiKey: copiedKey,
            baseURL: mapping ? mapping.baseURL : '',
            model: modelId,
            isDefault: true,
          });
        }
      }
      // 保存回 v2.0 对象格式（与 saveApiKeysToProfiles 一致）
      const profilesObj = {};
      for (const p of profiles) {
        const key = p.id || p.provider;
        profilesObj[key] = {
          provider: p.provider || '',
          apiKey: p.apiKey || '',
          model: p.model || '',
          baseUrl: p.baseURL || p.baseUrl || '',
          label: p.label || p.provider || key,
        };
      }
      duanConfig.profiles = profilesObj;
      duanConfig.configured = true;
      duanConfig.lastRun = Date.now();
      duanConfig.activeProfile = activeProfileId || Object.keys(profilesObj)[0] || '';
      markConfigSelfWrite();
      fs.writeFileSync(duanConfigPath, JSON.stringify(duanConfig, null, 2), 'utf-8');
      process.env.DEFAULT_MODEL = modelId;
      process.env.DEFAULT_MODEL_PROVIDER = targetProvider;
    } catch (err) {
      console.error('[Model] 同步更新 ~/.duan/config.json 失败:', err.message);
    }
    // 广播模型变更到所有渲染进程（B1 修复：前端实时感知供应商切换）
    try {
      mainWindow.webContents.send('model:changed', {
        model: modelId,
        provider: targetProvider,
        timestamp: Date.now(),
      });
    } catch (e) { /* 渲染进程未就绪时忽略 */ }
    return { success: true, model: modelId, provider: targetProvider };
  });

  // ----- 系统状态 -----
  safeHandle('system:status', async () => {
    const config = loadConfig();
    const duanConfig = loadDuanConfig();
    let statusProfiles = duanConfig.profiles || [];
    if (!Array.isArray(statusProfiles)) statusProfiles = Object.values(statusProfiles);
    const hasApiKey = statusProfiles.some(p => p.apiKey && p.apiKey.length > 8 && !p.apiKey.startsWith('your_'));

    // 读取技能数量（与技能管理页面一致：内置技能 + 用户学习技能）
    let skillCount = 0;
    try {
      // 用户学习技能
      const skillsJsonPath = path.join(os.homedir(), '.duan', 'learning', 'skills.json');
      if (fs.existsSync(skillsJsonPath)) {
        const raw = JSON.parse(fs.readFileSync(skillsJsonPath, 'utf-8'));
        const list = Array.isArray(raw) ? raw : (raw.skills || []);
        skillCount = list.length;
      }
    } catch { /* ignore */ }
    // 加上内置技能数（与技能管理页面 skills:remote 一致）
    try {
      const builtinDir = path.join(__dirname, '..', 'skills', 'builtin');
      if (fs.existsSync(builtinDir)) {
        const builtinEntries = fs.readdirSync(builtinDir).filter(f => {
          const p = path.join(builtinDir, f);
          return fs.statSync(p).isDirectory() && (fs.existsSync(path.join(p, 'SKILL.md')) || fs.existsSync(path.join(p, 'skill.json')));
        });
        skillCount += builtinEntries.length;
      }
    } catch { /* ignore */ }

    // 工具数量：从内置工具注册表统计（真实值）
    const toolCount = BUILTIN_TOOL_NAMES.length;

    // 读取目标数量
    let goalTotal = 0;
    let goalActive = 0;
    try {
      const goalsPath = path.join(os.homedir(), '.awareness', 'goals.json');
      if (fs.existsSync(goalsPath)) {
        const raw = JSON.parse(fs.readFileSync(goalsPath, 'utf-8'));
        const goals = Array.isArray(raw) ? raw : (raw.goals || []);
        goalTotal = goals.length;
        goalActive = goals.filter(g => g.status === 'active' || !g.completed).length;
      }
    } catch { /* ignore */ }

    // 读取心跳计数
    let beatCount = 0;
    try {
      const heartbeatPath = path.join(os.homedir(), '.awareness', 'heartbeat.json');
      if (fs.existsSync(heartbeatPath)) {
        const raw = JSON.parse(fs.readFileSync(heartbeatPath, 'utf-8'));
        beatCount = raw.beatCount || raw.count || 0;
      }
    } catch { /* ignore */ }
    // 如果文件不存在，根据运行时间估算心跳数
    if (beatCount === 0) beatCount = Math.floor(process.uptime() / 2);

    // 读取学习记录数量
    let recordCount = 0;
    try {
      const recordsPath = path.join(os.homedir(), '.duan', 'learning', 'records.json');
      if (fs.existsSync(recordsPath)) {
        const raw = JSON.parse(fs.readFileSync(recordsPath, 'utf-8'));
        recordCount = (Array.isArray(raw) ? raw : (raw.records || [])).length;
      }
    } catch { /* ignore */ }

    // 基于真实运行状态计算意识指标
    const agentRunning = !!agentProcess && !agentProcess.killed;
    const uptimeSec = process.uptime();
    // consciousness: 基于运行时间，越长越高（最高 0.95）
    const consciousnessLevel = Math.min(0.95, 0.3 + (uptimeSec / 3600) * 0.1);
    // focus: 有活跃任务则为 0.8，否则 0.5
    const focusLevel = agentRunning ? 0.8 : 0.5;
    // energy: 基于 CPU/内存使用率
    const mem = process.memoryUsage();
    const memRatio = mem.heapTotal > 0 ? mem.heapUsed / mem.heapTotal : 0;
    const cpu = process.cpuUsage();
    const cpuFraction = Math.min(1, ((cpu.user + cpu.system) / 1e6) / Math.max(1, uptimeSec));
    const energyLevel = Math.max(0.2, Math.min(0.95, 0.5 + cpuFraction * 0.3 - memRatio * 0.1));
    // curiosity: 默认值
    const curiosityLevel = 0.6;

    // 从 Web 服务器获取真实对话数和消息数
    let realConvCount = 0;
    let realMsgCount = 0;
    let realToolCalls = 0;
    if (agentRunning) {
      try {
        const convList = await fetchFromAgent('/api/conversations');
        if (Array.isArray(convList)) {
          realConvCount = convList.length;
          // 获取每个对话的消息数
          for (const conv of convList) {
            realMsgCount += conv.messageCount || 0;
          }
        }
        // 获取性能指标中的工具调用数
        const metrics = await fetchFromAgent('/api/performance/metrics');
        if (metrics && typeof metrics === 'object') {
          realToolCalls = metrics.toolCallsTotal || metrics.totalToolCalls || metrics.toolCallCount || 0;
        }
      } catch { /* ignore */ }
    }

    return {
      platform: process.platform,
      arch: process.arch,
      electronVersion: process.versions.electron,
      nodeVersion: process.versions.node,
      chromeVersion: process.versions.chrome,
      appVersion: app.getVersion(),
      agentRunning,
      agentPid: agentProcess?.pid ?? null,
      model: process.env.DEFAULT_MODEL || duanConfig.defaultModel || config.model || '未配置',
      apiProvider: config.apiProvider,
      uptime: uptimeSec,
      memoryUsage: mem,
      // 扩展字段用于前端状态面板
      version: app.getVersion() || '17.0',
      mode: 'desktop',
      skills: skillCount,
      toolsAvailable: toolCount,
      conversations: realConvCount || recordCount,
      messageCount: realMsgCount,
      toolCalls: realToolCalls,
      features: {
        smartDetection: hasApiKey,
        multiAgent: hasApiKey,
        streaming: hasApiKey,
        toolCalling: hasApiKey,
        conversationManagement: true,
        consciousness: uptimeSec > 60,
        goalSystem: goalTotal > 0,
        heartbeat: beatCount > 0,
        subAgents: hasApiKey,
      },
      consciousness: {
        mood: agentRunning ? 'focused' : 'neutral',
        consciousness: consciousnessLevel,
        focus: focusLevel,
        energy: energyLevel,
        curiosity: curiosityLevel,
        curiosityNote: '默认值',
        moodDescription: agentRunning ? 'Agent运行中' : (hasApiKey ? '待命' : '等待配置'),
      },
      selfAwareness: {
        evolutionLevel: hasApiKey ? 'desktop-v2' : 'desktop',
        capabilities: BUILTIN_TOOL_NAMES.map(n => TOOL_LABELS[n]).filter(Boolean),
        totalTasks: recordCount,
      },
      goals: { total: goalTotal, active: goalActive },
      heartbeat: { running: !!agentProcess, beatCount: beatCount },
    };
  });

  // ----- 远程对话（飞书/企业微信等通道的对话） -----
  // 从 Web 服务器 API 获取远程通道创建的对话

  /** 从 Agent Web 服务器获取数据 */
  async function fetchFromAgent(apiPath) {
    return new Promise((resolve) => {
      const req = http.request({
        hostname: 'localhost',
        port: agentPort,
        path: apiPath,
        method: 'GET',
        timeout: 5000,
      }, (res) => {
        let data = '';
        res.on('data', (chunk) => { data += chunk.toString(); });
        res.on('end', () => {
          try { resolve(JSON.parse(data)); }
          catch { resolve(null); }
        });
      });
      req.on('error', () => resolve(null));
      req.on('timeout', () => { req.destroy(); resolve(null); });
      req.end();
    });
  }

  // 获取远程对话列表（包括飞书/企业微信等通道的对话）
  safeHandle('conversations:remote', async () => {
    const list = await fetchFromAgent('/api/conversations');
    if (!list || !Array.isArray(list)) return { conversations: [] };
    // 标记远程通道对话
    const remoteConvs = list.filter(c => c.id && c.id.startsWith('bridge_'));
    return { conversations: remoteConvs };
  });

  // 获取远程对话的消息
  safeHandle('conversations:remote:messages', async (_event, { conversationId }) => {
    if (!conversationId) return { messages: [] };
    const messages = await fetchFromAgent(`/api/conversations/${conversationId}/messages`);
    if (!messages || !Array.isArray(messages)) return { messages: [] };
    return { messages };
  });

  // 获取仪表盘数据（从 Web 服务器 API 获取真实数据）
  safeHandle('dashboard:remote', async () => {
    const [metrics, report, snapshots, profile, sla, predAcc, recStats, skills, convList] = await Promise.all([
      fetchFromAgent('/api/performance/metrics'),
      fetchFromAgent('/api/eval/report'),
      fetchFromAgent('/api/eval/snapshots?limit=100'),
      fetchFromAgent('/api/profile/default'),
      fetchFromAgent('/api/performance/sla'),
      fetchFromAgent('/api/profile/prediction-accuracy'),
      fetchFromAgent('/api/profile/recommendation-stats'),
      fetchFromAgent('/api/skills'),
      fetchFromAgent('/api/conversations'),
    ]);

    const homeDir = os.homedir();

    // ===== 从本地文件系统读取真实数据（与 dashboard:data 相同的数据源）=====
    let totalConversations = 0;
    let totalMessages = 0;
    let totalToolCalls = 0;
    let toolCallSuccess = 0;
    let toolCallFail = 0;
    let totalLearningRecords = 0;
    let totalFeedbackFiles = 0;
    let avgFeedbackRating = 0;
    let configuredProviders = 0;
    let availableModels = 0;
    const recentToolUsage = {};
    const dailyMap = {};

    // 1. 对话历史统计: .duan/conversations/ 目录（真实数据源）
    try {
      const convDir = path.join(homeDir, '.duan', 'conversations');
      if (fs.existsSync(convDir)) {
        const convFiles = fs.readdirSync(convDir).filter(f => f.endsWith('.json'));
        totalConversations = convFiles.length;
        for (const cf of convFiles.slice(0, 100)) {
          try {
            const convData = JSON.parse(fs.readFileSync(path.join(convDir, cf), 'utf-8'));
            const msgs = convData.messages || [];
            totalMessages += msgs.length;
            for (const msg of msgs) {
              if (msg.toolCalls) {
                for (const tc of msg.toolCalls) {
                  totalToolCalls++;
                  const tName = tc.name || 'unknown';
                  recentToolUsage[tName] = (recentToolUsage[tName] || 0) + 1;
                  if (tc.status === 'success') toolCallSuccess++;
                  else if (tc.status === 'error') toolCallFail++;
                }
              }
              if (msg.timestamp) {
                const day = new Date(msg.timestamp).toISOString().slice(0, 10);
                dailyMap[day] = (dailyMap[day] || 0) + 1;
              }
            }
          } catch { /* ignore */ }
        }
      }
    } catch { /* ignore */ }

    // 如果本地无对话数据，回退到远程 API 的对话列表
    if (totalConversations === 0 && Array.isArray(convList)) {
      totalConversations = convList.length;
      for (const conv of convList) {
        totalMessages += conv.messageCount || 0;
      }
    }

    // 2. 学习记录: .duan/learning/records.json
    try {
      const recordsPath = path.join(homeDir, '.duan', 'learning', 'records.json');
      if (fs.existsSync(recordsPath)) {
        const raw = JSON.parse(fs.readFileSync(recordsPath, 'utf-8'));
        const records = Array.isArray(raw) ? raw : (raw.records || []);
        totalLearningRecords = records.length;
      }
    } catch { /* ignore */ }

    // 3. 反馈数据: .duan/feedback/
    try {
      const feedbackDir = path.join(homeDir, '.duan', 'feedback');
      if (fs.existsSync(feedbackDir)) {
        const feedbackFiles = fs.readdirSync(feedbackDir).filter(f => f.endsWith('.json'));
        totalFeedbackFiles = feedbackFiles.length;
        let totalRating = 0;
        let ratingCount = 0;
        for (const f of feedbackFiles) {
          try {
            const data = JSON.parse(fs.readFileSync(path.join(feedbackDir, f), 'utf-8'));
            if (data.rating) { totalRating += data.rating; ratingCount++; }
          } catch { /* ignore */ }
        }
        if (ratingCount > 0) avgFeedbackRating = totalRating / ratingCount;
      }
    } catch { /* ignore */ }

    // 4. 配置统计
    try {
      const config = loadConfig();
      const duanConfig = loadDuanConfig();
      if (config?.apiKeys) {
        configuredProviders = Object.keys(config.apiKeys).filter(k => config.apiKeys[k] && config.apiKeys[k] !== '未配置').length;
      }
      if (duanConfig?.profiles) {
        availableModels = duanConfig.profiles.reduce((sum, p) => sum + (p.models?.length || 0), 0);
      }
    } catch { /* ignore */ }

    // 5. 如果远程 metrics 有工具调用数据，也合并进来
    if (metrics && typeof metrics === 'object') {
      // performance-metrics 返回的是 toolCallSuccessRate（比率），不是计数
      // 只有当本地没有工具调用数据时才使用远程的比率估算
      if (totalToolCalls === 0 && metrics.totalInteractions > 0) {
        totalToolCalls = metrics.totalInteractions;
        if (metrics.toolCallSuccessRate !== undefined) {
          toolCallSuccess = Math.round(totalToolCalls * metrics.toolCallSuccessRate);
          toolCallFail = totalToolCalls - toolCallSuccess;
        }
      }
    }

    // 6. 每日活动数组
    const dailyActivity = Object.entries(dailyMap)
      .sort(([a], [b]) => a.localeCompare(b))
      .slice(-14)
      .map(([date, count]) => ({ date, count }));

    // 7. 如果远程 report 为空，尝试从本地 .awareness/cognitive-state.json 读取
    let finalReport = report;
    if (!finalReport) {
      try {
        const cognitivePath = path.join(homeDir, '.awareness', 'cognitive-state.json');
        if (fs.existsSync(cognitivePath)) {
          finalReport = JSON.parse(fs.readFileSync(cognitivePath, 'utf-8'));
          if (finalReport && typeof finalReport === 'object') {
            finalReport.dimensionScores = finalReport.dimensionScores || { accuracy: 0.5, efficiency: 0.5, coverage: 0.5, retention: 0.5, adaptation: 0.5 };
            finalReport.warnings = Array.isArray(finalReport.warnings) ? finalReport.warnings : [];
            finalReport.abTests = Array.isArray(finalReport.abTests) ? finalReport.abTests : [];
          }
        }
      } catch { /* ignore */ }
    }

    // 7.5 如果 report 的 abTests 为空，尝试从本地 eval-metrics/state.json 读取
    if (finalReport && (!finalReport.abTests || finalReport.abTests.length === 0)) {
      try {
        const evalStatePath = path.join(homeDir, '.duan', 'eval-metrics', 'state.json');
        if (fs.existsSync(evalStatePath)) {
          const evalState = JSON.parse(fs.readFileSync(evalStatePath, 'utf-8'));
          if (Array.isArray(evalState.abTests) && evalState.abTests.length > 0) {
            finalReport.abTests = evalState.abTests;
          }
        }
      } catch { /* ignore */ }
    }

    // 8. 如果远程 recStats 为空，尝试从本地反馈数据构建
    let finalRecStats = recStats;
    if (!finalRecStats && totalFeedbackFiles > 0) {
      finalRecStats = {
        totalRecommendations: totalFeedbackFiles,
        totalFeedback: totalFeedbackFiles,
        avgRating: avgFeedbackRating,
        serviceStats: [],
      };
    }

    const systemStats = {
      totalConversations,
      totalMessages,
      totalToolCalls,
      toolCallSuccess,
      toolCallFail,
      totalSkills: Array.isArray(skills) ? skills.length : 0,
      totalLearningRecords,
      totalFeedbackFiles,
      avgFeedbackRating: Math.round(avgFeedbackRating * 10) / 10,
      uptimeSeconds: process.uptime(),
      memoryUsage: Math.round(process.memoryUsage().heapUsed / 1024 / 1024),
      nodeVersion: process.version,
      platform: process.platform,
      configuredProviders,
      availableModels,
      recentToolUsage,
      dailyActivity,
    };

    return { metrics, report: finalReport, snapshots, profile, sla: sla && sla.overall ? sla : null, predAcc, recStats: finalRecStats, skills, systemStats };
  });

  // 获取技能列表（从 Web 服务器 API 获取真实数据）
  safeHandle('skills:remote', async () => {
    let remoteSkills = await fetchFromAgent('/api/skills');
    if (!remoteSkills || !Array.isArray(remoteSkills)) remoteSkills = [];

    const homeDir = os.homedir();
    const merged = [...remoteSkills];

    // 1. 合并内置技能（从本地文件扫描）
    const builtinSkills = [];
    const builtinDirs = [
      path.join(__dirname, 'skills', 'builtin'),
      path.join(__dirname, '..', 'skills', 'builtin'),
      path.join(process.cwd(), 'skills', 'builtin'),
    ];
    if (process.resourcesPath) {
      builtinDirs.push(path.join(process.resourcesPath, 'skills', 'builtin'));
      builtinDirs.push(path.join(process.resourcesPath, 'skills'));
    }
    // normalize id：统一为小写 kebab-case
    const normId = (s) => String(s || '').toLowerCase().replace(/[_\s]+/g, '-').replace(/[^a-z0-9-]/g, '');

    for (const bdir of builtinDirs) {
      try {
        if (!fs.existsSync(bdir)) continue;
        const stat = fs.statSync(bdir);
        if (!stat.isDirectory()) continue;
        const entries = fs.readdirSync(bdir);
        for (const entry of entries) {
          const skillMdPath = path.join(bdir, entry, 'SKILL.md');
          const skillJsonPath = path.join(bdir, entry, 'skill.json');
          if (fs.existsSync(skillMdPath)) {
            try {
              const content = fs.readFileSync(skillMdPath, 'utf-8');
              const fmMatch = content.match(/^---\n([\s\S]*?)\n---/);
              if (fmMatch) {
                const fields = parseSkillFrontmatter(fmMatch[1]);
                const id = getSkillField(fields, 'id') || entry;
                const name = getSkillField(fields, 'name') || entry;
                const domain = getSkillField(fields, 'domain') || 'general';
                const description = getSkillField(fields, 'description') || '';
                const tags = getSkillArrayField(fields, 'keywords');
                if (!builtinSkills.find(s => normId(s.id) === normId(id))) {
                  builtinSkills.push({
                    id, name, version: '1.0.0', description,
                    category: domain, tags,
                    successRate: 0, usageCount: 0,
                    source: 'builtin',
                    createdAt: Date.now(), updatedAt: Date.now(),
                  });
                }
              }
            } catch { /* ignore */ }
          } else if (fs.existsSync(skillJsonPath)) {
            try {
              const raw = JSON.parse(fs.readFileSync(skillJsonPath, 'utf-8'));
              if (!builtinSkills.find(s => normId(s.id) === normId(raw.id || raw.name))) {
                builtinSkills.push({
                  id: raw.id || raw.name, name: raw.name || raw.id,
                  version: raw.version || '1.0.0', description: raw.description || '',
                  category: raw.category || raw.domain || 'general', tags: raw.tags || [],
                  successRate: 0, usageCount: 0,
                  source: 'builtin',
                  createdAt: Date.now(), updatedAt: Date.now(),
                });
              }
            } catch { /* ignore */ }
          }
        }
      } catch { /* ignore */ }
    }
    // 合并内置技能到 merged（使用 normalize id 去重）
    for (const bs of builtinSkills) {
      if (!merged.find(s => normId(s.id) === normId(bs.id) || normId(s.name) === normId(bs.name))) {
        merged.push(bs);
      }
    }

    // 2. 合并用户学习技能（~/.duan/learning/skills.json）— 这是前端状态栏统计的技能数来源
    try {
      const userSkillsPath = path.join(homeDir, '.duan', 'learning', 'skills.json');
      if (fs.existsSync(userSkillsPath)) {
        const raw = JSON.parse(fs.readFileSync(userSkillsPath, 'utf-8'));
        const list = Array.isArray(raw) ? raw : (raw.skills || []);
        for (const s of list) {
          const sid = s.id || s.name;
          if (sid && !merged.find(x => normId(x.id) === normId(sid) || normId(x.name) === normId(s.name))) {
            merged.push({
              id: sid, name: s.name || s.id,
              version: s.version || '1.0.0', description: s.description || '',
              category: s.category || s.domain || 'development', tags: s.tags || [],
              successRate: s.successRate ?? s.success_rate ?? 0,
              usageCount: s.usageCount ?? s.usage_count ?? 0,
              source: 'learned',
              createdAt: s.createdAt || s.created_at || Date.now(),
              updatedAt: s.updatedAt || s.updated_at || Date.now(),
            });
          }
        }
      }
    } catch { /* ignore */ }

    // 2b. 合并 AI 生成的技能（从 generated-skills 目录读取 registry.json + .md 文件）
    try {
      const genSkillDirs = [
        path.join(process.cwd(), '.duan', 'generated-skills'),
        path.join(homeDir, '.duan', 'generated-skills'),
        path.join(__dirname, '.duan', 'generated-skills'),
        path.join(__dirname, '..', '.duan', 'generated-skills'),
      ];
      for (const genDir of genSkillDirs) {
        if (!fs.existsSync(genDir)) continue;
        // 读取 registry.json
        const registryPath = path.join(genDir, 'registry.json');
        if (fs.existsSync(registryPath)) {
          try {
            const registry = JSON.parse(fs.readFileSync(registryPath, 'utf-8'));
            const skills = registry.skills || registry;
            if (Array.isArray(skills)) {
              for (const s of skills) {
                const sid = s.id || s.name;
                if (sid && !merged.find(x => normId(x.id) === normId(sid) || normId(x.name) === normId(s.name))) {
                  merged.push({
                    id: sid, name: s.name || s.id,
                    version: s.version || '1.0.0', description: s.description || '',
                    category: s.category || 'automation', tags: s.tags || [],
                    successRate: s.successRate ?? 0, usageCount: s.usageCount ?? 0,
                    source: 'generated',
                    createdAt: s.createdAt || Date.now(),
                    updatedAt: s.updatedAt || Date.now(),
                  });
                }
              }
            }
          } catch { /* ignore */ }
        }
        // 也扫描 .md 文件（确保即使 registry.json 不存在也能读取）
        try {
          const files = fs.readdirSync(genDir).filter(f => f.endsWith('.md'));
          for (const file of files) {
            try {
              const content = fs.readFileSync(path.join(genDir, file), 'utf-8');
              const fmMatch = content.match(/^---\n([\s\S]*?)\n---/);
              if (fmMatch) {
                const fm = fmMatch[1];
                const getName = (k) => { const m = fm.match(new RegExp(`^${k}:\\s*(.+)$`, 'm')); return m ? m[1].trim() : ''; };
                const sid = getName('id') || file.replace('.md', '');
                const sname = getName('name') || sid;
                if (!merged.find(x => normId(x.id) === normId(sid) || normId(x.name) === normId(sname))) {
                  merged.push({
                    id: sid, name: sname,
                    version: getName('version') || '1.0.0',
                    description: getName('description') || '',
                    category: getName('category') || 'automation',
                    tags: [], successRate: 0, usageCount: 0,
                    source: 'generated',
                    createdAt: Date.now(), updatedAt: Date.now(),
                  });
                }
              }
            } catch { /* ignore */ }
          }
        } catch { /* ignore */ }
        break; // 只读取第一个存在的目录
      }
    } catch { /* ignore */ }

    // 3. 从学习记录和 Agent 服务器对话中统计真实的工具/技能使用数据
    // 工具名 → 技能 ID 映射（内置技能对应的工具）
    const TOOL_TO_SKILL = {
      'web_search': 'web-search', 'web_fetch': 'web-search',
      'browser_operate': 'browser-ops',
      'code_execute': 'code-generate', 'code_generate': 'code-generate',
      'file_read': 'file-ops', 'file_write': 'file-ops', 'file_list': 'file-ops', 'list_directory': 'file-ops',
      'shell_execute': 'shell-exec',
      'desktop_open': 'desktop-ops', 'desktop_operate': 'desktop-ops',
    };
    const usageMap = {}; // { skillId: { count, success, lastUsed } }

    // 3a. 从 ~/.duan/learning/records.json 读取真实学习记录（包含工具调用历史）
    try {
      const recordsPath = path.join(homeDir, '.duan', 'learning', 'records.json');
      if (fs.existsSync(recordsPath)) {
        const records = JSON.parse(fs.readFileSync(recordsPath, 'utf-8'));
        const list = Array.isArray(records) ? records : (records.records || []);
        for (const rec of list) {
          const tools = rec.tools || [];
          const success = rec.success === true;
          const ts = rec.timestamp ? new Date(rec.timestamp).getTime() : Date.now();
          for (const toolName of tools) {
            const skillId = TOOL_TO_SKILL[toolName];
            if (skillId) {
              if (!usageMap[skillId]) usageMap[skillId] = { count: 0, success: 0, lastUsed: 0 };
              usageMap[skillId].count++;
              if (success) usageMap[skillId].success++;
              if (ts > usageMap[skillId].lastUsed) usageMap[skillId].lastUsed = ts;
            }
            // 也按工具名本身记录（用于未映射的工具）
            if (!usageMap[toolName]) usageMap[toolName] = { count: 0, success: 0, lastUsed: 0 };
            usageMap[toolName].count++;
            if (success) usageMap[toolName].success++;
            if (ts > usageMap[toolName].lastUsed) usageMap[toolName].lastUsed = ts;
          }
        }
      }
    } catch { /* ignore */ }

    // 3b. 从 Agent 服务器获取对话历史，统计工具调用数据
    try {
      const convList = await fetchFromAgent('/api/conversations');
      if (Array.isArray(convList)) {
        for (const conv of convList.slice(0, 50)) {
          try {
            const msgs = await fetchFromAgent(`/api/conversations/${conv.id}/messages`);
            if (!Array.isArray(msgs)) continue;
            for (const msg of msgs) {
              if (msg.toolCalls && Array.isArray(msg.toolCalls)) {
                for (const tc of msg.toolCalls) {
                  const tName = tc.name || 'unknown';
                  const skillId = TOOL_TO_SKILL[tName] || tName;
                  const success = tc.status === 'success' || tc.success === true;
                  const ts = tc.timestamp ? new Date(tc.timestamp).getTime() : (conv.updatedAt ? new Date(conv.updatedAt).getTime() : Date.now());
                  if (!usageMap[skillId]) usageMap[skillId] = { count: 0, success: 0, lastUsed: 0 };
                  usageMap[skillId].count++;
                  if (success) usageMap[skillId].success++;
                  if (ts > usageMap[skillId].lastUsed) usageMap[skillId].lastUsed = ts;
                }
              }
            }
          } catch { /* ignore */ }
        }
      }
    } catch { /* ignore */ }

    // 3c. 将真实使用数据合并到技能列表
    for (const skill of merged) {
      const usage = usageMap[skill.id] || usageMap[skill.name];
      if (usage && usage.count > 0) {
        skill.usageCount = usage.count;
        skill.successRate = usage.success / usage.count;
        skill.lastUsed = usage.lastUsed || skill.updatedAt;
      }
    }

    // 3d. 过滤假技能：只保留有真实定义文件或有完整内容的技能（homeDir 已在上方声明）
    const realSkills = merged.filter(skill => {
      const sid = skill.id || skill.name;
      if (!sid) return false;

      // 内置技能：检查 SKILL.md 文件是否存在
      if (skill.source === 'builtin' || skill.category === 'builtin') {
        const builtinMd = path.join(__dirname, '..', 'skills', 'builtin', sid, 'SKILL.md');
        const builtinJson = path.join(__dirname, '..', 'skills', 'builtin', `${sid}.json`);
        return fs.existsSync(builtinMd) || fs.existsSync(builtinJson);
      }

      // AI 生成技能：检查 .md 文件是否存在
      if (skill.source === 'generated') {
        const genPath = path.join(homeDir, '.duan', 'generated-skills', `${sid}.md`);
        return fs.existsSync(genPath);
      }

      // 技能包：检查目录是否存在
      if (skill.source === 'package' || skill.source === 'user_defined') {
        const pkgDir = path.join(homeDir, '.duan', 'skills', sid);
        const pkgMd = path.join(pkgDir, 'SKILL.md');
        const discJson = path.join(homeDir, '.duan', 'skills', `${sid}.json`);
        const discMd = path.join(homeDir, '.duan', 'skills', `${sid}.md`);
        // 如果有定义文件，保留
        if (fs.existsSync(pkgMd) || fs.existsSync(discJson) || fs.existsSync(discMd)) return true;
        // 如果在 discovered.json 中有完整描述（不是空壳），保留
        if (skill.description && skill.description.length > 10) return true;
        // 否则过滤掉
        return false;
      }

      // 学习记录技能：检查是否有完整描述
      if (skill.source === 'learned' || skill.source === 'auto_learned') {
        // auto_learned 技能必须有描述和关键词，否则是假技能
        if (!skill.description || skill.description.length < 5) return false;
        if (!skill.keywords || skill.keywords.length === 0) return false;
        return true;
      }

      // 提取的技能：检查 .awareness/skills.json 中是否有内容
      if (skill.source === 'extracted') {
        return skill.description && skill.description.length > 5;
      }

      // 默认：有描述的保留
      return skill.description && skill.description.length > 0;
    });

    // 用过滤后的列表替换
    merged.length = 0;
    merged.push(...realSkills);

    // 4. 数据校验：确保字段完整性
    for (const s of merged) {
      s.successRate = typeof s.successRate === 'number' && !isNaN(s.successRate) ? s.successRate : 0;
      s.usageCount = typeof s.usageCount === 'number' && !isNaN(s.usageCount) ? s.usageCount : 0;
      s.tags = Array.isArray(s.tags) ? s.tags : [];
      s.version = s.version || '1.0.0';
      s.description = s.description || '';
      s.category = s.category || 'general';
      s.createdAt = s.createdAt || Date.now();
      s.updatedAt = s.updatedAt || s.createdAt;
    }

    return { skills: merged };
  });

  // 配对码生成（通过 IPC 转发到 Web 服务器）
  safeHandle('pairing:generate', async (_event, { note } = {}) => {
    try {
      const resp = await new Promise((resolve) => {
        const postData = JSON.stringify({ note: note || '' });
        const req = http.request({
          hostname: 'localhost', port: agentPort,
          path: '/api/pairing/generate', method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Content-Length': Buffer.byteLength(postData) },
          timeout: 10000,
        }, (res) => {
          let data = '';
          res.on('data', (chunk) => { data += chunk.toString(); });
          res.on('end', () => { try { resolve(JSON.parse(data)); } catch { resolve(null); } });
        });
        req.on('error', () => resolve(null));
        req.on('timeout', () => { req.destroy(); resolve(null); });
        req.write(postData);
        req.end();
      });
      return resp || { success: false, error: '无法连接到 Agent 服务' };
    } catch (e) {
      return { success: false, error: e.message };
    }
  });

  // 配对码列表
  safeHandle('pairing:codes', async () => {
    return await fetchFromAgent('/api/pairing/codes') || { success: false, codes: [] };
  });

  // 已配对用户列表
  safeHandle('pairing:users', async () => {
    return await fetchFromAgent('/api/pairing/users') || { success: false, users: [] };
  });

  // 配对系统状态
  safeHandle('pairing:status', async () => {
    return await fetchFromAgent('/api/pairing/status') || { success: false };
  });

  // 解除配对
  safeHandle('pairing:unpair', async (_event, { channel, userId }) => {
    try {
      const resp = await new Promise((resolve) => {
        const req = http.request({
          hostname: 'localhost', port: agentPort,
          path: `/api/pairing/users/${encodeURIComponent(channel)}/${encodeURIComponent(userId)}`,
          method: 'DELETE', timeout: 10000,
        }, (res) => {
          let data = '';
          res.on('data', (chunk) => { data += chunk.toString(); });
          res.on('end', () => { try { resolve(JSON.parse(data)); } catch { resolve(null); } });
        });
        req.on('error', () => resolve(null));
        req.on('timeout', () => { req.destroy(); resolve(null); });
        req.end();
      });
      return resp || { success: false, error: '无法连接到 Agent 服务' };
    } catch (e) {
      return { success: false, error: e.message };
    }
  });

  // 定期检查远程对话更新，通知前端
  let lastRemoteConvCount = 0;
  let remotePollTimer = null;
  function startRemoteConvPoller() {
    if (remotePollTimer) clearInterval(remotePollTimer);
    remotePollTimer = setInterval(async () => {
      // P1 修复：检查 mainWindow 是否已销毁，避免 webContents.send 抛出异常
      if (!agentProcess || !mainWindow || mainWindow.isDestroyed()) return;
      const list = await fetchFromAgent('/api/conversations');
      if (!list || !Array.isArray(list)) return;
      // await 后再次检查窗口状态
      if (!mainWindow || mainWindow.isDestroyed()) return;
      const remoteConvs = list.filter(c => c.id && c.id.startsWith('bridge_'));
      if (remoteConvs.length > lastRemoteConvCount) {
        lastRemoteConvCount = remoteConvs.length;
        // 通知前端有新的远程消息
        mainWindow.webContents.send('remote:conversationsUpdated', { conversations: remoteConvs });
      }
    }, 5000); // 每 5 秒检查一次
  }
  startRemoteConvPoller();

  // ----- 窗口控制（自定义标题栏） -----
  safeHandle('window:minimize', async (_event) => {
    const win = BrowserWindow.fromWebContents(_event.sender);
    if (win) win.minimize();
    return { success: true };
  });

  safeHandle('window:maximize', async (_event) => {
    const win = BrowserWindow.fromWebContents(_event.sender);
    if (!win) return { success: false };
    if (win.isMaximized()) {
      win.unmaximize();
    } else {
      win.maximize();
    }
    return { success: true, maximized: win.isMaximized() };
  });

  safeHandle('window:close', async (_event) => {
    const win = BrowserWindow.fromWebContents(_event.sender);
    if (win) win.close();
    return { success: true };
  });

  // ----- 自动更新 -----
  ipcMain.handle('updater:check', async () => {
    if (!autoUpdater) {
      return { available: false, error: '自动更新未启用' };
    }
    try {
      const result = await autoUpdater.checkForUpdates();
      return { available: result !== null, version: result?.updateInfo?.version };
    } catch (err) {
      return { available: false, error: err.message };
    }
  });

  ipcMain.handle('updater:install', async () => {
    try {
      if (autoUpdater) {
        isQuitting = true;
        autoUpdater.quitAndInstall();
      }
      return { success: true };
    } catch (err) {
      console.error('[IPC] updater:install 失败:', err.message);
      return { success: false, error: err.message };
    }
  });

  // ----- 代码编辑器（P0-2 修复：路径校验 + 敏感路径防护）-----
  ipcMain.handle('editor:readFile', async (_event, filePath) => {
    try {
      const check = validateEditorPath(filePath);
      if (!check.ok) return { success: false, error: check.error };
      const content = fs.readFileSync(check.resolved, 'utf-8');
      // 限制读取大小（10MB），防止内存溢出
      const MAX_READ_SIZE = 10 * 1024 * 1024;
      if (Buffer.byteLength(content) > MAX_READ_SIZE) {
        return { success: false, error: `文件过大（超过 10MB），请使用专业编辑器打开` };
      }
      return { success: true, content };
    } catch (err) {
      return { success: false, error: err.message };
    }
  });

  ipcMain.handle('editor:saveFile', async (_event, filePath, content) => {
    try {
      const check = validateEditorPath(filePath);
      if (!check.ok) return { success: false, error: check.error };
      // 限制写入大小（10MB）
      const MAX_WRITE_SIZE = 10 * 1024 * 1024;
      if (content && Buffer.byteLength(content) > MAX_WRITE_SIZE) {
        return { success: false, error: `内容过大（超过 10MB），无法保存` };
      }
      fs.writeFileSync(check.resolved, content, 'utf-8');
      return { success: true };
    } catch (err) {
      return { success: false, error: err.message };
    }
  });

  ipcMain.handle('editor:readDir', async (_event, dirPath) => {
    try {
      const check = validateEditorPath(dirPath);
      if (!check.ok) return { success: false, error: check.error };
      // P0 工具融合：editor:goto 由 tool-executor.js 直接 send 到 renderer，
      // 此处无需 handler，但保留占位以便未来扩展（如跨窗口跳转）。

      // 递归深度限制（防止遍历整个磁盘）
      const MAX_DEPTH = 10;
      // 单目录条目数限制
      const MAX_ENTRIES_PER_DIR = 2000;

      function readDirRecursive(dir, baseDir = dir, depth = 0) {
        if (depth > MAX_DEPTH) return [];
        const items = fs.readdirSync(dir, { withFileTypes: true });
        const limited = items.slice(0, MAX_ENTRIES_PER_DIR);
        return limited.map(item => {
          const fullPath = path.join(dir, item.name);
          const relativePath = path.relative(baseDir, fullPath);
          // 跳过敏感路径
          if (isSensitivePath(fullPath)) return null;
          if (item.isDirectory()) {
            return {
              name: item.name,
              path: fullPath,
              type: 'directory',
              children: readDirRecursive(fullPath, baseDir, depth + 1)
            };
          }
          return {
            name: item.name,
            path: fullPath,
            type: 'file',
            ext: path.extname(item.name).slice(1)
          };
        }).filter(Boolean);
      }
      const tree = readDirRecursive(check.resolved);
      return { success: true, tree };
    } catch (err) {
      return { success: false, error: err.message };
    }
  });

  // ----- 技能管理（从本地文件读取真实数据，含缓存与实时同步） -----
  // 技能缓存：避免每次调用都重新扫描文件系统
  let skillCache = null; // { skills: Array, timestamp: number, hash: string }
  const SKILL_CACHE_TTL = 30000; // 30秒缓存有效期
  let skillCacheInvalidated = false; // 文件变更时立即失效

  // 解析 SKILL.md frontmatter，支持单行值和多行数组（keywords/examples）
  function parseSkillFrontmatter(fm) {
    const fields = {};
    const lines = fm.split('\n');
    let i = 0;
    while (i < lines.length) {
      const line = lines[i];
      const single = line.match(/^(\w+)\s*:\s*(.+)$/);
      if (single) {
        fields[single[1]] = single[2].trim().replace(/^['"]|['"]$/g, '');
        i++;
        continue;
      }
      const arrayHeader = line.match(/^(\w+)\s*:\s*$/);
      if (arrayHeader) {
        const key = arrayHeader[1];
        const items = [];
        i++;
        while (i < lines.length) {
          const itemMatch = lines[i].match(/^\s+-\s+(.+)$/);
          if (itemMatch) { items.push(itemMatch[1].trim().replace(/^['"]|['"]$/g, '')); i++; }
          else break;
        }
        if (items.length > 0) fields[key] = items;
        continue;
      }
      i++;
    }
    return fields;
  }
  function getSkillField(fields, k) {
    const v = fields[k];
    if (!v) return '';
    if (Array.isArray(v)) return v.join(', ');
    return String(v);
  }
  function getSkillArrayField(fields, k) {
    const v = fields[k];
    if (!v) return [];
    if (Array.isArray(v)) return v;
    return String(v).split(',').map(s => s.trim()).filter(Boolean);
  }

  // 计算技能数据指纹（用于检测数据是否真的变化）
  function computeSkillHash(skills) {
    try {
      const sig = skills.map(s => `${s.id}:${s.updatedAt || 0}:${s.usageCount || 0}`).sort().join('|');
      let h = 0;
      for (let i = 0; i < sig.length; i++) {
        h = ((h << 5) - h) + sig.charCodeAt(i);
        h |= 0;
      }
      return String(h);
    } catch { return ''; }
  }

  // 通知所有渲染窗口技能数据已更新
  function notifySkillsUpdated(skills) {
    try {
      if (mainWindow && !mainWindow.isDestroyed()) {
        mainWindow.webContents.send('skill:updated', { skills, timestamp: Date.now() });
      }
    } catch (e) {
      console.warn('[skill] 通知更新失败:', e.message);
    }
  }

  // 监听技能目录变化（实时同步）
  // P1-5 修复：使用模块作用域的 skillWatchers 变量
  function setupSkillWatchers() {
    // 清理旧的 watcher
    for (const w of skillWatchers) { try { w.close(); } catch {} }
    skillWatchers = [];

    const homeDir = os.homedir();
    const watchDirs = [
      path.join(homeDir, '.duan', 'learning'),
      path.join(homeDir, '.awareness'),
      path.join(homeDir, '.learnings'),
      path.join(homeDir, '.duan', 'conversations'),
      path.join(__dirname, '..', 'skills', 'builtin'),
      path.join(__dirname, '..', 'skills', 'custom'),
    ];

    for (const dir of watchDirs) {
      try {
        if (!fs.existsSync(dir)) continue;
        const stat = fs.statSync(dir);
        if (!stat.isDirectory()) continue;
        const watcher = fs.watch(dir, { persistent: false }, (eventType) => {
          if (eventType === 'change' || eventType === 'rename') {
            // 标记缓存失效，下次读取时重新加载
            skillCacheInvalidated = true;
            console.log(`[skill] 检测到目录变化: ${dir}, 缓存已失效`);
          }
        });
        skillWatchers.push(watcher);
      } catch (e) {
        console.warn(`[skill] 无法监听目录 ${dir}:`, e.message);
      }
    }
  }
  setupSkillWatchers();

  ipcMain.handle('skill:list', async () => {
    try {
      // 检查缓存是否有效
      const now = Date.now();
      if (skillCache && !skillCacheInvalidated && (now - skillCache.timestamp) < SKILL_CACHE_TTL) {
        return { success: true, skills: skillCache.skills, cached: true };
      }

      const homeDir = os.homedir();
      const skills = [];

      // 0. 扫描打包内置技能目录（skills/builtin/*/SKILL.md）
      const bundledDirs = [];
      if (process.resourcesPath) {
        bundledDirs.push(path.join(process.resourcesPath, 'skills', 'builtin'));
        bundledDirs.push(path.join(process.resourcesPath, 'skills'));
      }
      bundledDirs.push(path.join(__dirname, 'skills', 'builtin'));
      bundledDirs.push(path.join(__dirname, '..', 'skills', 'builtin'));
      bundledDirs.push(path.join(process.cwd(), 'skills', 'builtin'));

      for (const bdir of bundledDirs) {
        try {
          if (!fs.existsSync(bdir)) continue;
          const stat = fs.statSync(bdir);
          if (!stat.isDirectory()) continue;
          const entries = fs.readdirSync(bdir);
          for (const entry of entries) {
            const skillMdPath = path.join(bdir, entry, 'SKILL.md');
            const skillJsonPath = path.join(bdir, entry, 'skill.json');
            if (fs.existsSync(skillMdPath)) {
              try {
                const content = fs.readFileSync(skillMdPath, 'utf-8');
                // 解析 YAML frontmatter
                const fmMatch = content.match(/^---\n([\s\S]*?)\n---/);
                if (fmMatch) {
                  const fields = parseSkillFrontmatter(fmMatch[1]);
                  const id = getSkillField(fields, 'id') || entry;
                  const name = getSkillField(fields, 'name') || entry;
                  const domain = getSkillField(fields, 'domain') || 'general';
                  const description = getSkillField(fields, 'description') || '';
                  const tags = getSkillArrayField(fields, 'keywords');
                  if (!skills.find(s => s.id === id)) {
                    skills.push({
                      id, name, version: '1.0.0', description,
                      category: domain, tags,
                      successRate: 0, usageCount: 0,
                      source: 'builtin',
                      createdAt: Date.now(), updatedAt: Date.now(),
                    });
                  }
                }
              } catch { /* ignore */ }
            } else if (fs.existsSync(skillJsonPath)) {
              try {
                const raw = JSON.parse(fs.readFileSync(skillJsonPath, 'utf-8'));
                if (!skills.find(s => s.id === (raw.id || raw.name))) {
                  skills.push({
                    id: raw.id || raw.name, name: raw.name || raw.id,
                    version: raw.version || '1.0.0', description: raw.description || '',
                    category: raw.domain || raw.category || 'general', tags: raw.keywords || [],
                    successRate: 0, usageCount: 0, source: 'builtin',
                    createdAt: Date.now(), updatedAt: Date.now(),
                  });
                }
              } catch { /* ignore */ }
            }
          }
        } catch { /* ignore */ }
      }

      // 1. 从 .duan/learning/skills.json 读取
      const skillsJsonPath = path.join(homeDir, '.duan', 'learning', 'skills.json');
      if (fs.existsSync(skillsJsonPath)) {
        try {
          const raw = JSON.parse(fs.readFileSync(skillsJsonPath, 'utf-8'));
          const list = Array.isArray(raw) ? raw : (raw.skills || []);
          for (const s of list) {
            const sid = s.id || s.name;
            if (!skills.find(x => x.id === sid)) {
              skills.push({
                id: sid, name: s.name || s.id,
                version: s.version || '1.0.0', description: s.description || '',
                category: s.category || 'development', tags: s.tags || [],
                successRate: s.successRate ?? s.success_rate ?? 0,
                usageCount: s.usageCount ?? s.usage_count ?? 0,
                source: 'learned',
                createdAt: s.createdAt || s.created_at || Date.now(),
                updatedAt: s.updatedAt || s.updated_at || Date.now(),
              });
            }
          }
        } catch { /* ignore */ }
      }

      // 2. 从 .learnings/EXTRACTED_SKILLS.md 读取
      const extractedPath = path.join(homeDir, '.learnings', 'EXTRACTED_SKILLS.md');
      if (fs.existsSync(extractedPath)) {
        try {
          const content = fs.readFileSync(extractedPath, 'utf-8');
          const skillBlocks = content.split(/^## /m).filter(b => b.trim());
          for (const block of skillBlocks) {
            const lines = block.split('\n');
            const name = lines[0].trim().replace(/^#+\s*/, '');
            if (name && !skills.find(s => s.name === name)) {
              skills.push({
                id: name.toLowerCase().replace(/\s+/g, '-'),
                name, version: '1.0.0',
                description: lines.slice(1, 3).join(' ').trim().substring(0, 100) || '',
                category: 'development', tags: [],
                successRate: 0, usageCount: 0, source: 'extracted',
                createdAt: fs.statSync(extractedPath).mtimeMs,
                updatedAt: fs.statSync(extractedPath).mtimeMs,
              });
            }
          }
        } catch { /* ignore */ }
      }

      // 3. 从对话历史中统计技能使用数据: .duan/conversations/
      try {
        const convDir = path.join(homeDir, '.duan', 'conversations');
        if (fs.existsSync(convDir)) {
          const convFiles = fs.readdirSync(convDir).filter(f => f.endsWith('.json'));
          const usageMap = /** @type {Record<string, {count:number,success:number}>} */ ({});
          for (const cf of convFiles.slice(0, 100)) {
            try {
              const convData = JSON.parse(fs.readFileSync(path.join(convDir, cf), 'utf-8'));
              const msgs = convData.messages || [];
              for (const msg of msgs) {
                if (msg.toolCalls) {
                  for (const tc of msg.toolCalls) {
                    const tName = tc.name || 'unknown';
                    if (!usageMap[tName]) usageMap[tName] = { count: 0, success: 0 };
                    usageMap[tName].count++;
                    if (tc.status === 'success') usageMap[tName].success++;
                  }
                }
              }
            } catch { /* ignore */ }
          }
          // 将使用数据合并到技能列表
          for (const skill of skills) {
            const usage = usageMap[skill.id] || usageMap[skill.name];
            if (usage) {
              skill.usageCount = usage.count;
              skill.successRate = usage.count > 0 ? usage.success / usage.count : 0;
            }
          }
          // 不再把不在技能列表中的工具作为"工具技能"添加
          // 这些只是工具调用记录，不是真正的技能定义，打开会提示"技能不存在"
        }
      } catch { /* ignore */ }

      // 数据校验：过滤掉无效技能数据，确保字段完整性
      const validSkills = skills.filter(s => {
        if (!s || !s.id || !s.name) return false;
        // 确保数值字段为有效数字
        s.successRate = typeof s.successRate === 'number' && !isNaN(s.successRate) ? s.successRate : 0;
        s.usageCount = typeof s.usageCount === 'number' && !isNaN(s.usageCount) ? s.usageCount : 0;
        s.tags = Array.isArray(s.tags) ? s.tags : [];
        s.version = s.version || '1.0.0';
        s.description = s.description || '';
        s.category = s.category || 'general';
        s.createdAt = s.createdAt || Date.now();
        s.updatedAt = s.updatedAt || s.createdAt;
        return true;
      });

      // 更新缓存
      const newHash = computeSkillHash(validSkills);
      const dataChanged = !skillCache || skillCache.hash !== newHash;
      skillCache = { skills: validSkills, timestamp: Date.now(), hash: newHash };
      skillCacheInvalidated = false;

      // 如果数据真的变化了，通知前端实时更新
      if (dataChanged) {
        notifySkillsUpdated(validSkills);
      }

      return { success: true, skills: validSkills, cached: false };
    } catch (err) {
      console.error('[skill:list] 异常:', err.message);
      return { success: false, skills: [], error: err.message };
    }
  });

  // 手动刷新技能缓存（强制重新加载）
  safeHandle('skill:refresh', async () => {
    skillCacheInvalidated = true;
    skillCache = null;
    return { success: true };
  });

  ipcMain.handle('skill:detail', async (_event, skillId) => {
    try {
      if (!skillId || typeof skillId !== 'string') {
        return { success: false, error: '无效的技能 ID', quality: null, versions: [], content: '' };
      }
      // 安全：字符白名单校验，防止路径遍历（与 skill:delete 一致）
      if (!/^[a-zA-Z0-9_\-]+$/.test(skillId)) {
        return { success: false, error: '技能 ID 包含非法字符，仅允许字母、数字、下划线和连字符', quality: null, versions: [], content: '' };
      }
      // 安全：拒绝包含路径分隔符的输入（深度防御）
      if (skillId.includes('..') || skillId.includes('/') || skillId.includes('\\')) {
        return { success: false, error: '技能 ID 不能包含路径分隔符', quality: null, versions: [], content: '' };
      }

      const homeDir = os.homedir();
      let content = '';

      // 读取 SKILL.md 内容（修复：Electron 模式下之前未返回 content）
      const contentSearchPaths = [
        path.join(__dirname, '..', 'skills', 'builtin', skillId, 'SKILL.md'),
        path.join(__dirname, '..', 'skills', 'builtin', `${skillId}.md`),
        path.join(__dirname, '..', 'skills', 'custom', `${skillId}.md`),
        path.join(homeDir, '.duan', 'skills', `${skillId}.md`),
        path.join(homeDir, '.learnings', 'EXTRACTED_SKILLS.md'),
      ];
      for (const p of contentSearchPaths) {
        try {
          if (fs.existsSync(p)) {
            const raw = fs.readFileSync(p, 'utf-8');
            // 如果是 EXTRACTED_SKILLS.md，提取对应技能的章节
            if (p.endsWith('EXTRACTED_SKILLS.md')) {
              // 安全：skillId 已通过白名单校验，可安全用于正则构造
              const escapedId = skillId.replace(/[-_]/g, '[\\s\\-_]?');
              const blockMatch = raw.match(new RegExp(`^##\\s+${escapedId}[\\s\\S]*?(?=^##\\s|$)`, 'm'));
              if (blockMatch) { content = blockMatch[0]; break; }
            } else {
              content = raw;
              break;
            }
          }
        } catch (e) {
          console.warn(`[skill:detail] 读取内容失败 ${p}:`, e.message);
        }
      }

      // 从 .awareness/skills.json 读取质量评估
      const awarenessPath = path.join(homeDir, '.awareness', 'skills.json');
      let quality = null;
      if (fs.existsSync(awarenessPath)) {
        try {
          const raw = JSON.parse(fs.readFileSync(awarenessPath, 'utf-8'));
          const list = Array.isArray(raw) ? raw : (raw.skills || []);
          const found = list.find(s => s.id === skillId || s.name === skillId);
          if (found) {
            quality = {
              skillId: found.id || found.name,
              overallScore: found.overallScore ?? found.qualityScore ?? 0,
              dimensions: found.dimensions || { correctness: 0, completeness: 0, usability: 0, performance: 0 },
              executionSuccessRate: found.executionSuccessRate ?? found.successRate ?? 0,
              sampleSize: found.sampleSize ?? found.usageCount ?? 0,
              recommendations: found.recommendations || [],
            };
          }
        } catch { /* ignore */ }
      }

      // 从技能文件读取版本历史
      let versions = [];
      try {
        // 1. 内置技能
        const builtinPath = path.join(__dirname, '..', 'skills', 'builtin', `${skillId}.json`);
        if (fs.existsSync(builtinPath)) {
          const data = JSON.parse(fs.readFileSync(builtinPath, 'utf-8'));
          versions.push({ version: data.version || '1.0.0', createdAt: data.createdAt || Date.now(), message: '初始版本' });
          if (data.updatedAt && data.updatedAt !== data.createdAt) {
            versions.push({ version: data.version || '1.0.0', createdAt: data.updatedAt, message: '更新' });
          }
        }
        // 2. 用户学习技能
        const userSkillsPath = path.join(homeDir, '.duan', 'learning', 'skills.json');
        if (fs.existsSync(userSkillsPath)) {
          const raw = JSON.parse(fs.readFileSync(userSkillsPath, 'utf-8'));
          const list = Array.isArray(raw) ? raw : (raw.skills || []);
          const found = list.find(s => s.id === skillId || s.name === skillId);
          if (found) {
            versions.push({ version: found.version || '1.0.0', createdAt: found.createdAt || Date.now(), message: '技能创建' });
            if (found.updatedAt && found.updatedAt !== found.createdAt) {
              versions.push({ version: found.version || '1.0.0', createdAt: found.updatedAt, message: '技能更新' });
            }
          }
        }
        // 3. 从对话历史中提取工具使用记录作为版本
        const convDir = path.join(homeDir, '.duan', 'conversations');
        if (fs.existsSync(convDir)) {
          const convFiles = fs.readdirSync(convDir).filter(f => f.endsWith('.json')).slice(-20);
          for (const cf of convFiles) {
            try {
              const convData = JSON.parse(fs.readFileSync(path.join(convDir, cf), 'utf-8'));
              const msgs = convData.messages || [];
              for (const msg of msgs) {
                if (msg.toolCalls) {
                  for (const tc of msg.toolCalls) {
                    if (tc.name === skillId && msg.timestamp) {
                      const existing = versions.find(v => Math.abs(v.createdAt - new Date(msg.timestamp).getTime()) < 60000);
                      if (!existing) {
                        versions.push({
                          version: `v${versions.length + 1}.0`,
                          createdAt: new Date(msg.timestamp).getTime(),
                          message: `工具调用: ${tc.status === 'success' ? '成功' : '失败'}`,
                        });
                      }
                    }
                  }
                }
              }
            } catch { /* ignore */ }
          }
        }
        // 按时间排序
        versions.sort((a, b) => a.createdAt - b.createdAt);
      } catch { /* ignore */ }

      return { success: true, quality, versions, content };
    } catch (err) {
      console.error('[skill:detail] 异常:', err.message);
      return { success: false, quality: null, versions: [], content: '', error: err.message };
    }
  });

  // 删除技能（仅允许删除用户学习技能，不允许删除内置技能）
  ipcMain.handle('skill:delete', async (_event, skillId) => {
    try {
      if (!skillId || typeof skillId !== 'string') {
        return { success: false, error: '无效的技能 ID' };
      }

      // 安全校验：仅允许安全字符，防止路径遍历
      if (!/^[a-zA-Z0-9_\-]+$/.test(skillId)) {
        return { success: false, error: '技能 ID 包含非法字符（仅允许字母、数字、下划线、连字符）' };
      }
      if (skillId.includes('..') || skillId.includes('/') || skillId.includes('\\')) {
        return { success: false, error: '技能 ID 包含非法路径字符' };
      }

      const homeDir = os.homedir();
      let deleted = false;
      const deletedFrom = [];

      // 1. 内置技能禁止删除（修复路径：实际格式是 {skillId}/SKILL.md）
      const builtinDir = path.join(__dirname, '..', 'skills', 'builtin', skillId);
      const builtinMd = path.join(builtinDir, 'SKILL.md');
      const builtinJson = path.join(__dirname, '..', 'skills', 'builtin', `${skillId}.json`);
      if (fs.existsSync(builtinMd) || fs.existsSync(builtinJson) || fs.existsSync(builtinDir)) {
        return { success: false, error: '内置技能不允许删除' };
      }

      // 2. 从用户学习技能文件中删除
      const userSkillsPath = path.join(homeDir, '.duan', 'learning', 'skills.json');
      if (fs.existsSync(userSkillsPath)) {
        try {
          const raw = JSON.parse(fs.readFileSync(userSkillsPath, 'utf-8'));
          const list = Array.isArray(raw) ? raw : (raw.skills || []);
          const filtered = list.filter(s => (s.id || s.name) !== skillId);
          if (filtered.length !== list.length) {
            const newData = Array.isArray(raw) ? filtered : { ...raw, skills: filtered };
            fs.writeFileSync(userSkillsPath, JSON.stringify(newData, null, 2), 'utf-8');
            deleted = true;
            deletedFrom.push('用户学习技能');
          }
        } catch (e) {
          console.error('[skill:delete] 删除用户技能失败:', e.message);
        }
      }

      // 3. 从 .awareness/skills.json 中删除质量评估记录
      const awarenessPath = path.join(homeDir, '.awareness', 'skills.json');
      if (fs.existsSync(awarenessPath)) {
        try {
          const raw = JSON.parse(fs.readFileSync(awarenessPath, 'utf-8'));
          const list = Array.isArray(raw) ? raw : (raw.skills || []);
          const filtered = list.filter(s => (s.id || s.name) !== skillId);
          if (filtered.length !== list.length) {
            const newData = Array.isArray(raw) ? filtered : { ...raw, skills: filtered };
            fs.writeFileSync(awarenessPath, JSON.stringify(newData, null, 2), 'utf-8');
            deleted = true;
            deletedFrom.push('质量评估记录');
          }
        } catch (e) {
          console.error('[skill:delete] 删除质量评估失败:', e.message);
        }
      }

      // 4. 删除独立的技能文件（覆盖所有存储位置）
      const standalonePaths = [
        path.join(homeDir, '.duan', 'skills', `${skillId}.json`),
        path.join(homeDir, '.duan', 'skills', `${skillId}.md`),
        path.join(homeDir, '.duan', 'generated-skills', `${skillId}.md`),  // AI 生成技能
        path.join(__dirname, '..', 'skills', 'custom', `${skillId}.json`),
        path.join(__dirname, '..', 'skills', 'custom', `${skillId}.md`),
      ];
      for (const p of standalonePaths) {
        if (fs.existsSync(p)) {
          try {
            fs.unlinkSync(p);
            deleted = true;
            deletedFrom.push(`文件: ${path.basename(p)}`);
          } catch (e) {
            console.error(`[skill:delete] 删除文件 ${p} 失败:`, e.message);
          }
        }
      }

      // 5. 删除技能包目录（~/.duan/skills/{skillId}/）
      const skillPkgDir = path.join(homeDir, '.duan', 'skills', skillId);
      if (fs.existsSync(skillPkgDir) && fs.statSync(skillPkgDir).isDirectory()) {
        try {
          fs.rmSync(skillPkgDir, { recursive: true, force: true });
          deleted = true;
          deletedFrom.push('技能包目录');
        } catch (e) {
          console.error(`[skill:delete] 删除技能包目录失败:`, e.message);
        }
      }

      // 6. 从 discovered.json 中删除（SkillDiscovery 系统）
      const discoveredPath = path.join(homeDir, '.duan', 'skills', 'discovered.json');
      if (fs.existsSync(discoveredPath)) {
        try {
          const discovered = JSON.parse(fs.readFileSync(discoveredPath, 'utf-8'));
          const list = Array.isArray(discovered) ? discovered : (discovered.skills || []);
          const filtered = list.filter(s => (s.id || s.name) !== skillId);
          if (filtered.length !== list.length) {
            const newData = Array.isArray(discovered) ? filtered : { ...discovered, skills: filtered };
            fs.writeFileSync(discoveredPath, JSON.stringify(newData, null, 2), 'utf-8');
            deleted = true;
            deletedFrom.push('发现技能记录');
          }
        } catch (e) {
          console.error('[skill:delete] 删除发现技能记录失败:', e.message);
        }
      }

      // 7. 从 generated-skills/registry.json 中删除（SkillGenerator 系统）
      const registryPath = path.join(homeDir, '.duan', 'generated-skills', 'registry.json');
      if (fs.existsSync(registryPath)) {
        try {
          const registry = JSON.parse(fs.readFileSync(registryPath, 'utf-8'));
          const skills = registry.skills || {};
          if (skills[skillId]) {
            delete skills[skillId];
            registry.skills = skills;
            // 同时清理 versions 和 qualityLog
            if (registry.versions) delete registry.versions[skillId];
            if (registry.qualityLog) registry.qualityLog = registry.qualityLog.filter(q => q.skillId !== skillId);
            fs.writeFileSync(registryPath, JSON.stringify(registry, null, 2), 'utf-8');
            deleted = true;
            deletedFrom.push('生成技能注册表');
          }
        } catch (e) {
          console.error('[skill:delete] 删除生成技能注册表失败:', e.message);
        }
      }

      // 8. 尝试通过 Agent 服务器 API 删除（确保服务器端也清理）
      try {
        await fetchFromAgent(`/api/skills/${encodeURIComponent(skillId)}`, { method: 'DELETE' });
      } catch { /* 忽略服务器端错误，本地删除优先 */ }

      if (!deleted) {
        return { success: false, error: `未找到技能: ${skillId}` };
      }

      // 删除后使缓存失效
      skillCacheInvalidated = true;
      skillCache = null;

      console.log(`[skill:delete] 已删除技能 ${skillId}, 来源: ${deletedFrom.join(', ')}`);
      return { success: true, deletedFrom };
    } catch (err) {
      console.error('[skill:delete] 异常:', err.message);
      return { success: false, error: err.message };
    }
  });

  // ----- 从成功案例打包真实技能 -----
  // 接收成功的对话/工具调用记录，生成完整的 SKILL.md 定义文件
  safeHandle('skill:package', async (_event, params) => {
    try {
      const { name, description, intent, toolsUsed, steps, keywords, examples, conversationSnippet } = params || {};
      if (!name || !description) {
        return { success: false, error: '技能名称和描述不能为空' };
      }
      // 安全校验技能名
      const skillId = name.toLowerCase().replace(/[^a-z0-9_\-]/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '');
      if (!skillId || !/^[a-z0-9_\-]+$/.test(skillId)) {
        return { success: false, error: '技能名称无效（仅允许小写字母、数字、下划线、连字符）' };
      }

      const homeDir = os.homedir();
      const skillDir = path.join(homeDir, '.duan', 'skills', skillId);
      if (!fs.existsSync(skillDir)) fs.mkdirSync(skillDir, { recursive: true });

      // 构建 SKILL.md 内容
      const kwList = Array.isArray(keywords) && keywords.length > 0
        ? keywords : [intent || description.substring(0, 20)];
      const exList = Array.isArray(examples) && examples.length > 0
        ? examples : [intent || description.substring(0, 50)];
      const toolList = Array.isArray(toolsUsed) ? toolsUsed : [];
      const stepList = Array.isArray(steps) && steps.length > 0 ? steps : [];

      // 生成 YAML frontmatter
      const yamlLines = [
        '---',
        `name: ${skillId}`,
        `id: ${skillId}`,
        `domain: general`,
        `description: ${description.replace(/\n/g, ' ')}`,
        'keywords:',
        ...kwList.map(k => `  - ${k}`),
        'examples:',
        ...exList.map(e => `  - ${e.replace(/\n/g, ' ')}`),
        '---',
      ];

      // 生成技能正文
      const bodyLines = [
        `# ${name}`,
        '',
        `## 技能描述`,
        description,
        '',
      ];

      if (toolList.length > 0) {
        bodyLines.push('## 使用工具', ...toolList.map(t => `- \`${t}\``), '');
      }

      if (stepList.length > 0) {
        bodyLines.push('## 执行步骤');
        stepList.forEach((step, i) => {
          bodyLines.push(`${i + 1}. ${step}`);
        });
        bodyLines.push('');
      }

      if (conversationSnippet) {
        bodyLines.push('## 成功案例', '```', conversationSnippet.substring(0, 2000), '```', '');
      }

      bodyLines.push('## 注意事项', '- 此技能从成功对话中自动打包生成', `- 创建时间: ${new Date().toISOString()}`);

      const skillMdContent = [...yamlLines, '', ...bodyLines].join('\n');
      const skillMdPath = path.join(skillDir, 'SKILL.md');
      fs.writeFileSync(skillMdPath, skillMdContent, 'utf-8');

      // 更新 discovered.json 注册表
      const discoveredPath = path.join(homeDir, '.duan', 'skills', 'discovered.json');
      let discovered = [];
      try {
        if (fs.existsSync(discoveredPath)) {
          discovered = JSON.parse(fs.readFileSync(discoveredPath, 'utf-8'));
          if (!Array.isArray(discovered)) discovered = discovered.skills || [];
        }
      } catch { /* ignore */ }

      // 移除同 ID 旧记录
      discovered = discovered.filter(s => (s.id || s.name) !== skillId);
      // 添加新记录
      discovered.push({
        id: skillId,
        name: skillId,
        domain: 'general',
        description,
        keywords: kwList,
        examples: exList,
        source: 'user_defined',
        confidence: 1.0,
        installStatus: 'installed',
        rating: 0,
        usageCount: 1,
        createdAt: Date.now(),
        updatedAt: Date.now(),
        toolsUsed: toolList,
      });

      const discoveredDir = path.dirname(discoveredPath);
      if (!fs.existsSync(discoveredDir)) fs.mkdirSync(discoveredDir, { recursive: true });
      fs.writeFileSync(discoveredPath, JSON.stringify(discovered, null, 2), 'utf-8');

      // 使缓存失效
      skillCacheInvalidated = true;
      skillCache = null;

      console.log(`[skill:package] 已打包技能 ${skillId} 到 ${skillMdPath}`);
      return { success: true, skillId, path: skillMdPath };
    } catch (err) {
      console.error('[skill:package] 异常:', err.message);
      return { success: false, error: err.message };
    }
  });

  // ----- 学习新技能：直接调用 Agent 服务器的 /api/skills/generate API -----
  safeHandle('skill:generate', async (_event, { description }) => {
    if (!description || typeof description !== 'string' || description.trim().length < 3) {
      return { success: false, error: '技能描述不能为空（至少 3 个字符）' };
    }
    try {
      const postData = JSON.stringify({ description: description.trim() });
      const result = await new Promise((resolve) => {
        const req = http.request({
          hostname: 'localhost', port: agentPort,
          path: '/api/skills/generate', method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Content-Length': Buffer.byteLength(postData) },
          timeout: 90000,
        }, (res) => {
          let body = '';
          res.on('data', (chunk) => { body += chunk.toString(); });
          res.on('end', () => {
            try {
              const json = JSON.parse(body);
              if (res.statusCode === 200 && json.success) {
                resolve({ success: true, skill: json.skill, message: `技能 "${json.skill?.name || description}" 已生成并保存` });
              } else {
                resolve({ success: false, error: json.error || json.message || `服务器返回 ${res.statusCode}` });
              }
            } catch (e) {
              resolve({ success: false, error: `解析响应失败: ${e.message}` });
            }
          });
        });
        req.on('error', (e) => resolve({ success: false, error: `无法连接 Agent 服务器: ${e.message}` }));
        req.on('timeout', () => { req.destroy(); resolve({ success: false, error: '请求超时（90s），请检查 API Key 是否配置正确' }); });
        req.write(postData);
        req.end();
      });
      return result;
    } catch (e) {
      return { success: false, error: e.message };
    }
  });

  // ----- E2 修复：技能市场 IPC（marketList/marketInstall/marketUninstall） -----
  // skill:marketList — 列出市场可安装技能（读 ~/.duan/skills/discovered.json）
  safeHandle('skill:marketList', async (_event, query) => {
    try {
      const discoveredPath = path.join(os.homedir(), '.duan', 'skills', 'discovered.json');
      if (!fs.existsSync(discoveredPath)) {
        return { success: true, skills: [], message: '暂无已发现的技能，请先运行技能发现' };
      }
      const raw = JSON.parse(fs.readFileSync(discoveredPath, 'utf-8'));
      let skills = Array.isArray(raw) ? raw : (raw.discovered || raw.skills || []);
      // 按相关性过滤（如果提供 query）
      if (query && typeof query === 'string' && query.trim()) {
        const q = query.toLowerCase();
        skills = skills.filter((s) =>
          (s.name && s.name.toLowerCase().includes(q)) ||
          (s.description && s.description.toLowerCase().includes(q)) ||
          (s.keywords && Array.isArray(s.keywords) && s.keywords.some((k) => k.toLowerCase().includes(q)))
        );
      }
      // 按置信度和评分排序
      skills.sort((a, b) => {
        const scoreA = (a.confidence || 0) * 0.6 + ((a.rating || 0) / 5) * 0.4;
        const scoreB = (b.confidence || 0) * 0.6 + ((b.rating || 0) / 5) * 0.4;
        return scoreB - scoreA;
      });
      return { success: true, skills, total: skills.length };
    } catch (err) {
      console.error('[skill:marketList] 异常:', err.message);
      return { success: false, skills: [], error: err.message };
    }
  });

  // skill:marketInstall — 安装市场技能（更新 discovered.json 的 installStatus）
  safeHandle('skill:marketInstall', async (_event, { skillId }) => {
    if (!skillId || typeof skillId !== 'string') {
      return { success: false, error: 'skillId 不能为空' };
    }
    // 安全：字符白名单校验，防止路径遍历
    if (!/^[\w.-]+$/.test(skillId)) {
      return { success: false, error: 'skillId 包含非法字符' };
    }
    try {
      const discoveredPath = path.join(os.homedir(), '.duan', 'skills', 'discovered.json');
      if (!fs.existsSync(discoveredPath)) {
        return { success: false, error: '技能发现数据不存在，请先运行技能发现' };
      }
      const raw = JSON.parse(fs.readFileSync(discoveredPath, 'utf-8'));
      const list = Array.isArray(raw) ? raw : (raw.discovered || raw.skills || []);
      const idx = list.findIndex((s) => s.id === skillId);
      if (idx < 0) {
        return { success: false, error: `技能 "${skillId}" 未在市场中发现` };
      }
      if (list[idx].installStatus === 'installed') {
        return { success: true, message: `技能 "${list[idx].name}" 已安装`, skill: list[idx] };
      }
      list[idx].installStatus = 'installed';
      list[idx].lastUsed = Date.now();
      // 保存回文件
      const newData = Array.isArray(raw) ? list : { ...raw, discovered: list };
      fs.writeFileSync(discoveredPath, JSON.stringify(newData, null, 2), 'utf-8');
      console.log(`[skill:marketInstall] 已安装技能 ${skillId}`);
      return { success: true, message: `技能 "${list[idx].name}" 安装成功`, skill: list[idx] };
    } catch (err) {
      console.error('[skill:marketInstall] 异常:', err.message);
      return { success: false, error: err.message };
    }
  });

  // skill:marketUninstall — 卸载市场技能（更新 discovered.json 的 installStatus）
  safeHandle('skill:marketUninstall', async (_event, { skillId }) => {
    if (!skillId || typeof skillId !== 'string') {
      return { success: false, error: 'skillId 不能为空' };
    }
    if (!/^[\w.-]+$/.test(skillId)) {
      return { success: false, error: 'skillId 包含非法字符' };
    }
    try {
      const discoveredPath = path.join(os.homedir(), '.duan', 'skills', 'discovered.json');
      if (!fs.existsSync(discoveredPath)) {
        return { success: false, error: '技能发现数据不存在' };
      }
      const raw = JSON.parse(fs.readFileSync(discoveredPath, 'utf-8'));
      const list = Array.isArray(raw) ? raw : (raw.discovered || raw.skills || []);
      const idx = list.findIndex((s) => s.id === skillId);
      if (idx < 0) {
        return { success: false, error: `技能 "${skillId}" 未在市场中发现` };
      }
      if (list[idx].installStatus !== 'installed') {
        return { success: true, message: `技能 "${list[idx].name}" 未安装，无需卸载` };
      }
      list[idx].installStatus = 'available';
      const newData = Array.isArray(raw) ? list : { ...raw, discovered: list };
      fs.writeFileSync(discoveredPath, JSON.stringify(newData, null, 2), 'utf-8');
      console.log(`[skill:marketUninstall] 已卸载技能 ${skillId}`);
      return { success: true, message: `技能 "${list[idx].name}" 已卸载` };
    } catch (err) {
      console.error('[skill:marketUninstall] 异常:', err.message);
      return { success: false, error: err.message };
    }
  });

  // ===== C2/C3: SubAgent IPC handlers — 桥接后端 /api/subagent/* 端点 =====
  // 列出可用 SubAgent
  safeHandle('subagent:listAgents', async () => {
    try {
      return await new Promise((resolve) => {
        const req = http.request({
          hostname: 'localhost', port: agentPort,
          path: '/api/subagent/agents', method: 'GET',
          timeout: 10000,
        }, (res) => {
          let body = '';
          res.on('data', (chunk) => { body += chunk.toString(); });
          res.on('end', () => {
            try { resolve(JSON.parse(body)); } catch { resolve({ success: false, agents: [] }); }
          });
        });
        req.on('error', () => resolve({ success: false, agents: [], error: '无法连接 Agent 服务器' }));
        req.on('timeout', () => { req.destroy(); resolve({ success: false, agents: [], error: '请求超时' }); });
        req.end();
      });
    } catch (e) {
      return { success: false, agents: [], error: e.message };
    }
  });

  // 列出团队模板
  safeHandle('subagent:listTemplates', async () => {
    try {
      return await new Promise((resolve) => {
        const req = http.request({
          hostname: 'localhost', port: agentPort,
          path: '/api/subagent/team-templates', method: 'GET',
          timeout: 10000,
        }, (res) => {
          let body = '';
          res.on('data', (chunk) => { body += chunk.toString(); });
          res.on('end', () => {
            try { resolve(JSON.parse(body)); } catch { resolve({ success: false, templates: [] }); }
          });
        });
        req.on('error', () => resolve({ success: false, templates: [], error: '无法连接 Agent 服务器' }));
        req.on('timeout', () => { req.destroy(); resolve({ success: false, templates: [], error: '请求超时' }); });
        req.end();
      });
    } catch (e) {
      return { success: false, templates: [], error: e.message };
    }
  });

  // 启动团队执行（POST /api/subagent/team/start）
  safeHandle('subagent:startTeam', async (_event, { templateName, taskGoal, extraContext } = {}) => {
    if (!templateName || !taskGoal) {
      return { success: false, error: 'templateName 和 taskGoal 必填' };
    }
    try {
      const postData = JSON.stringify({ templateName, taskGoal, extraContext });
      return await new Promise((resolve) => {
        const req = http.request({
          hostname: 'localhost', port: agentPort,
          path: '/api/subagent/team/start', method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Content-Length': Buffer.byteLength(postData) },
          timeout: 30000,
        }, (res) => {
          let body = '';
          res.on('data', (chunk) => { body += chunk.toString(); });
          res.on('end', () => {
            try { resolve(JSON.parse(body)); } catch { resolve({ success: false, error: '解析响应失败' }); }
          });
        });
        req.on('error', (e) => resolve({ success: false, error: `无法连接 Agent 服务器: ${e.message}` }));
        req.on('timeout', () => { req.destroy(); resolve({ success: false, error: '请求超时（30s）' }); });
        req.write(postData);
        req.end();
      });
    } catch (e) {
      return { success: false, error: e.message };
    }
  });

  // SSE 流转发：main 进程建立到后端的 SSE 长连接，收到事件后转发给 renderer
  let subagentSSECleanup = null;
  ipcMain.handle('subagent:stream:connect', async () => {
    // 避免重复连接
    if (subagentSSECleanup) return { success: true, message: 'SSE 流已连接' };
    try {
      const req = http.request({
        hostname: 'localhost', port: agentPort,
        path: '/api/subagent/stream', method: 'GET',
        headers: { Accept: 'text/event-stream' },
        timeout: 0, // 无超时，长连接
      }, (res) => {
        let buffer = '';
        res.on('data', (chunk) => {
          buffer += chunk.toString();
          // SSE 事件以 \n\n 分隔
          const parts = buffer.split('\n\n');
          buffer = parts.pop() || ''; // 最后一段可能不完整，保留
          for (const part of parts) {
            const dataLine = part.split('\n').find(l => l.startsWith('data: '));
            if (dataLine) {
              const jsonStr = dataLine.slice(6);
              try {
                const event = JSON.parse(jsonStr);
                // 转发给所有 renderer
                for (const win of BrowserWindow.getAllWindows()) {
                  win.webContents.send('subagent:stream', event);
                }
              } catch { /* 非 JSON 数据行（如心跳注释），忽略 */ }
            }
          }
        });
        res.on('end', () => { console.log('[subagent:stream] SSE 连接已关闭'); subagentSSECleanup = null; });
        res.on('error', () => { subagentSSECleanup = null; });
      });
      req.on('error', (e) => { console.error('[subagent:stream] 连接失败:', e.message); subagentSSECleanup = null; });
      req.end();
      subagentSSECleanup = () => { req.destroy(); };
      return { success: true, message: 'SSE 流已连接' };
    } catch (e) {
      return { success: false, error: e.message };
    }
  });

  ipcMain.handle('subagent:stream:disconnect', async () => {
    if (subagentSSECleanup) { subagentSSECleanup(); subagentSSECleanup = null; }
    return { success: true };
  });

  // ===== D-IPC: MCP 插件市场 IPC handlers — 桥接后端 /api/mcp/marketplace/* =====
  const mcpMarketRequest = async (path, method = 'GET', body = null) => {
    try {
      const options = { hostname: 'localhost', port: agentPort, path, method, timeout: 30000 };
      if (body) {
        const postData = JSON.stringify(body);
        options.headers = { 'Content-Type': 'application/json', 'Content-Length': Buffer.byteLength(postData) };
      }
      return await new Promise((resolve) => {
        const req = http.request(options, (res) => {
          let respBody = '';
          res.on('data', (chunk) => { respBody += chunk.toString(); });
          res.on('end', () => {
            try { resolve(JSON.parse(respBody)); } catch { resolve({ success: false, error: '解析响应失败' }); }
          });
        });
        req.on('error', (e) => resolve({ success: false, error: `无法连接 Agent 服务器: ${e.message}` }));
        req.on('timeout', () => { req.destroy(); resolve({ success: false, error: '请求超时' }); });
        if (body) req.write(JSON.stringify(body));
        req.end();
      });
    } catch (e) {
      return { success: false, error: e.message };
    }
  };

  safeHandle('mcp:marketplace:list', async () => mcpMarketRequest('/api/mcp/marketplace/list'));
  safeHandle('mcp:marketplace:installed', async () => mcpMarketRequest('/api/mcp/marketplace/installed'));
  safeHandle('mcp:marketplace:install', async (_event, { id }) => mcpMarketRequest(`/api/mcp/marketplace/install/${id}`, 'POST'));
  safeHandle('mcp:marketplace:uninstall', async (_event, { id }) => mcpMarketRequest(`/api/mcp/marketplace/uninstall/${id}`, 'POST'));
  safeHandle('mcp:marketplace:enable', async (_event, { id, enabled }) => mcpMarketRequest(`/api/mcp/marketplace/enable/${id}`, 'POST', { enabled }));
  safeHandle('mcp:marketplace:stats', async () => mcpMarketRequest('/api/mcp/marketplace/stats'));
  safeHandle('mcp:marketplace:updates', async () => mcpMarketRequest('/api/mcp/marketplace/updates'));

  // ===== 能力评估 IPC 桥接（代理后端 /api/capability/* REST API） =====
  // 复用 mcpMarketRequest 的代理模式，支持 GET/POST
  const capabilityRequest = async (path, method = 'GET', body = null) => {
    try {
      const options = { hostname: 'localhost', port: agentPort, path, method, timeout: 60000 };
      if (body) {
        const postData = JSON.stringify(body);
        options.headers = { 'Content-Type': 'application/json', 'Content-Length': Buffer.byteLength(postData) };
      }
      return await new Promise((resolve) => {
        const req = http.request(options, (res) => {
          let respBody = '';
          res.on('data', (chunk) => { respBody += chunk.toString(); });
          res.on('end', () => {
            try { resolve(JSON.parse(respBody)); }
            catch { resolve({ success: false, error: '解析响应失败' }); }
          });
        });
        req.on('error', (e) => resolve({ success: false, error: `无法连接 Agent 服务器: ${e.message}` }));
        req.on('timeout', () => { req.destroy(); resolve({ success: false, error: '请求超时（评估可能仍在运行）' }); });
        if (body) req.write(JSON.stringify(body));
        req.end();
      });
    } catch (e) {
      return { success: false, error: e.message };
    }
  };

  safeHandle('capability:dimensions', async () => capabilityRequest('/api/capability/dimensions'));
  safeHandle('capability:report', async () => capabilityRequest('/api/capability/report'));
  safeHandle('capability:assess', async (_event, body) => capabilityRequest('/api/capability/assess', 'POST', body || { label: 'current' }));
  safeHandle('capability:save-baseline', async () => capabilityRequest('/api/capability/baseline', 'POST'));
  safeHandle('capability:baseline', async () => capabilityRequest('/api/capability/baseline'));
  safeHandle('capability:snapshots', async () => capabilityRequest('/api/capability/snapshots'));
  safeHandle('capability:runtime-values', async () => capabilityRequest('/api/capability/runtime-values'));

  ipcMain.handle('dashboard:data', async () => {
    try {
      const homeDir = os.homedir();
      const result = {
        metrics: null,
        report: null,
        snapshots: [],
        profile: null,
        sla: null,
        predAcc: null,
        recStats: null,
        systemStats: null,
      };

      // ===== 从系统真实数据源收集统计 =====
      const systemStats = /** @type {any} */ ({
        totalConversations: 0,
        totalMessages: 0,
        totalToolCalls: 0,
        toolCallSuccess: 0,
        toolCallFail: 0,
        totalSkills: 0,
        totalLearningRecords: 0,
        totalFeedbackFiles: 0,
        avgFeedbackRating: 0,
        uptimeSeconds: process.uptime(),
        nodeVersion: process.version,
        platform: process.platform,
        memoryUsage: Math.round(process.memoryUsage().heapUsed / 1024 / 1024),
        configuredProviders: 0,
        availableModels: 0,
        recentToolUsage: /** @type {Record<string,number>} */ ({}),
        dailyActivity: /** @type {Array<{date:string,count:number}>} */ ([]),
      });

      // 1. 性能指标: .awareness/metrics.json
      const metricsPath = path.join(homeDir, '.awareness', 'metrics.json');
      if (fs.existsSync(metricsPath)) {
        try { result.metrics = JSON.parse(fs.readFileSync(metricsPath, 'utf-8')); } catch { /* ignore */ }
      }

      // 2. 认知状态: .awareness/cognitive-state.json
      const cognitivePath = path.join(homeDir, '.awareness', 'cognitive-state.json');
      if (fs.existsSync(cognitivePath)) {
        try {
          const parsed = JSON.parse(fs.readFileSync(cognitivePath, 'utf-8'));
          // 确保关键字段不为 null/undefined，防止前端 Object.entries 崩溃
          if (parsed && typeof parsed === 'object') {
            parsed.dimensionScores = parsed.dimensionScores || { accuracy: 0.5, efficiency: 0.5, coverage: 0.5, retention: 0.5, adaptation: 0.5 };
            parsed.warnings = Array.isArray(parsed.warnings) ? parsed.warnings : [];
            parsed.abTests = Array.isArray(parsed.abTests) ? parsed.abTests : [];
            result.report = parsed;
          }
        } catch { /* ignore */ }
      }

      // 3. 评估快照: .awareness/eval-snapshots.json
      const snapshotsPath = path.join(homeDir, '.awareness', 'eval-snapshots.json');
      if (fs.existsSync(snapshotsPath)) {
        try {
          const raw = JSON.parse(fs.readFileSync(snapshotsPath, 'utf-8'));
          result.snapshots = Array.isArray(raw) ? raw : (raw.snapshots || []);
        } catch { /* ignore */ }
      }

      // 4. 用户画像: .learnings/USER_PROFILE.json
      const profilePath = path.join(homeDir, '.learnings', 'USER_PROFILE.json');
      if (fs.existsSync(profilePath)) {
        try { result.profile = JSON.parse(fs.readFileSync(profilePath, 'utf-8')); } catch { /* ignore */ }
      }

      // 5. SLA 状态: .awareness/sla-status.json
      const slaPath = path.join(homeDir, '.awareness', 'sla-status.json');
      if (fs.existsSync(slaPath)) {
        try { result.sla = JSON.parse(fs.readFileSync(slaPath, 'utf-8')); } catch { /* ignore */ }
      }

      // 6. 预测准确率: .awareness/prediction-accuracy.json
      const predAccPath = path.join(homeDir, '.awareness', 'prediction-accuracy.json');
      if (fs.existsSync(predAccPath)) {
        try { result.predAcc = JSON.parse(fs.readFileSync(predAccPath, 'utf-8')); } catch { /* ignore */ }
      }

      // 7. 推荐统计: .awareness/recommendation-stats.json
      const recStatsPath = path.join(homeDir, '.awareness', 'recommendation-stats.json');
      if (fs.existsSync(recStatsPath)) {
        try { result.recStats = JSON.parse(fs.readFileSync(recStatsPath, 'utf-8')); } catch { /* ignore */ }
      }

      // 8. 学习记录: .duan/learning/records.json
      const recordsPath = path.join(homeDir, '.duan', 'learning', 'records.json');
      let records = [];
      if (fs.existsSync(recordsPath)) {
        try {
          const raw = JSON.parse(fs.readFileSync(recordsPath, 'utf-8'));
          records = Array.isArray(raw) ? raw : (raw.records || []);
          systemStats.totalLearningRecords = records.length;
          if (records.length > 0 && !result.metrics) {
            result.metrics = {
              totalInteractions: records.length,
              taskCompletionRate: records.filter((r) => r.success || r.completed).length / records.length,
              avgResponseTime: records.reduce((sum, r) => sum + (r.duration || r.responseTime || 0), 0) / records.length,
              toolCallSuccessRate: records.filter((r) => r.success || r.completed).length / records.length,
              contextCoherence: 0,
              selfCorrectionRate: records.filter((r) => r.retried || r.selfCorrected).length / records.length,
              intentAccuracy: 0,
              userSatisfaction: 0,
            };
          }
        } catch { /* ignore */ }
      }

      // 9. 反馈数据: .duan/feedback/
      const feedbackDir = path.join(homeDir, '.duan', 'feedback');
      if (fs.existsSync(feedbackDir)) {
        try {
          const feedbackFiles = fs.readdirSync(feedbackDir).filter(f => f.endsWith('.json'));
          systemStats.totalFeedbackFiles = feedbackFiles.length;
          if (feedbackFiles.length > 0 && !result.recStats) {
            let totalFeedback = 0;
            let totalRating = 0;
            for (const f of feedbackFiles) {
              try {
                const data = JSON.parse(fs.readFileSync(path.join(feedbackDir, f), 'utf-8'));
                if (data.rating) { totalRating += data.rating; totalFeedback++; }
              } catch { /* ignore */ }
            }
            if (totalFeedback > 0) {
              systemStats.avgFeedbackRating = totalRating / totalFeedback;
              result.recStats = {
                totalRecommendations: feedbackFiles.length,
                totalFeedback,
                avgRating: totalRating / totalFeedback,
                serviceStats: [],
              };
            }
          }
        } catch { /* ignore */ }
      }

      // 10. 技能统计: skills/builtin/ 目录
      try {
        const skillsDir = path.join(__dirname, '..', 'skills', 'builtin');
        if (fs.existsSync(skillsDir)) {
          const skillFiles = fs.readdirSync(skillsDir).filter(f => f.endsWith('.json') || f.endsWith('.md'));
          systemStats.totalSkills = skillFiles.length;
        }
      } catch { /* ignore */ }
      // 也检查 ~/.duan/learning/skills.json
      try {
        const userSkillsPath = path.join(homeDir, '.duan', 'learning', 'skills.json');
        if (fs.existsSync(userSkillsPath)) {
          const skillsData = JSON.parse(fs.readFileSync(userSkillsPath, 'utf-8'));
          const userSkills = Array.isArray(skillsData) ? skillsData : (skillsData.skills || []);
          systemStats.totalSkills += userSkills.length;
        }
      } catch { /* ignore */ }

      // 11. 配置统计
      try {
        const config = loadConfig();
        const duanConfig = loadDuanConfig();
        if (config?.apiKeys) {
          systemStats.configuredProviders = Object.keys(config.apiKeys).filter(k => config.apiKeys[k] && config.apiKeys[k] !== '未配置').length;
        }
        if (duanConfig?.profiles) {
          systemStats.availableModels = duanConfig.profiles.reduce((sum, p) => sum + (p.models?.length || 0), 0);
        }
      } catch { /* ignore */ }

      // 12. 对话历史统计: .duan/conversations/ 目录
      try {
        const convDir = path.join(homeDir, '.duan', 'conversations');
        if (fs.existsSync(convDir)) {
          const convFiles = fs.readdirSync(convDir).filter(f => f.endsWith('.json'));
          systemStats.totalConversations = convFiles.length;
          let totalMsgs = 0;
          let totalToolCalls = 0;
          let toolSuccess = 0;
          let toolFail = 0;
          const toolUsage = /** @type {Record<string,number>} */ ({});
          const dailyMap = /** @type {Record<string,number>} */ ({});
          for (const cf of convFiles.slice(0, 100)) { // 最多读取100个对话文件
            try {
              const convData = JSON.parse(fs.readFileSync(path.join(convDir, cf), 'utf-8'));
              const msgs = convData.messages || [];
              totalMsgs += msgs.length;
              for (const msg of msgs) {
                if (msg.toolCalls) {
                  for (const tc of msg.toolCalls) {
                    totalToolCalls++;
                    const tName = tc.name || 'unknown';
                    toolUsage[tName] = (toolUsage[tName] || 0) + 1;
                    if (tc.status === 'success') toolSuccess++;
                    else if (tc.status === 'error') toolFail++;
                  }
                }
                // 按日期统计活动
                if (msg.timestamp) {
                  const day = new Date(msg.timestamp).toISOString().slice(0, 10);
                  dailyMap[day] = (dailyMap[day] || 0) + 1;
                }
              }
            } catch { /* ignore */ }
          }
          systemStats.totalMessages = totalMsgs;
          systemStats.totalToolCalls = totalToolCalls;
          systemStats.toolCallSuccess = toolSuccess;
          systemStats.toolCallFail = toolFail;
          systemStats.recentToolUsage = toolUsage;
          // 转换为数组并排序
          systemStats.dailyActivity = Object.entries(dailyMap)
            .sort(([a], [b]) => a.localeCompare(b))
            .slice(-14)
            .map(([date, count]) => ({ date, count }));
        }
      } catch { /* ignore */ }

      // 13. 也检查 .learnings/ 目录下的提取技能
      try {
        const extractedSkillsPath = path.join(homeDir, '.learnings', 'EXTRACTED_SKILLS.md');
        if (fs.existsSync(extractedSkillsPath)) {
          const content = fs.readFileSync(extractedSkillsPath, 'utf-8');
          const skillMatches = content.match(/^##\s+.+/gm);
          if (skillMatches) {
            systemStats.totalSkills += skillMatches.length;
          }
        }
      } catch { /* ignore */ }

      result.systemStats = systemStats;

      // ===== 如果没有数据文件，基于系统运行时状态生成初始数据 =====
      if (!result.metrics) {
        result.metrics = {
          totalInteractions: systemStats.totalMessages || 0,
          taskCompletionRate: systemStats.totalToolCalls > 0 ? systemStats.toolCallSuccess / systemStats.totalToolCalls : 0,
          avgResponseTime: 0,
          toolCallSuccessRate: systemStats.totalToolCalls > 0 ? systemStats.toolCallSuccess / systemStats.totalToolCalls : 0,
          contextCoherence: 0.5,
          selfCorrectionRate: 0,
          intentAccuracy: 0.5,
          userSatisfaction: 0.5,
        };
      }
      if (!result.report) {
        const overallScore = systemStats.totalToolCalls > 0
          ? systemStats.toolCallSuccess / systemStats.totalToolCalls
          : 0.5;
        result.report = {
          accuracy: overallScore,
          accuracyTarget: 0.85,
          accuracyMet: overallScore >= 0.85,
          overallScore,
          dimensionScores: { accuracy: overallScore, efficiency: 0.5, coverage: 0.5, retention: 0.5, adaptation: 0.5 },
          trend: 'stable',
          velocity: 0,
          warnings: [],
          abTests: [],
        };
      }
      if (!result.snapshots || result.snapshots.length === 0) {
        result.snapshots = [];
      }
      if (!result.profile) {
        result.profile = {
          totalInteractions: systemStats.totalMessages || 0,
          successRate: systemStats.totalToolCalls > 0 ? systemStats.toolCallSuccess / systemStats.totalToolCalls : 0,
          interests: [],
          preferredLanguages: ['中文'],
          predictions: {},
        };
      }
      if (!result.sla) {
        const completionRate = systemStats.totalToolCalls > 0 ? systemStats.toolCallSuccess / systemStats.totalToolCalls : 0;
        result.sla = {
          taskCompletionRate: { current: completionRate, baseline: 0.5, target: 0.85, improvement: completionRate - 0.5, met: completionRate >= 0.85 },
          userSatisfaction: { current: 0.5, baseline: 0.5, target: 0.75, improvement: 0, met: false },
          avgResponseTime: { current: 2000, baseline: 3000, target: 2000, improvement: 0.33, met: true },
          overall: { progress: Math.round(completionRate * 100), phase: '初始阶段' },
        };
      }
      if (!result.predAcc) {
        result.predAcc = {
          globalAccuracy: 0.5,
          accuracyTarget: 0.85,
          accuracyMet: false,
          totalPredictions: 0,
          correctPredictions: 0,
          userReports: [],
        };
      }
      if (!result.recStats) {
        result.recStats = systemStats.totalFeedbackFiles > 0 ? {
          totalRecommendations: systemStats.totalFeedbackFiles,
          totalFeedback: systemStats.totalFeedbackFiles,
          avgRating: systemStats.avgFeedbackRating || 0,
          serviceStats: [],
        } : { available: false };
      }

      return { success: true, ...result };
    } catch (err) {
      return { success: false, error: err.message, metrics: null, report: null, snapshots: [], profile: null, sla: null, predAcc: null, recStats: null };
    }
  });

  // ----- 文件选择对话框 -----
  // 安全打开外部链接（供 BrowserPanel 的"外部浏览器打开"按钮使用）
  ipcMain.handle('shell:openExternal', async (_event, url) => {
    if (!url || typeof url !== 'string' || !/^https?:\/\//i.test(url)) {
      return { success: false, error: '安全限制: 仅允许打开 http:// 或 https:// URL' };
    }
    try {
      await shell.openExternal(url);
      return { success: true };
    } catch (err) {
      console.error('[主进程] shell.openExternal 失败:', err);
      return { success: false, error: err.message };
    }
  });

  ipcMain.handle('dialog:openFile', async (_event, options) => {
    try {
      const { dialog } = require('electron');
      const result = await dialog.showOpenDialog(mainWindow, {
        title: options?.title || '选择文件',
        properties: ['openFile', 'multiSelections'],
        filters: options?.filters || [
          { name: '图片', extensions: ['jpg', 'jpeg', 'png', 'gif', 'bmp', 'webp', 'svg'] },
          { name: '文档', extensions: ['pdf', 'doc', 'docx', 'txt', 'md', 'csv', 'json', 'xml'] },
          { name: '代码', extensions: ['js', 'ts', 'py', 'java', 'c', 'cpp', 'h', 'go', 'rs', 'rb', 'php', 'html', 'css', 'sql'] },
          { name: '所有文件', extensions: ['*'] },
        ],
      });
      if (result.canceled || result.filePaths.length === 0) {
        return { success: false, canceled: true, files: [] };
      }
      const files = result.filePaths.map(fp => {
        const fs = require('fs');
        const path = require('path');
        const ext = path.extname(fp).toLowerCase().replace('.', '');
        const isImage = ['jpg', 'jpeg', 'png', 'gif', 'bmp', 'webp', 'svg'].includes(ext);
        let base64Data = null;
        try {
          const buffer = fs.readFileSync(fp);
          base64Data = buffer.toString('base64');
        } catch (e) { /* ignore */ }
        return {
          path: fp,
          name: path.basename(fp),
          ext,
          isImage,
          size: base64Data ? base64Data.length : 0,
          base64: base64Data,
          mimeType: isImage ? `image/${ext === 'jpg' ? 'jpeg' : ext}` : `application/${ext}`,
        };
      });
      return { success: true, canceled: false, files };
    } catch (err) {
      return { success: false, canceled: false, files: [], error: err.message };
    }
  });

  // ----- API Key 真实验证 -----
  ipcMain.handle('test:api_key', async (_event, { provider, apiKey, baseURL }) => {
    try {
      if (!apiKey || apiKey.trim().length < 10) {
        return { valid: false, message: 'API Key 格式无效，长度不足' };
      }

      // 根据 provider 确定 baseURL
      const mapping = PROVIDER_MAP[provider];
      const testBaseURL = baseURL || mapping?.baseURL || '';

      if (!testBaseURL) {
        // 无法确定 baseURL，仅做格式验证
        return { valid: true, message: 'Key 格式验证通过（无法在线验证，未配置 baseURL）' };
      }

      // 尝试调用 /models 端点验证 Key
      const https = require('https');
      const http = require('http');
      const base = testBaseURL.replace(/\/+$/, '');
      const testUrl = new URL(base + '/models');

      return new Promise((resolve) => {
        const timeout = setTimeout(() => {
          resolve({ valid: false, message: '验证请求超时（10秒），请检查网络连接' });
        }, 10000);

        const lib = testUrl.protocol === 'https:' ? https : http;
        const req = lib.request({
          hostname: testUrl.hostname,
          port: testUrl.port,
          path: testUrl.pathname,
          method: 'GET',
          headers: {
            'Authorization': `Bearer ${apiKey}`,
            'Content-Type': 'application/json',
          },
        }, (res) => {
          let data = '';
          res.on('data', (chunk) => { data += chunk; });
          res.on('end', () => {
            clearTimeout(timeout);
            if (res.statusCode === 200) {
              resolve({ valid: true, message: 'API Key 验证通过' });
            } else if (res.statusCode === 401 || res.statusCode === 403) {
              resolve({ valid: false, message: 'API Key 无效或已过期' });
            } else {
              // 其他状态码可能是端点不支持，但 Key 可能有效
              resolve({ valid: true, message: `Key 格式验证通过（服务器返回 ${res.statusCode}，无法确认有效性）` });
            }
          });
        });

        req.on('error', (err) => {
          clearTimeout(timeout);
          resolve({ valid: false, message: `连接失败: ${err.message}` });
        });

        req.end();
      });
    } catch (err) {
      return { valid: false, message: `验证失败: ${err.message}` };
    }
  });
}

// ===== 自动更新事件 =====

function setupAutoUpdater() {
  if (!autoUpdater) return;

  // P0-3 修复：明确自动下载策略 — autoDownload=false 由用户触发下载
  // 但 update-available 事件中自动下载，保持当前行为（用户已通过检查更新表达意愿）
  // 补充缺失的事件处理，错误通过 IPC 通知用户

  autoUpdater.on('checking-for-update', () => {
    console.log('[Updater] 正在检查更新...');
    if (mainWindow && !mainWindow.isDestroyed()) {
      mainWindow.webContents.send('updater:checking');
    }
  });

  autoUpdater.on('update-available', (info) => {
    console.log('[Updater] 发现新版本:', info.version || 'unknown');
    if (mainWindow && !mainWindow.isDestroyed()) {
      mainWindow.webContents.send('updater:available', info);
    }
    // 自动下载（用户已通过检查更新表达意愿）
    autoUpdater.downloadUpdate();
  });

  autoUpdater.on('update-not-available', (info) => {
    console.log('[Updater] 当前已是最新版本');
    if (mainWindow && !mainWindow.isDestroyed()) {
      mainWindow.webContents.send('updater:not-available', info);
    }
  });

  autoUpdater.on('download-progress', (progress) => {
    if (mainWindow && !mainWindow.isDestroyed()) {
      mainWindow.webContents.send('updater:progress', {
        percent: progress.percent,
        transferred: progress.transferred,
        total: progress.total,
        bytesPerSecond: progress.bytesPerSecond,
      });
    }
  });

  autoUpdater.on('update-downloaded', (info) => {
    console.log('[Updater] 更新已下载，等待安装');
    if (mainWindow && !mainWindow.isDestroyed()) {
      mainWindow.webContents.send('updater:downloaded', info);
    }
  });

  autoUpdater.on('error', (err) => {
    console.error('[Updater] 自动更新错误:', err);
    // P0-3 修复：错误通过 IPC 通知用户
    if (mainWindow && !mainWindow.isDestroyed()) {
      mainWindow.webContents.send('updater:error', {
        message: err instanceof Error ? err.message : String(err),
      });
    }
  });

  // P0-3 修复：启动后延迟 30 秒自动检查更新（非阻塞）
  setTimeout(() => {
    if (autoUpdater && !isQuitting) {
      console.log('[Updater] 启动后自动检查更新...');
      autoUpdater.checkForUpdates().catch((err) => {
        console.warn('[Updater] 自动检查更新失败:', err.message);
      });
    }
  }, 30000);

  // 预热 Python 缓存（延迟 2 秒，非阻塞，加速首次语音试听）
  setTimeout(() => {
    try {
      const py = findPythonExecutable();
      if (py) console.log('[Voice] Python 缓存预热完成:', py);
      else console.warn('[Voice] 未找到 Python，语音试听将依赖 Agent 服务器');
    } catch { /* ignore */ }
  }, 2000);
}

// ===== 应用生命周期 =====

// 防止多实例 - 必须在 app.whenReady 之前调用
// P2-3 修复：在所有其他逻辑之前启用日志文件化，确保后续所有 console 输出都能被记录
setupFileLogging();

const gotLock = app.requestSingleInstanceLock();
if (!gotLock) {
  console.log('[主进程] 已有实例运行，退出');
  app.quit();
} else {
  console.log('[主进程] 获取单实例锁成功');

  app.on('second-instance', () => {
    console.log('[主进程] 第二实例启动，聚焦主窗口');
    if (mainWindow) {
      mainWindow.show();
      mainWindow.focus();
    }
  });

  app.whenReady().then(() => {
    console.log('[主进程] app.whenReady 触发');

    // P1-1 修复：注入内容安全策略（CSP），防止 XSS 攻击
    try {
      const cspDirectives = IS_DEV
        ? [
            "default-src 'self'",
            "script-src 'self' 'unsafe-inline' 'unsafe-eval'",  // 开发模式需要 eval
            "style-src 'self' 'unsafe-inline'",
            "img-src 'self' data: blob: https:",
            "media-src 'self' blob: data:",  // 允许 TTS 音频 blob URL 播放
            "connect-src 'self' http://localhost:* ws://localhost:* https:",
            "font-src 'self' data:",
            "object-src 'none'",
            "frame-src 'self' https: http:",  // P1-7 修复：允许 webview 加载外部网页
          ].join('; ')
        : [
            "default-src 'self'",
            "script-src 'self'",
            "style-src 'self' 'unsafe-inline'",
            "img-src 'self' data: blob: https:",
            "media-src 'self' blob: data:",  // 允许 TTS 音频 blob URL 播放
            "connect-src 'self' https:",
            "font-src 'self' data:",
            "object-src 'none'",
            "frame-src 'self' https: http:",  // P1-7 修复：允许 webview 加载外部网页
          ].join('; ');

      session.defaultSession.webRequest.onHeadersReceived((details, callback) => {
        callback({
          responseHeaders: {
            ...details.responseHeaders,
            'Content-Security-Policy': [cspDirectives],
          },
        });
      });
      console.log('[主进程] CSP 策略注入完成');
    } catch (err) {
      console.error('[主进程] CSP 注入失败:', err);
    }

    try {
      registerIpcHandlers();
      console.log('[主进程] IPC 注册完成');
    } catch (err) {
      console.error('[主进程] IPC 注册失败:', err);
    }

    try {
      createMainWindow();
      console.log('[主进程] 主窗口创建完成');
    } catch (err) {
      console.error('[主进程] 主窗口创建失败:', err);
    }

    try {
      createTray();
      console.log('[主进程] 托盘创建完成');
    } catch (err) {
      console.error('[主进程] 托盘创建失败:', err);
    }

    try {
      startAgent();
      console.log('[主进程] Agent 启动完成');
    } catch (err) {
      console.error('[主进程] Agent 启动失败:', err);
    }

    // 启动统一配置文件监听（三端实时同步）
    try {
      startConfigWatcher();
      console.log('[主进程] 配置文件监听已启动');
    } catch (err) {
      console.error('[主进程] 配置文件监听启动失败:', err);
    }

    setupAutoUpdater();

    app.on('activate', () => {
      if (BrowserWindow.getAllWindows().length === 0) {
        createMainWindow();
      } else if (mainWindow) {
        mainWindow.show();
        mainWindow.focus();
      }
    });
  }).catch((err) => {
    console.error('[主进程] whenReady 错误:', err);
  });
}

app.on('before-quit', () => {
  isQuitting = true;
  stopConfigWatcher();
  stopSkillWatchers();
  stopAgent();
  // P1-5 修复：销毁托盘图标
  if (tray) {
    try { tray.destroy(); } catch { /* ignore */ }
    tray = null;
  }
  // P2-3 修复：关闭日志文件流，确保所有日志落盘
  closeFileLogging();
});

app.on('window-all-closed', () => {
  // 不退出，保持托盘运行
});
