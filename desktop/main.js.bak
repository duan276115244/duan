        },
      },
      {
        type: 'function',
        function: {
          name: 'complete',
          description: '任务完成时调用，提交最终结果',
          parameters: { type: 'object', properties: { result: { type: 'string', description: '任务完成结果摘要' } }, required: ['result'] },
        },
      },
      {
        type: 'function',
        function: {
          name: 'app_operate',
          description: '统一应用操作接口（跨软件控制，支持24类主流应用）。自动处理前置验证、超时(默认5s)、失败重试(默认3次)和后置验证。支持应用: photoshop/powerpoint/vscode/chrome/firefox/notepad++/sublime/powershell/cmd/windowsterminal/word/excel/outlook/wechat/dingtalk/feishu/figma/vlc/spotify/explorer/system/git/docker/nodejs。操作类型: launch/activate/shortcut/workflow/menu/type/click/find_click。',
          parameters: {
