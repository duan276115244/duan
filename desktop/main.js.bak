  // channel:templates — 获取通道模板
  safeHandle('channel:templates', async () => {
    return { success: true, data: CHANNEL_TEMPLATES };
  });

  // channel:list — 列出所有通道
  safeHandle('channel:list', async () => {
    const channels = loadChannelsConfig();
    const list = Object.entries(channels).map(([id, cfg]) => ({ id, ...cfg }));
    return { success: true, data: list };
  });

  // channel:save — 新增或更新通道
  safeHandle('channel:save', async (_event, { id, ...cfg }) => {
    if (!id || !cfg.type) return { success: false, message: '缺少 id 或 type' };
    const channels = loadChannelsConfig();
    channels[id] = { ...channels[id], ...cfg };
    if (saveChannelsConfig(channels)) {
      console.log(`[Channels] 保存通道: ${id}`);
      return { success: true, data: { id, ...channels[id] } };
    }
    return { success: false, message: '保存失败' };
  });

  // channel:delete — 删除通道
  safeHandle('channel:delete', async (_event, id) => {
    const channels = loadChannelsConfig();
    if (!channels[id]) return { success: false, message: '通道不存在' };
    delete channels[id];
    if (saveChannelsConfig(channels)) {
      console.log(`[Channels] 删除通道: ${id}`);
      return { success: true };
    }
    return { success: false, message: '删除失败' };
  });

  // channel:test — 测试通道凭证格式
  safeHandle('channel:test', async (_event, { type, ...cfg }) => {
    const errors = [];
    switch (type) {
      case 'feishu':
        if (!cfg.appId) errors.push('缺少 App ID');
        if (!cfg.appSecret) errors.push('缺少 App Secret');
        if (cfg.connectionMode === 'webhook' && !cfg.webhookUrl) errors.push('Webhook 模式缺少 Webhook URL');
        if (cfg.webhookUrl && !cfg.webhookUrl.startsWith('http')) errors.push('Webhook URL 格式错误');
        break;
      case 'wecom':
        if (!cfg.botId) errors.push('缺少 Bot ID');
        if (!cfg.secret) errors.push('缺少 Secret');
        if (cfg.connectionMode === 'callback') {
          if (!cfg.corpId) errors.push('回调模式缺少 Corp ID');
          if (!cfg.agentId) errors.push('回调模式缺少 Agent ID');
          if (!cfg.token) errors.push('回调模式缺少 Token');
          if (!cfg.encodingAesKey) errors.push('回调模式缺少 EncodingAESKey');
        }
        break;
      case 'dingtalk':
        if (cfg.connectionMode === 'webhook' || !cfg.connectionMode) {
          if (!cfg.webhookUrl) errors.push('Webhook 模式缺少 Webhook URL');
          if (cfg.webhookUrl && !cfg.webhookUrl.startsWith('http')) errors.push('Webhook URL 格式错误');
        } else if (cfg.connectionMode === 'app') {
          if (!cfg.appKey) errors.push('App 模式缺少 App Key');
          if (!cfg.appSecret) errors.push('App 模式缺少 App Secret');
          if (!cfg.robotCode) errors.push('App 模式缺少 Robot Code');
        }
        break;
      case 'telegram':
        if (!cfg.botToken) errors.push('缺少 Bot Token');
        if (cfg.botToken && !cfg.botToken.includes(':')) errors.push('Bot Token 格式错误（应包含冒号）');
        break;
      case 'whatsapp':
        if (!cfg.phoneNumberId) errors.push('缺少 Phone Number ID');
        if (!cfg.accessToken) errors.push('缺少 Access Token');
        if (!cfg.verifyToken) errors.push('缺少 Webhook Verify Token');
        break;
      case 'slack':
        if (!cfg.botToken) errors.push('缺少 Bot Token');
        if (cfg.botToken && !cfg.botToken.startsWith('xoxb-')) errors.push('Bot Token 应以 xoxb- 开头');
        break;
      case 'qqbot':
        if (!cfg.appId) errors.push('缺少 App ID');
        if (!cfg.appSecret) errors.push('缺少 App Secret');
        break;
      case 'signal':
        if (!cfg.signalNumber) errors.push('缺少 Signal 电话号码');
        if (cfg.signalNumber && !cfg.signalNumber.startsWith('+')) errors.push('电话号码应包含国际区号（+开头）');
        break;
      case 'mattermost':
        if (!cfg.serverUrl) errors.push('缺少服务器 URL');
        if (cfg.serverUrl && !cfg.serverUrl.startsWith('http')) errors.push('服务器 URL 格式错误');
        if (!cfg.webhookUrl && !cfg.accessToken) errors.push('需要至少配置 Webhook URL 或 Access Token 之一');
        break;
      case 'imessage':
        if (!cfg.bridgeEmail) errors.push('缺少桥接邮箱');
        if (!cfg.appPassword) errors.push('缺少应用专用密码');
        if (cfg.bridgeEmail && !cfg.bridgeEmail.includes('@')) errors.push('邮箱格式错误');
        break;
      case 'discord':
        if (!cfg.botToken) errors.push('缺少 Bot Token');
        break;
      case 'email':
        if (!cfg.smtpHost) errors.push('缺少 SMTP 主机');
        if (!cfg.smtpUser) errors.push('缺少用户名');
        if (!cfg.smtpPass) errors.push('缺少密码');
        break;
      case 'webhook':
        if (!cfg.webhookUrl) errors.push('缺少 Webhook URL');
        if (cfg.webhookUrl && !cfg.webhookUrl.startsWith('http')) errors.push('Webhook URL 格式错误');
        break;
      default: errors.push(`未知通道类型: ${type}`);
    }
    if (errors.length > 0) return { success: false, message: errors.join('; '), data: { errors } };
    return { success: true, message: `✅ ${type} 通道凭证格式验证通过` };
  });

