      { key: 'appId', label: 'App ID', type: 'text', required: true, help: 'QQ 开放平台→应用信息→AppID' },
      { key: 'appSecret', label: 'App Secret', type: 'password', required: true, help: 'QQ 开放平台→应用信息→AppSecret' },
      { key: 'token', label: 'Token', type: 'password', required: false, help: 'QQ 开放平台→机器人→Token（用于 WebSocket 鉴权）' },
      { key: 'sandbox', label: '沙箱模式', type: 'select', required: false, options: ['false', 'true'], default: 'false', help: '是否使用沙箱环境' },
    ], accessControl: true },
    signal: { type: 'signal', label: 'Signal', description: 'Signal 机器人，通过 signal-cli 接入', fields: [
      { key: 'signalNumber', label: 'Signal 电话号码', type: 'text', required: true, placeholder: '+8613800138000', help: '注册 Signal 的电话号码（带国际区号）' },
      { key: 'signalCliPath', label: 'signal-cli 路径', type: 'text', required: false, placeholder: '/usr/local/bin/signal-cli', help: 'signal-cli 可执行文件路径' },
      { key: 'configDir', label: '配置目录', type: 'text', required: false, help: 'signal-cli 配置目录（默认 ~/.config/signal' },
    ], accessControl: true },
    mattermost: { type: 'mattermost', label: 'Mattermost', description: 'Mattermost 机器人，支持 Webhook 和 Bot Token', fields: [
      { key: 'webhookUrl', label: 'Webhook URL', type: 'text', required: false, help: 'Mattermost→集成→Incoming Webhook' },
      { key: 'accessToken', label: 'Bot Access Token', type: 'password', required: false, help: 'Mattermost→集成→Bot 账号→Access Token' },
