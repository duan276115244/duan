  safeHandle('voice:load', async () => {
    return loadVoiceConfig();
  });

  safeHandle('voice:save', async (_event, config) => {
    const ok = saveVoiceConfig(config);
    return { success: ok };
  });

  safeHandle('voice:listVoices', async () => {
    return { success: true, voices: BUILTIN_VOICES };
  });

  // 查找可用的 Python 可执行文件（解决 Electron 环境下 PATH 不含 WindowsApps 别名的问题）
  let _cachedPythonCmd = null;
  function findPythonExecutable() {
    if (_cachedPythonCmd) return _cachedPythonCmd;
    const { execSync } = require('child_process');
    // 候选列表：[命令, 是否需要引号包裹]
    const candidates = [
      ['python', true],
      ['python3', true],
      ['py -3', false],
      // Microsoft Store Python 真实路径
      ['C:\\Users\\Administrator\\AppData\\Local\\Microsoft\\WindowsApps\\PythonSoftwareFoundation.Python.3.12_qbz5n2kfra8p0\\python.exe', true],
      // 常规安装路径
      ['C:\\Python312\\python.exe', true], ['C:\\Python311\\python.exe', true], ['C:\\Python310\\python.exe', true],
      ['C:\\Program Files\\Python312\\python.exe', true], ['C:\\Program Files\\Python311\\python.exe', true],
      ['C:\\Program Files (x86)\\Python312\\python.exe', true], ['C:\\Program Files (x86)\\Python311\\python.exe', true],
    ];
    for (const [cmd, needsQuote] of candidates) {
      try {
        const testCmd = needsQuote ? `"${cmd}" -c "import sys; print(sys.version)"` : `${cmd} -c "import sys; print(sys.version)"`;
        execSync(testCmd, { timeout: 5000, stdio: 'pipe' });
        _cachedPythonCmd = cmd;
        return cmd;
      } catch { /* 继续尝试下一个 */ }
    }
    return null;
  }

  // 全局变量：当前录音进程（用于手动停止录音）
  let currentRecordingProcess = null;

  // 异步执行命令（使用 spawn，不阻塞主进程）
  // 返回 Promise<{ stdout: string, stderr: string, code: number }>
  // options.onSpawn: (child) => void  — 进程启动时的回调（用于存储进程引用）
  function runProcessAsync(cmd, args, options = {}) {
    return new Promise((resolve) => {
      const timeout = options.timeout || 30000;
      const useShell = options.shell !== undefined ? options.shell : true;
      const child = spawn(cmd, args, {
        stdio: ['ignore', 'pipe', 'pipe'],
        shell: useShell,
        windowsHide: true,
      });
      if (options.onSpawn) {
        try { options.onSpawn(child); } catch { /* ignore */ }
      }
      let stdout = '';
      let stderr = '';
      let timer = null;

      child.stdout.on('data', (data) => { stdout += data.toString(); });
      child.stderr.on('data', (data) => { stderr += data.toString(); });

      child.on('error', (err) => {
        if (timer) clearTimeout(timer);
        resolve({ stdout, stderr: stderr + err.message, code: -1 });
      });

      child.on('close', (code) => {
        if (timer) clearTimeout(timer);
        resolve({ stdout, stderr, code: code ?? -1 });
      });

      timer = setTimeout(() => {
        try { child.kill('SIGKILL'); } catch { /* ignore */ }
        resolve({ stdout, stderr: stderr + '\n进程超时被终止', code: -2 });
      }, timeout);
    });
  }

  // 手动停止录音：创建停止信号文件（Python 脚本检测到后优雅停止并转写已录内容）
  safeHandle('voice:stopRecording', async () => {
    // 优先使用停止信号文件（优雅停止，能转写已录内容）
    const tmpDir = path.join(os.tmpdir(), 'duan-voice');
    if (fs.existsSync(tmpDir)) {
      try {
        const stopFiles = fs.readdirSync(tmpDir).filter(f => f.startsWith('stop_') && f.endsWith('.signal'));
        for (const f of stopFiles) {
          const stopFilePath = path.join(tmpDir, f);
          fs.writeFileSync(stopFilePath, 'stop', 'utf-8');
        }
        if (stopFiles.length > 0) {
          return { success: true, message: '停止信号已发送' };
        }
      } catch (e) {
        // 信号文件方式失败，回退到强制终止
      }
    }
    // 回退：强制终止进程
    if (currentRecordingProcess) {
      try {
        currentRecordingProcess.kill('SIGKILL');
        currentRecordingProcess = null;
        return { success: true, message: '录音已强制停止' };
      } catch (e) {
        return { success: false, error: '停止录音失败: ' + e.message };
      }
    }
    return { success: true, message: '没有正在进行的录音' };
  });

