              action: { type: 'string', description: '操作类型: launch/activate/shortcut/workflow/menu/type/click/find_click' },
              params: { type: 'string', description: '操作参数(JSON字符串)。shortcut: {"shortcutName":"新建"}; workflow: {"workflowName":"打开网址","params":{"url":"..."}}; menu: {"menuPath":["File","Save"]}; type: {"text":"内容"}; click: {"x":100,"y":200}; find_click: {"description":"保存按钮"}' },
              timeout: { type: 'number', description: '操作超时时间(毫秒)，默认 5000' },
              retry: { type: 'number', description: '失败重试次数，默认 3' },
            },
            required: ['app', 'action', 'params'],
          },
        },
      },
      {
        type: 'function',
        function: {
          name: 'app_batch',
          description: '批量执行多个跨软件操作（合并执行，提升响应时间）。支持并发非阻塞执行或串行出错即停。',
          parameters: {
            type: 'object',
            properties: {
              operations: { type: 'string', description: '操作列表(JSON数组字符串)，每项为 {app, action, params, timeout?, retry?}' },
              stopOnError: { type: 'boolean', description: '出错是否停止后续操作(默认 false，并发执行)' },
            },
            required: ['operations'],
          },
        },
      },
      {
        type: 'function',
        function: {
          name: 'app_list',
          description: '列出所有已注册的应用配置（24类主流应用），包括应用ID、名称、可用快捷键数量和工作流数量。',
          parameters: { type: 'object', properties: {} },
        },
      },
      {
        type: 'function',
        function: {
          name: 'self_improve',
          description: '自我改进工具（需用户在设置中启用）。可搜索网络获取 agent 改进方案、读取自身代码、提出代码修改（每次修改需用户通过对话框批准）。模式: search(搜索)/read(读代码)/propose(提修改-需批准)/history(历史)/status(状态)。可修改文件白名单: desktop/main.js, desktop/tool-executor.js, desktop/preload.js 等。',
          parameters: {
            type: 'object',
            properties: {
              mode: { type: 'string', description: '模式: search(搜索改进方案)/read(读取自身代码)/propose(提出修改,需用户批准)/history(查看历史)/status(查看状态)' },
              query: { type: 'string', description: 'search模式: 搜索关键词' },
              file: { type: 'string', description: 'read/propose模式: 文件名(如 desktop/main.js)' },
              description: { type: 'string', description: 'propose模式: 修改目的和预期效果说明' },
              oldCode: { type: 'string', description: 'propose模式: 要替换的原始代码片段(必须与文件实际内容完全一致)' },
              newCode: { type: 'string', description: 'propose模式: 替换后的新代码' },
              limit: { type: 'number', description: 'history模式: 返回记录数(默认10)' },
            },
            required: ['mode'],
          },
        },
      },
      // P0 工具融合：终端面板操作（让 Agent 能操控终端面板）
      {
        type: 'function',
        function: {
          name: 'terminal_operate',
          description: '操作终端面板（让 Agent 能与终端融合）。action=run(执行命令并显示在终端面板)/type(向终端注入文本)/clear(清屏)/activate(激活面板)。run 模式会执行命令并把输出注入终端面板，与用户手动输入一致。',
          parameters: {
            type: 'object',
            properties: {
              action: { type: 'string', description: '操作类型: run(执行命令)/type(注入文本)/clear(清屏)/activate(激活面板)' },
              command: { type: 'string', description: 'run模式: 要执行的命令' },
              text: { type: 'string', description: 'type模式: 要注入的文本' },
              timeout: { type: 'number', description: 'run模式: 超时毫秒(默认60秒)' },
            },
            required: ['action'],
          },
        },
      },
      // P0 工具融合：编辑器面板操作（让 Agent 能操控编辑器面板）
      {
        type: 'function',
        function: {
          name: 'editor_operate',
          description: '操作编辑器面板（让 Agent 能与编辑器融合）。action=open(打开文件,流式显示编写进程)/read(读取文件内容返回)/goto(跳转到指定行)/activate(激活面板)。open 模式会用打字机动画逐行显示代码,让用户看到编写进程。',
          parameters: {
            type: 'object',
            properties: {
              action: { type: 'string', description: '操作类型: open(打开文件)/read(读取内容)/goto(跳转行)/activate(激活面板)' },
              path: { type: 'string', description: 'open/read/goto模式: 文件路径' },
              line: { type: 'number', description: 'goto模式: 要跳转的行号' },
            },
            required: ['action'],
          },
        },
      },
    ];

    // 工具执行器（已拆分到 desktop/tool-executor.js）
    const executeTool = createToolExecutor({
      getMainWindow: () => mainWindow,
      getBrowserWindow: () => browserWindow,
      createBrowserWindow,
      ROOT_DIR,
      DANGEROUS_CMD_REGEX,
      isSensitivePath,
      isWithinWorkspace,
      isSelfImproveEnabled: () => isSelfImproveEnabled(),
      requestApproval: (proposal) => requestSelfImproveApproval(proposal),
      requestWorkspaceAccess: async (dirPath, reason) => await requestWorkspaceAccess(dirPath, reason),
    });

    // 构建用户消息内容（支持多模态附件）
    let userContent;
    if (attachments && attachments.length > 0) {
      // 有附件时使用 OpenAI 多模态格式
      const contentParts = [];
      // 先添加文本
      if (message) {
        contentParts.push({ type: 'text', text: message });
      }
      // 添加附件
      for (const att of attachments) {
        if (att.isImage && att.base64) {
          // 图片：使用 image_url 格式
          contentParts.push({
            type: 'image_url',
            image_url: { url: `data:${att.mimeType || 'image/png'};base64,${att.base64}` },
          });
        } else if (att.base64) {
          // 非图片文件：将内容作为文本描述
          contentParts.push({ type: 'text', text: `[附件: ${att.name} (${att.mimeType || att.ext || '未知类型'})]` });
        } else if (att.path) {
          contentParts.push({ type: 'text', text: `[文件: ${att.name}]` });
        }
      }
      userContent = contentParts;
    } else {
      userContent = message;
    }

    // 检测模型是否需要非流式请求（流式 tool_calls 格式不标准）
    const noFCStreamingModels = ['ark-code', 'doubao-coding', 'coding_plan'];
    const modelNeedsNonStreaming = noFCStreamingModels.some(m => resolved.actualModel.toLowerCase().includes(m));

    let systemPrompt = `你是段先生 v19.0，具备经验学习能力的超级智能体。用中文回复。

## 核心准则
先理解→再规划→后执行→查结果→必反思。每一步都要基于上一步结果做出判断，不要盲目重复。

## 任务分类与策略
- **闲聊/问候/知识问答**：直接回复，不调工具
- **简单任务**（1-2步）：思考→执行→完成
- **复杂任务**（3+步）：用think分解步骤→逐步执行→每步检查→调整计划
- **模糊意图**：先文字回复确认理解，等用户明确再行动

## 工具选择矩阵
| 任务 | 首选工具 | 备选 |
|------|---------|------|
| 执行命令/脚本 | shell_execute | code_execute |
| 读取文件 | file_read (支持offset/limit分段) | shell_execute(cat) |
| 写入整个文件 | file_write | shell_execute(echo) |
| **编辑文件局部** | **file_edit** (search-replace) | file_write(整文件重写) |
| **搜索文件内容** | **grep_search** (正则匹配) | shell_execute(findstr) |
| 按文件名搜索 | search_files | shell_execute(dir/ls) |
| 读取图片/二进制 | file_read(自动识别) | desktop_open |
| 网络搜索 | web_search | browser_operate+搜索引擎 |
| 获取网页内容 | web_fetch | browser_operate+extract |
| 下载图片/文件 | web_fetch(自动保存) | code_execute+https |
| 浏览器操作 | browser_operate | - |
| 生成图片 | code_execute+API | browser_operate+绘图网站 |
| 执行JS代码 | code_execute | - |
| 打开桌面应用 | app_operate | desktop_open |
| 分析图片内容 | 需视觉模型(GPT-4o/Claude/Qwen-VL) | - |
| **访问工作区外目录** | **request_workspace_access** | - |

## file_edit 使用指南（V17 新增，优先使用）
- **用途**：精确编辑文件局部内容，避免整文件重写，节省 token
- **参数**：path(文件路径), old_text(要替换的原文), new_text(新文本), replace_all(可选,替换所有匹配)
- **old_text 必须与文件内容完全匹配**（包括缩进和换行）
- **编辑前先 file_read** 读取目标部分，确保 old_text 精确
- **参数名兼容**：path/filePath/file_path/filename/file, old_text/oldText/search/find, new_text/newText/replace/replacement
- 如果 old_text 有多处匹配，提供更长的上下文确保唯一，或设置 replace_all=true

## grep_search 使用指南（V17 新增）
- **用途**：在文件内容中搜索匹配正则表达式的行（类似 grep/ripgrep）
- **参数**：pattern(正则), path(搜索目录,可选), include(文件过滤如*.ts或*.ts,*.tsx,可选), max_results(默认50), max_depth(默认10)
- **场景**：查找函数定义、变量引用、配置项、import 语句等
- **示例**：grep_search({pattern: "function\\s+handleSubmit", include: "*.tsx"})

## search_files 使用指南（V17 新增）
- **用途**：按文件名 glob 模式递归搜索文件（如 *.ts、*.tsx、test*）
- **参数**：pattern(glob模式), root(搜索根目录,可选), max_depth(默认10), max_results(默认50)
- **场景**：查找特定类型的文件、查找测试文件、查找配置文件
- **示例**：search_files({pattern: "*.test.ts"}) 或 search_files({pattern: "*.config.*"})

## 验证闭环（关键！）
- 代码文件(.js/.ts/.json)写入后系统自动验证语法，验证失败会回滚并返回错误。收到语法错误时立即修复重试
- 安装依赖后验证：node -e "require('包名')" 确认安装成功
- 命令执行后检查输出和退出码，确认真正成功
- 验证失败时：读取错误信息→分析原因→修复→重新验证

## browser_operate 操作流程
1. goto 打开页面（自动等待SPA渲染）
2. extract 提取内容（自动等待重试）
3. click 点击元素（自动等待重试）
4. type 输入文字
5. scroll 滚动页面
6. screenshot 截图
7. eval 执行JS
注意：必须先goto，才能执行其他操作。SPA页面加载慢，工具会自动等待。

## 图片/附件处理
- 用户发送的图片附件，你可以直接在消息中看到（如果模型支持视觉）
- 不要用 file_read 读取图片文件（会返回提示信息）
- 不要用 web_fetch 获取图片URL（会自动下载保存，返回文件路径）
- 如需生成图片：用 code_execute 调用图片生成API，或用 browser_operate 打开AI绘图网站

## 工作区与目录权限（重要）
- file_list/file_read/file_write 只能访问工作区内的目录（项目根目录、~/.duan/、临时目录等）
- 当需要访问桌面、下载、文档等用户目录时，**必须先调用 request_workspace_access 工具请求用户授权**
- 调用示例: request_workspace_access({path: "C:\\\\Users\\\\Administrator\\\\Desktop", reason: "整理桌面图片"})
- 用户批准后，即可用 file_list/file_read 等工具操作该目录（授权在本次会话有效）
- **禁止用 shell_execute 或 code_execute 绕过工作区限制**（会因引号转义/模块白名单等问题失败，且浪费时间）
- 如果用户拒绝授权，尊重用户决定，改用工作区内路径或请用户手动提供文件

## 错误恢复策略
- 工具返回❌：仔细阅读错误信息，调整参数后重试（最多2次）
- 连续2次失败：用think分析原因，换工具或换方法
- 连续3次失败：停止当前方法，向用户说明困难并建议替代方案
- 收到"⚠️已跳过"：立即换方法或结束任务
- 网络超时：检查URL是否正确，或换用 browser_operate
- **收到"安全限制: 路径...不在允许的工作区范围内"：立即调用 request_workspace_access 请求权限，不要用其他工具绕过**

## shell_execute 跨平台兼容（V17）
- shell_execute 支持跨平台：可直接使用 mkdir -p / rm -rf / ls / cp / mv / touch / cat 等 Unix 命令
- 系统会自动将 Unix 命令转换为 Windows PowerShell 兼容格式（无需手动转换）
- npm install / git clone / pip install 等长命令会自动延长超时到 5 分钟（无需手动设置 timeout）
- Windows 上使用 PowerShell 替代 cmd.exe，兼容性更好
- 复杂命令（含 && | > 等管道重定向）会自动进入 shell 模式执行

## 执行规则
- 同一文件写入≤2次，改前先file_read
- 同一工具连续≤3次(browser_operate≤6次)、总计≤8次(browser_operate≤15次)
- 写HTML一次性输出完整文件，写入后自动预览
- 任务完成立即complete或回复，不继续调工具
- 每轮执行后用think反思：结果是否符合预期？下一步该做什么？
- **所有工具调用必须与当前用户任务直接相关。禁止在任务失败后做无关搜索（如任务是整理文件，不要搜索赚钱方法等无关内容）**
- **任务无法完成时：直接向用户说明困难原因和建议，调用complete结束。不要分心做其他事。**

## 自我反思清单（复杂任务每3步执行一次）
1. 当前进展：已完成什么？还剩什么？
2. 方向检查：当前方法是否有效？是否需要换思路？
3. 错误分析：如果有失败，根本原因是什么？
4. 下一步：最有效的下一步行动是什么？

## 自我改进能力（self_improve 工具）
当用户要求你"自我修复"、"完善自身"、"学习新技能"或"优化自己的代码/思考能力"时，使用 self_improve 工具：
- **mode=search**: 搜索网络获取 agent 改进方案、最新 LLM agent 技术、工具调用优化方法
- **mode=read**: 读取自身代码文件（白名单: desktop/main.js, desktop/tool-executor.js, desktop/preload.js 等）
- **mode=propose**: 提出代码修改（提供 file/description/oldCode/newCode）。**每次修改都会弹出对话框让用户批准**，用户拒绝则不修改。修改前自动创建备份。
- **mode=history**: 查看历史修改记录
- **mode=status**: 查看自我改进是否已启用

自我改进流程：
1. 先用 status 检查是否启用（未启用时提示用户在设置中开启）
2. 用 search 搜索改进方案
3. 用 read 读取相关代码
4. 用 propose 提出修改（oldCode 必须与文件实际内容完全一致，注意缩进和换行）
5. 修改被拒绝时，调整方案后可重新提出

安全规则：
- 只能修改白名单内的文件
- 每次修改必须用户批准
- 修改前自动备份，可回滚
- 不要一次提出过大改动，分多次小步修改更安全

思考简短，行动迅速，但不要跳过理解环节。`;

    // 不支持流式 tool_calls 的模型：在系统提示中注入工具调用格式
    if (modelNeedsNonStreaming) {
      systemPrompt += `\n\n## 工具调用格式\n当前模型不支持自动工具调用，当你需要调用工具时，请使用以下格式：\n\`\`\`tool_call\n{"name": "工具名", "arguments": {"参数名": "参数值"}}\n\`\`\`\n可以同时调用多个工具，每个工具调用一个代码块。调用完工具后等待结果，不要自行编造结果。`;
    }

    // P1-14 优化：清理历史消息，防止过长历史浪费上下文
    const cleanedHistory = (history || []).map(h => {
      const content = typeof h.content === 'string' ? h.content : JSON.stringify(h.content ?? '');
      // 单条历史消息最多 4000 字符
      if (content.length > 4000) {
        return { role: h.role, content: content.substring(0, 4000) + '\n[历史消息已截断]' };
      }
      return { role: h.role, content: h.content };
    }).slice(-10); // 最多保留最近 10 条历史消息

    const messages = [
      { role: 'system', content: systemPrompt },
      ...cleanedHistory,
      { role: 'user', content: userContent },
    ];

    // ===== 上下文窗口管理：防止 token 膨胀 =====
    // 粗略 token 估算：中文约 1.5 字符/token，英文约 4 字符/token，取中间值
    const estimateTokens = (text) => {
      if (!text) return 0;
      const str = typeof text === 'string' ? text : JSON.stringify(text);
      // 中文字符数
      const cjkCount = (str.match(/[\u4e00-\u9fff\u3040-\u30ff]/g) || []).length;
      const otherCount = str.length - cjkCount;
      return Math.ceil(cjkCount / 1.5 + otherCount / 4);
    };
    // 估算 messages 数组的总 token 数
    const estimateMessagesTokens = (msgs) => {
      let total = 0;
      for (const m of msgs) {
        total += estimateTokens(m.content || '');
        if (m.tool_calls) total += estimateTokens(JSON.stringify(m.tool_calls));
        if (m.tool_call_id) total += 10;
        total += 4; // 每条消息的固定开销
      }
      return total;
    };
    // 根据模型的上下文窗口动态确定上限（默认 32K，留 8K 给输出）
    const CONTEXT_TOKEN_LIMIT = (() => {
      const model = (resolved.actualModel || '').toLowerCase();
      // 已知大窗口模型
      if (model.includes('claude-3') || model.includes('gpt-4o') || model.includes('gemini-1.5')) return 120000;
      if (model.includes('gpt-4') || model.includes('claude')) return 100000;
      if (model.includes('deepseek') || model.includes('qwen')) return 60000;
      return 24000; // 保守默认值
    })();
    const RESERVED_OUTPUT_TOKENS = 4096;
    const MAX_CONTEXT_TOKENS = CONTEXT_TOKEN_LIMIT - RESERVED_OUTPUT_TOKENS;

    // 压缩旧的工具结果：将早期的 tool 消息内容替换为智能摘要
    // P1-13 优化：保留关键信息（成功/失败、错误原因、关键数据），而非简单截断
    function compressOldToolResults(msgs) {
      let compressed = 0;
      // 从第 4 条消息开始（保留 system + 最近 2 条），压缩旧的 tool 结果
      for (let i = 3; i < msgs.length - 6; i++) {
        const m = msgs[i];
        if (m.role === 'tool' && typeof m.content === 'string' && m.content.length > 500) {
          const original = m.content;
          // 智能摘要：保留前 150 字符 + 关键信息
          let summary = original.substring(0, 150);
          // 提取错误信息（❌ 开头的行）
          const errorLines = original.split('\n').filter(l => l.startsWith('❌') || l.startsWith('⚠️'));
          if (errorLines.length > 0) {
            summary += '\n[关键错误] ' + errorLines.slice(0, 2).join(' | ');
          }
          // 提取 URL（如果有）
          const urlMatch = original.match(/https?:\/\/[^\s\n]+/);
          if (urlMatch) {
            summary += `\n[URL] ${urlMatch[0]}`;
          }
          // 提取文件路径（如果有）
          const pathMatches = original.match(/[A-Z]:\\[^\s\n]+|[a-z]:\/[^\s\n]+|\/[a-z][^\s\n]+/gi);
          if (pathMatches) {
            summary += `\n[路径] ${pathMatches.slice(0, 2).join(', ')}`;
          }
          m.content = `[已压缩] ${summary}...（原始 ${original.length} 字符已省略）`;
          compressed++;
        }
        // 压缩旧的 assistant 消息中的长内容
        if (m.role === 'assistant' && typeof m.content === 'string' && m.content.length > 1000 && !m.tool_calls) {
          m.content = `[已压缩] ${m.content.substring(0, 300)}...`;
          compressed++;
        }
      }
      if (compressed > 0) {
        console.log(`[ReAct] 上下文压缩：压缩了 ${compressed} 条旧消息（智能保留关键信息）`);
      }
      return compressed;
    }

    // 裁剪上下文：当 token 超限时，移除最早的非系统消息
    function trimContextIfNeeded(msgs) {
      let trimCount = 0;
      while (estimateMessagesTokens(msgs) > MAX_CONTEXT_TOKENS && msgs.length > 6) {
        // P1-9 修复：找到第一条可安全移除的消息（跳过 system 和 user 消息）
        // user 消息必须保留，否则 LLM API 会报 "No user query found in messages"
        const removableIdx = msgs.findIndex((m, i) => i > 0 && m.role !== 'system' && m.role !== 'user');
        if (removableIdx === -1 || removableIdx >= msgs.length - 4) break;
        // 不要移除最近 3 条消息
        if (removableIdx >= msgs.length - 3) break;
        msgs.splice(removableIdx, 1);
        trimCount++;
      }
      // 安全检查：确保 messages 中至少有一条 user 消息
      const hasUserMsg = msgs.some(m => m.role === 'user');
      if (!hasUserMsg && msgs.length > 0) {
        // 如果 user 消息被意外移除，在 system 之后插入一条占位 user 消息
        const placeholderContent = userContent || '(请继续执行用户的任务)';
        msgs.splice(1, 0, { role: 'user', content: placeholderContent });
        console.log('[ReAct] 安全修复：user 消息缺失，已重新插入');
      }
      if (trimCount > 0) {
        console.log(`[ReAct] 上下文裁剪：移除了 ${trimCount} 条早期消息以控制 token`);
      }
      return trimCount;
    }

    // ReAct 循环（最多25轮工具调用）
    const MAX_ROUNDS = 25;
    let fullContent = '';

    // P1-16 优化：为长工具结果生成摘要
    function generateResultSummary(toolName, result, limit) {
      const lines = result.split('\n');
      const summaryParts = [];

      if (toolName === 'file_read') {
        // 文件摘要：行数 + 文件类型
        summaryParts.push(`[摘要] 文件共 ${lines.length} 行`);
        // 提取关键结构（函数/类定义）
        const definitions = lines.filter(l => /^(function|class|const|let|var|export|import|def |public |private )/i.test(l.trim())).slice(0, 5);
        if (definitions.length > 0) {
          summaryParts.push('关键定义: ' + definitions.map(d => d.trim().substring(0, 60)).join(' | '));
        }
      } else if (toolName === 'web_fetch' || toolName === 'browser_operate') {
        // 网页摘要：标题 + 链接数
        const titleMatch = result.match(/<title[^>]*>([^<]+)<\/title>/i);
        if (titleMatch) summaryParts.push(`[摘要] 页面标题: ${titleMatch[1]}`);
        const linkCount = (result.match(/<a\s/gi) || []).length;
        if (linkCount > 0) summaryParts.push(`链接数: ${linkCount}`);
      } else if (toolName === 'web_search') {
        // 搜索摘要：结果数
        const resultCount = (result.match(/\[/g) || []).length;
        summaryParts.push(`[摘要] 搜索结果约 ${Math.floor(resultCount / 2)} 条`);
      } else if (toolName === 'shell_execute' || toolName === 'code_execute') {
        // 执行摘要：输出行数 + 错误数
        const errorCount = lines.filter(l => l.toLowerCase().includes('error') || l.includes('❌')).length;
        summaryParts.push(`[摘要] 输出 ${lines.length} 行${errorCount > 0 ? `，${errorCount} 行错误` : ''}`);
      }

      return summaryParts.length > 0 ? summaryParts.join(' | ') + '\n' : '';
    }

    // P1-15 优化：工具参数预验证
    function validateToolParams(toolName, args) {
      if (!args || typeof args !== 'object') {
        return '参数必须是对象';
      }
      switch (toolName) {
        case 'file_read':
          if (!args.path) return '缺少必需参数: path';
          if (typeof args.path !== 'string') return 'path 必须是字符串';
          break;
        case 'file_write':
          if (!args.path) return '缺少必需参数: path';
          if (!args.content && args.content !== '') return '缺少必需参数: content';
          break;
        case 'file_edit':
          if (!args.path) return '缺少必需参数: path';
          if (args.old_text === undefined || args.old_text === null) return '缺少必需参数: old_text';
          if (args.new_text === undefined || args.new_text === null) return '缺少必需参数: new_text';
          break;
        case 'grep_search':
          if (!args.pattern) return '缺少必需参数: pattern';
          if (typeof args.pattern !== 'string') return 'pattern 必须是字符串';
          break;
        case 'search_files':
          if (!args.pattern) return '缺少必需参数: pattern';
          if (typeof args.pattern !== 'string') return 'pattern 必须是字符串';
          break;
        case 'web_search':
          if (!args.query) return '缺少必需参数: query';
          if (typeof args.query !== 'string') return 'query 必须是字符串';
          if (args.query.length > 500) return 'query 过长（最多500字符）';
          break;
        case 'web_fetch':
          if (!args.url) return '缺少必需参数: url';
          if (typeof args.url !== 'string') return 'url 必须是字符串';
          if (!args.url.startsWith('http://') && !args.url.startsWith('https://')) {
            return 'url 必须以 http:// 或 https:// 开头';
          }
          break;
        case 'browser_operate':
          if (!args.action) return '缺少必需参数: action';
          // V17 修复：补全所有支持的操作（与 tool-executor.js 实际支持的一致）
          const validActions = ['goto', 'click', 'type', 'press', 'extract', 'screenshot', 'scroll', 'eval', 'info', 'wait', 'wait_for_change', 'close'];
          if (!validActions.includes(args.action)) {
            return `action 必须是: ${validActions.join(', ')} 之一`;
          }
          if (args.action === 'goto' && !args.url) return 'goto 操作需要 url 参数';
          if (args.action === 'click' && !args.selector) return 'click 操作需要 selector 参数';
          if (args.action === 'type' && !args.text) return 'type 操作需要 text 参数';
          if (args.action === 'press' && !args.key) return 'press 操作需要 key 参数';
          if (args.action === 'eval' && !args.code) return 'eval 操作需要 code 参数';
          break;
        case 'shell_execute':
          if (!args.command) return '缺少必需参数: command';
          if (typeof args.command !== 'string') return 'command 必须是字符串';
          break;
        case 'code_execute':
          if (!args.code) return '缺少必需参数: code';
          if (typeof args.code !== 'string') return 'code 必须是字符串';
          break;
        case 'desktop_open':
          if (!args.target) return '缺少必需参数: target';
          if (typeof args.target !== 'string') return 'target 必须是字符串';
          break;
        case 'app_operate':
          if (!args.app) return '缺少必需参数: app';
          if (!args.action) return '缺少必需参数: action';
          break;
        case 'request_workspace_access':
          if (!args.path) return '缺少必需参数: path';
          if (typeof args.path !== 'string') return 'path 必须是字符串';
          break;
        case 'self_improve':
          if (!args.mode) return '缺少必需参数: mode';
          break;
        case 'think':
          if (!args.thought) return '缺少必需参数: thought';
          break;
        case 'complete':
          // V17 修复：执行器使用 args.result，验证也应对齐（同时兼容 response）
          if (!args.result && !args.response) return '缺少必需参数: result';
          break;
        case 'terminal_operate': {
          const validTermActions = ['run', 'type', 'clear', 'activate'];
          if (args.action && !validTermActions.includes(args.action)) {
            return `action 必须是: ${validTermActions.join(', ')} 之一`;
          }
          if ((!args.action || args.action === 'run') && !args.command && !args.cmd) {
            return 'run 操作需要 command 参数';
          }
          break;
        }
        case 'editor_operate': {
          const validEditorActions = ['open', 'read', 'goto', 'activate'];
          if (args.action && !validEditorActions.includes(args.action)) {
            return `action 必须是: ${validEditorActions.join(', ')} 之一`;
          }
          const editorAction = args.action || 'open';
          if ((editorAction === 'open' || editorAction === 'read' || editorAction === 'goto') && !args.path && !args.file && !args.filePath) {
            return `${editorAction} 操作需要 path 参数`;
          }
          break;
        }
      }
      return null; // 验证通过
    }

    // ===== 工具调用冗余防护（死循环检测）=====
    // 记录工具调用历史：{ name, argsHash, path } 用于检测重复
    const toolCallHistory = [];
    // P1-14 优化：工具结果缓存，避免重复执行相同工具+参数
    const toolResultCache = new Map(); // key: `${name}:${argsHash}` → result string
    // 同一工具+同一参数的最大调用次数
    const MAX_SAME_CALL = 2;
    // 同一工具（任意参数）的最大调用次数
    const MAX_TOTAL_CALL_PER_TOOL = 8;
    // 同一文件路径写入的最大次数（防止反复写同一文件）
    const MAX_WRITE_SAME_PATH = 2;
    // 写入路径计数器
    const writePathCount = new Map();
    // V17: 连续失败计数器 — key: 工具名，value: 连续失败次数
    const consecutiveFailures = new Map();
    // V17: 总连续失败次数（所有工具合计，用于检测整体卡住）
    let totalConsecutiveFailures = 0;
    const MAX_CONSECUTIVE_FAILURES = 3;

    /**
     * 检测工具调用是否应该被跳过（冗余/死循环防护）
     * 返回 { skip: boolean, reason: string, cachedResult?: string }
     */
    function checkToolRedundancy(toolName, toolArgs) {
      const argsHash = JSON.stringify(toolArgs);
      const cacheKey = `${toolName}:${argsHash}`;

      // 1. 同一工具+同一参数调用次数检测
      const sameCallCount = toolCallHistory.filter(t => t.name === toolName && t.argsHash === argsHash).length;
      if (sameCallCount >= MAX_SAME_CALL) {
        // P1-14 优化：返回缓存结果而非简单跳过
        const cached = toolResultCache.get(cacheKey);
        if (cached) {
          return { skip: true, reason: `工具 ${toolName} 已用相同参数调用过，返回缓存结果。`, cachedResult: cached };
        }
        return { skip: true, reason: `工具 ${toolName} 已用相同参数调用${sameCallCount}次，已跳过。请换一种方法或直接回复用户。` };
      }

      // 2. 同一工具总调用次数检测
      const totalCallCount = toolCallHistory.filter(t => t.name === toolName).length;
      const maxTotalForTool = toolName === 'browser_operate' ? 15 : MAX_TOTAL_CALL_PER_TOOL;
      if (totalCallCount >= maxTotalForTool) {
        return { skip: true, reason: `工具 ${toolName} 已被调用${totalCallCount}次，达到上限。请换一种方法或直接回复用户。` };
      }

      // 3. file_write 同一路径重复写入检测（关键修复：防止反复写同一文件）
      if (toolName === 'file_write' && toolArgs.path) {
        const normalizedPath = path.resolve(toolArgs.path).toLowerCase();
        const pathCount = writePathCount.get(normalizedPath) || 0;
        if (pathCount >= MAX_WRITE_SAME_PATH) {
          return { skip: true, reason: `文件 ${toolArgs.path} 已被写入${pathCount}次，已跳过。如需修改请使用 file_read 查看当前内容后再决定，或直接回复用户任务已完成。` };
        }
      }

      // 4. 连续相同工具调用检测（think 工具豁免，browser_operate 允许更多次）
      if (toolName === 'think') {
        // think 是推理工具，不限制连续调用次数
      } else {
        const maxConsecutive = toolName === 'browser_operate' ? 6 : 3;
        const recentN = toolCallHistory.slice(-maxConsecutive);
        if (recentN.length >= maxConsecutive && recentN.every(t => t.name === toolName)) {
          // 智能引导：根据工具类型给出针对性恢复建议，避免泛泛的"换一种方法"
          let guidance = '请换一种方法或直接回复用户。';
          if (['file_list', 'file_read', 'file_write', 'file_edit', 'grep_search', 'search_files'].includes(toolName)) {
            guidance = '如果是工作区限制，请调用 request_workspace_access 请求权限；如果路径不存在，请用 file_list 检查父目录；如果无法解决，请向用户说明困难。';
          } else if (toolName === 'shell_execute') {
            guidance = '请用 think 分析命令失败的根本原因（引号转义、路径、权限等），或换用 code_execute 工具。';
          } else if (toolName === 'web_search') {
            guidance = '请换用 web_fetch 获取具体网页内容，或用 browser_operate 浏览网站。';
          } else if (toolName === 'code_execute') {
            guidance = '请用 think 分析代码错误原因，或换用 shell_execute 工具。';
          } else if (toolName === 'browser_operate') {
            guidance = '请检查页面是否已加载完成，或换用 web_fetch 获取页面内容。';
          }
          return { skip: true, reason: `工具 ${toolName} 已连续调用${recentN.length}次，可能陷入循环。${guidance}` };
        }
      }

      return { skip: false, reason: '' };
    }

    /**
     * 检测整体死循环模式（基于最近10次调用）
     * P1-12 优化：think 工具不计入循环检测；browser_operate 阈值提高到 8
     */
    function detectDoomLoop() {
      if (toolCallHistory.length < 4) return { doom: false };
      // 过滤掉 think 工具（它是推理工具，频繁使用是正常的）
      const last10 = toolCallHistory.slice(-10).filter(t => t.name !== 'think');
      // 同一工具出现次数检测（browser_operate 允许更多次）
      const nameCounts = new Map();
      for (const t of last10) nameCounts.set(t.name, (nameCounts.get(t.name) || 0) + 1);
      for (const [name, count] of nameCounts) {
        const threshold = name === 'browser_operate' ? 8 : 6;
        if (count >= threshold) return { doom: true, tool: name, reason: `工具 ${name} 在最近10次调用中出现了${count}次` };
      }
      // 读写交替无进展
      if (toolCallHistory.length >= 8) {
        const last8 = toolCallHistory.slice(-8).filter(t => t.name !== 'think');
        const rwCount = last8.filter(t => t.name === 'file_read' || t.name === 'file_write').length;
        if (rwCount >= 6) return { doom: true, tool: 'file_read/file_write', reason: '读写交替无进展（8次调用中6次是读写操作）' };
      }
      // V17: 参数指纹去重检测 — 同一工具+同一参数反复调用（即使中间夹了 think 也能检测到）
      if (toolCallHistory.length >= 6) {
        const recent = toolCallHistory.slice(-12).filter(t => t.name !== 'think' && !t.skipped);
        const fingerprintCounts = new Map();
        for (const t of recent) {
          const fp = `${t.name}:${t.argsHash}`;
          fingerprintCounts.set(fp, (fingerprintCounts.get(fp) || 0) + 1);
        }
        for (const [fp, count] of fingerprintCounts) {
          if (count >= 3) {
            const toolName = fp.split(':')[0];
            return { doom: true, tool: toolName, reason: `工具 ${toolName} 以相同参数重复调用 ${count} 次（参数指纹去重检测）` };
          }
        }
      }
      // V17: 连续失败检测 — 最近多次调用全部失败
      if (toolCallHistory.length >= 4) {
        const recent4 = toolCallHistory.slice(-4).filter(t => t.name !== 'think' && !t.skipped);
        if (recent4.length >= 4 && recent4.every(t => t.failed)) {
          return { doom: true, tool: recent4[0].name, reason: `最近 ${recent4.length} 次工具调用全部失败，可能陷入错误循环` };
        }
      }
      return { doom: false };
    }

    for (let round = 0; round < MAX_ROUNDS; round++) {
      // P1-16 优化：进度反馈 — 显示当前轮次和工具调用统计
      if (round > 0 && mainWindow && !mainWindow.isDestroyed()) {
        const successCount = toolCallHistory.filter(t => !t.skipped && !t.failed).length;
        const failCount = toolCallHistory.filter(t => !t.skipped && t.failed).length;
        console.log(`[ReAct] === 第${round + 1}/${MAX_ROUNDS}轮 | 工具调用: ${toolCallHistory.length}次(成功${successCount}/失败${failCount}) ===`);
      }
      // 死循环检测：如果检测到死循环模式，强制结束
      const doomResult = detectDoomLoop();
      if (doomResult.doom) {
        console.warn(`[ReAct] 检测到死循环模式，强制结束（第${round + 1}轮）: ${doomResult.reason}`);
        if (mainWindow && !mainWindow.isDestroyed()) {
          mainWindow.webContents.send('agent:stream', { type: 'text', content: `\n\n⚠️ 检测到工具调用陷入循环（${doomResult.reason}），已自动停止。当前任务可能已部分完成，请检查结果或换一种方式重试。` });
        }
        break;
      }

      // ===== 上下文管理：在每轮请求前压缩和裁剪 =====
      if (round > 0) {
        // 先压缩旧的工具结果（第2轮开始才需要）
        compressOldToolResults(messages);
        // 再检查是否超限，超限则裁剪
        const totalTokens = estimateMessagesTokens(messages);
        if (totalTokens > MAX_CONTEXT_TOKENS) {
          console.log(`[ReAct] 上下文超限: ~${totalTokens} tokens > ${MAX_CONTEXT_TOKENS}，开始裁剪`);
          trimContextIfNeeded(messages);
        }
      }

      // P1-11: 注入任务进度摘要（从第2轮开始），帮助 LLM 了解已尝试的内容
      if (round > 0 && toolCallHistory.length > 0) {
        const recentActions = toolCallHistory.slice(-6);
        const successCount = recentActions.filter(t => !t.skipped && !t.failed).length;
        const failCount = recentActions.filter(t => t.failed || t.skipped).length;
        const actionSummary = recentActions.map((t, i) => {
          const status = t.skipped ? '⚠️跳过' : t.failed ? '❌失败' : '✅成功';
          const argsStr = t.argsHash ? t.argsHash.substring(0, 80) : '';
          return `${i + 1}. ${t.name}(${argsStr}) → ${status}`;
        }).join('\n');

        const progressHint = `[任务进度 第${round + 1}轮] 已执行${toolCallHistory.length}次工具调用，最近${recentActions.length}次:\n${actionSummary}\n成功${successCount}次，失败${failCount}次。${failCount >= 2 ? '⚠️ 多次失败，请考虑换方法。' : '继续按计划执行。'}`;

        // 将进度摘要追加到最后一条 tool 消息的内容末尾（不新增消息，避免破坏消息结构）
        const lastToolMsgIdx = messages.length - 1;
        if (messages[lastToolMsgIdx] && messages[lastToolMsgIdx].role === 'tool') {
          messages[lastToolMsgIdx].content = messages[lastToolMsgIdx].content + '\n\n' + progressHint;
        }
      }

      // 构建请求参数（不支持流式 FC 的模型使用非流式请求）
      // P1-12 优化：降低 temperature 提高工具调用一致性，增加 max_tokens 应对复杂任务
      const requestParams = {
        model: resolved.actualModel,
        messages,
        stream: !modelNeedsNonStreaming,
        temperature: 0.5,  // 工具调用需要更低温度以保证一致性
        max_tokens: 8192,  // 增加输出空间以应对复杂任务
        tools,
        tool_choice: 'auto',
      };

      // P1-12 优化：API 调用重试机制（指数退避），应对网络波动和限流
      let apiResponse;
      let lastApiError;
      const maxRetries = 3;
      for (let retry = 0; retry < maxRetries; retry++) {
        try {
          apiResponse = await client.chat.completions.create(requestParams);
          break;
        } catch (apiErr) {
          lastApiError = apiErr;
          const isRetryable = apiErr.status === 429 || apiErr.status >= 500 || apiErr.code === 'ECONNRESET' || apiErr.code === 'ETIMEDOUT' || apiErr.message.includes('timeout');
          if (!isRetryable || retry === maxRetries - 1) {
            console.error(`[ReAct] API调用失败(不可重试): ${apiErr.message}`);
            throw apiErr;
          }
          const backoffMs = Math.min(1000 * Math.pow(2, retry), 8000);
          console.warn(`[ReAct] API调用失败(可重试): ${apiErr.message}，${backoffMs}ms后重试(${retry + 1}/${maxRetries})`);
          if (mainWindow && !mainWindow.isDestroyed()) {
            mainWindow.webContents.send('agent:stream', { type: 'text', content: `\n⏳ 网络波动，${backoffMs / 1000}秒后重试...` });
          }
          await new Promise(r => setTimeout(r, backoffMs));
        }
      }
      if (!apiResponse) throw lastApiError;

      let assistantContent = '';
      let toolCalls = [];

      if (modelNeedsNonStreaming) {
        // 非流式响应：直接从完整响应中提取 tool_calls
        const choice = apiResponse.choices?.[0];
        if (choice) {
          assistantContent = choice.message?.content || '';
          fullContent += assistantContent;
          if (mainWindow && !mainWindow.isDestroyed() && assistantContent) {
            mainWindow.webContents.send('agent:stream', { type: 'text', content: assistantContent });
          }
          if (choice.message?.tool_calls) {
            toolCalls = choice.message.tool_calls.map(tc => ({
              id: tc.id || '',
              name: tc.function?.name || '',
              arguments: tc.function?.arguments || '',
            }));
          }
        }
      } else {
      // 流式响应：逐 chunk 解析

      for await (const chunk of apiResponse) {
        const delta = chunk.choices?.[0]?.delta;
        if (!delta) continue;

        if (delta.content) {
          assistantContent += delta.content;
          fullContent += delta.content;
          if (mainWindow && !mainWindow.isDestroyed()) {
            mainWindow.webContents.send('agent:stream', { type: 'text', content: delta.content });
          }
        }

        if (delta.tool_calls) {
          for (const tc of delta.tool_calls) {
            // 使用 index 索引（而非 tc.id），因为流式响应中 tc.id 只在首个 chunk 出现
            const idx = tc.index ?? 0;
            if (!toolCalls[idx]) {
              toolCalls[idx] = { id: tc.id || '', name: '', arguments: '' };
            }
            if (tc.id) toolCalls[idx].id = tc.id;
            if (tc.function?.name) {
              const currentName = toolCalls[idx].name;
              const newName = tc.function.name;
              if (!currentName) {
                toolCalls[idx].name = newName;
              } else if (newName.startsWith(currentName) && newName.length > currentName.length) {
                toolCalls[idx].name = newName;
              } else if (!currentName.includes(newName)) {
                toolCalls[idx].name += newName;
              }
            }
            if (tc.function?.arguments) toolCalls[idx].arguments += tc.function.arguments;
          }
        }
      }
      } // end of else (streaming) block

      // 过滤掉空的 toolCall 条目（index 索引可能留下空洞）
      toolCalls = toolCalls.filter(tc => tc && tc.name);

      // 【关键修复】过滤掉参数为空的工具调用（避免 file_write 参数: {} 等问题）
      toolCalls = toolCalls.filter(tc => {
        if (!tc.arguments || tc.arguments.trim() === '') {
          console.warn(`[ReAct] 工具 ${tc.name} 参数为空，跳过执行`);
          if (mainWindow && !mainWindow.isDestroyed()) {
            mainWindow.webContents.send('agent:stream', { type: 'warning', content: `⚠️ ${tc.name} 参数为空，跳过执行` });
          }
          return false;
        }
        return true;
      });

      // P1-15 优化：为缺失 ID 的工具调用生成唯一 ID，防止 API 报错
      for (let i = 0; i < toolCalls.length; i++) {
        if (!toolCalls[i].id) {
          toolCalls[i].id = `call_${Date.now()}_${i}_${Math.random().toString(36).substring(2, 8)}`;
        }
      }

      // 【关键修复】对于不支持 function calling 的模型，从文本中提取工具调用
      if (toolCalls.length === 0 && assistantContent && modelNeedsNonStreaming) {
        const pseudoCalls = extractPseudoToolCallsFromText(assistantContent);
        if (pseudoCalls.length > 0) {
          toolCalls = pseudoCalls;
          // 从文本中移除伪工具调用标签
          let cleanedContent = assistantContent;
          for (const pc of pseudoCalls) {
            cleanedContent = cleanedContent.replace(pc.rawMatch, '');
          }
          assistantContent = cleanedContent.trim();
        }
      }

      // 没有工具调用 → 结束
      if (toolCalls.length === 0) {
        // P1-15 优化：处理空响应 — LLM 返回空内容且无工具调用
        if (!assistantContent || assistantContent.trim() === '') {
          // 空响应：可能是模型异常，提供 fallback 消息
          if (round === 0) {
            // 第一轮就空响应，说明模型可能有问题
            assistantContent = '我理解了您的请求，但当前模型未能生成有效回复。请尝试以下操作：\n1. 重新发送消息\n2. 切换到其他模型\n3. 简化您的问题后重试';
            fullContent += assistantContent;
            if (mainWindow && !mainWindow.isDestroyed()) {
              mainWindow.webContents.send('agent:stream', { type: 'text', content: assistantContent });
            }
          } else {
            // 后续轮次空响应，说明模型可能已经完成但未调用 complete
            assistantContent = '\n\n[任务已完成]';
            fullContent += assistantContent;
            if (mainWindow && !mainWindow.isDestroyed()) {
              mainWindow.webContents.send('agent:stream', { type: 'text', content: assistantContent });
            }
          }
        }
        // 如果是第一轮且LLM只输出了文字没调用工具，说明LLM认为不需要工具，直接结束
        // 不再强制要求LLM调用工具，避免对简单问候/闲聊也执行工具
        break;
      }

      // 添加assistant消息
      messages.push({
        role: 'assistant',
        content: assistantContent || null,
        tool_calls: toolCalls.map(tc => ({
          id: tc.id, type: 'function', function: { name: tc.name, arguments: tc.arguments },
        })),
      });

      // P1-16 优化：工具执行顺序排序 — think 先执行，complete 最后执行
      const toolPriority = { think: 0, complete: 99 };
      toolCalls.sort((a, b) => (toolPriority[a.name] ?? 50) - (toolPriority[b.name] ?? 50));

      // 执行每个工具
      for (const tc of toolCalls) {
        let toolArgs = {};
        try { toolArgs = JSON.parse(tc.arguments); } catch (e) {
          console.warn(`[ReAct] 工具参数解析失败 | 工具: ${tc.name} | 原始参数: ${tc.arguments?.substring(0, 200)} | 错误: ${e.message}`);
          // 尝试修复截断的 JSON
          toolArgs = tryRepairJSON(tc.arguments || '');
          if (Object.keys(toolArgs).length === 0) {
            if (mainWindow && !mainWindow.isDestroyed()) {
              mainWindow.webContents.send('agent:stream', { type: 'tool_result', content: `❌ ${tc.name} 参数解析失败，请重试`, toolName: tc.name });
            }
            continue;
          }
        }

        // P1-15 优化：工具参数预验证，捕获常见参数错误
        const validationError = validateToolParams(tc.name, toolArgs);
        if (validationError) {
          console.warn(`[ReAct] 参数验证失败 | 工具: ${tc.name} | 错误: ${validationError}`);
          if (mainWindow && !mainWindow.isDestroyed()) {
            mainWindow.webContents.send('agent:stream', { type: 'tool_result', content: `❌ 参数错误: ${validationError}`, toolName: tc.name, duration: 0, success: false });
          }
          messages.push({ role: 'tool', content: `❌ 参数错误: ${validationError}`, tool_call_id: tc.id });
          toolCallHistory.push({ name: tc.name, argsHash: JSON.stringify(toolArgs), skipped: true, failed: true });
          continue;
        }

        // ===== 冗余检测：跳过重复的工具调用 =====
        const redundancyCheck = checkToolRedundancy(tc.name, toolArgs);
        if (redundancyCheck.skip) {
          console.warn(`[ReAct] 跳过冗余调用 | 工具: ${tc.name} | 原因: ${redundancyCheck.reason}`);
          if (mainWindow && !mainWindow.isDestroyed()) {
            mainWindow.webContents.send('agent:stream', { type: 'tool_call', content: `跳过 ${tc.name}（冗余）`, toolName: tc.name, toolArgs });
            mainWindow.webContents.send('agent:stream', { type: 'tool_result', content: redundancyCheck.cachedResult || `⚠️ ${redundancyCheck.reason}`, toolName: tc.name, duration: 0, success: !redundancyCheck.cachedResult ? false : true });
          }
          // P1-14 优化：如果有缓存结果，返回缓存而非跳过消息
          messages.push({ role: 'tool', content: redundancyCheck.cachedResult || `⚠️ ${redundancyCheck.reason}`, tool_call_id: tc.id });
          // 仍然记录到历史，以便后续检测
          toolCallHistory.push({ name: tc.name, argsHash: JSON.stringify(toolArgs), skipped: true });
          continue;
        }

        // 工具调用日志（便于排查"工具调用失败"问题）
        const toolStartTime = Date.now();
        console.log(`[ReAct] 工具调用 | 轮次: ${round + 1}/${MAX_ROUNDS} | 工具: ${tc.name} | 参数: ${JSON.stringify(toolArgs).substring(0, 300)}`);

        if (mainWindow && !mainWindow.isDestroyed()) {
          mainWindow.webContents.send('agent:stream', { type: 'tool_call', content: `执行 ${tc.name}`, toolName: tc.name, toolArgs });
        }

        // P1-13 优化：工具级超时保护，防止挂起
        const TOOL_TIMEOUTS = {
          browser_operate: 30000,  // 浏览器操作最多30秒
          web_fetch: 20000,        // 网页获取最多20秒
          web_search: 15000,       // 搜索最多15秒
          shell_execute: 30000,    // Shell命令最多30秒
          code_execute: 15000,     // 代码执行最多15秒
          app_operate: 30000,      // 应用操作最多30秒（含启动+激活+重试）
          file_read: 10000,        // 文件读取最多10秒
          file_write: 10000,       // 文件写入最多10秒
          file_list: 5000,         // 目录列表最多5秒
          think: 5000,             // 思考最多5秒
          complete: 5000,          // 完成最多5秒
          desktop_open: 10000,     // 打开应用最多10秒
          self_improve: 120000,    // 自我改进最多120秒（含用户批准对话框等待）
          request_workspace_access: 120000, // 请求目录权限最多120秒（含用户确认对话框等待）
          terminal_operate: 60000, // 终端操作最多60秒（含命令执行）
          editor_operate: 30000,   // 编辑器操作最多30秒
        };
        const toolTimeout = TOOL_TIMEOUTS[tc.name] || 20000;

        let rawToolResult;
        try {
          const toolPromise = executeTool(tc.name, toolArgs);
          const timeoutPromise = new Promise((_, reject) => {
            setTimeout(() => reject(new Error(`工具执行超时(${toolTimeout / 1000}秒)`)), toolTimeout);
          });
          const result = await Promise.race([toolPromise, timeoutPromise]);
          rawToolResult = typeof result === 'string' ? result : JSON.stringify(result ?? '');
        } catch (toolErr) {
          rawToolResult = `❌ 工具执行异常: ${toolErr.message}`;
        }
        // 类型保护：确保 toolResult 是字符串
        const toolResult = typeof rawToolResult === 'string' ? rawToolResult : JSON.stringify(rawToolResult ?? '');

        // P1-14 优化：为常见错误添加修复建议，帮助 Agent 更快恢复
        // V17 增强：覆盖更多错误模式，与服务端错误恢复保持一致
        let enhancedResult = toolResult;
        if (toolResult.startsWith('❌')) {
          const suggestions = [];
          const lowerResult = toolResult.toLowerCase();
          if (tc.name === 'browser_operate' && toolResult.includes('浏览器窗口未打开')) {
            suggestions.push('💡 建议：先调用 browser_operate({action:"goto", url:"..."}) 打开网页');
          } else if (tc.name === 'browser_operate' && toolResult.includes('未找到可点击元素')) {
            suggestions.push('💡 建议：先用 extract 查看页面内容，再根据实际元素文本调用 click');
          } else if (tc.name === 'file_read' && toolResult.includes('文件不存在')) {
            suggestions.push('💡 建议：先用 file_list 查看目录内容，确认文件路径');
          } else if (['file_read', 'file_write', 'file_edit', 'file_list', 'grep_search', 'search_files'].includes(tc.name) && toolResult.includes('安全限制') && toolResult.includes('工作区')) {
            // 工作区限制：提示 Agent 调用 request_workspace_access 请求权限，而非绕过
            const pathMatch = toolResult.match(/路径\s+(.+?)\s+(?:不在|超出)/);
            const dirHint = pathMatch ? pathMatch[1] : '该目录';
            suggestions.push(`💡 建议：目录 "${dirHint}" 在工作区外。请调用 request_workspace_access({path: "${dirHint}", reason: "..."}) 向用户请求访问权限，用户批准后即可访问。不要用 shell_execute/code_execute 绕过。`);
          } else if (tc.name === 'web_search' && (lowerResult.includes('failed') || lowerResult.includes('超时'))) {
            suggestions.push('💡 建议：网络搜索失败，可尝试 web_fetch 直接获取已知URL，或用 browser_operate 打开搜索引擎');
          } else if (tc.name === 'web_fetch' && (lowerResult.includes('超时') || lowerResult.includes('timeout'))) {
            suggestions.push('💡 建议：网页获取超时，可尝试 browser_operate 在内置浏览器中打开');
          } else if (tc.name === 'code_execute' && toolResult.includes('require')) {
            suggestions.push('💡 建议：可用 require 模块: https/http/crypto/url/querystring/os/path/fs/zlib/stream');
          } else if (tc.name === 'shell_execute' && toolResult.includes('白名单')) {
            suggestions.push('💡 建议：可用命令: npm/node/python/git/powershell/cmd/curl 等，或用 | > && 进入shell模式');
          }
          // V17 新增：参数错误修复
          else if (toolResult.includes('缺少参数') || lowerResult.includes('missing parameter')) {
            const argKeys = Object.keys(toolArgs || {});
            if (['file_write', 'file_edit'].includes(tc.name)) {
              suggestions.push(`💡 建议：file_write 需要 {path, content}，file_edit 需要 {path, old_text, new_text}。path 也接受 filePath/file_path/filename/file。你传入的参数: ${argKeys.join(', ')}`);
            } else if (tc.name === 'shell_execute') {
              suggestions.push(`💡 建议：shell_execute 需要 {command: "命令字符串"}。你传入的参数: ${argKeys.join(', ')}`);
            } else if (['search_files', 'grep_search'].includes(tc.name)) {
              suggestions.push(`💡 建议：需要 {pattern: "匹配模式"} 参数。你传入的参数: ${argKeys.join(', ')}`);
            } else {
              suggestions.push(`💡 建议：缺少必需参数。你传入的参数: ${argKeys.join(', ')}。请检查工具定义。`);
            }
          }
          // V17 新增：Shell 命令错误
          else if (tc.name === 'shell_execute' && (lowerResult.includes('cmd.exe') || lowerResult.includes('command failed'))) {
            suggestions.push('💡 建议：Shell命令失败。系统已自动使用 PowerShell 并转换 Unix 命令。可直接使用 mkdir -p/rm -rf 等 Unix 语法。避免用 && 连接多条命令，改用分步执行。');
          } else if (tc.name === 'shell_execute' && (lowerResult.includes('etimedout') || lowerResult.includes('超时'))) {
            suggestions.push('💡 建议：命令超时。长命令(npm install/git clone)已自动延长超时。如仍超时尝试分步执行或检查网络。');
          }
          // V17 新增：权限和文件存在错误
          else if (lowerResult.includes('permission denied') || lowerResult.includes('eacces') || toolResult.includes('权限')) {
            suggestions.push('💡 建议：权限不足。检查文件/目录权限，换用非敏感路径，避免访问系统目录。');
          } else if (lowerResult.includes('file exists') || lowerResult.includes('already exists') || toolResult.includes('已存在')) {
            suggestions.push('💡 建议：文件/目录已存在。先删除已有文件，或换用新名称。');
          }
          // V17 新增：网络错误
          else if (lowerResult.includes('econnrefused') || lowerResult.includes('econnreset') || lowerResult.includes('network')) {
            suggestions.push('💡 建议：网络连接失败。检查网络、防火墙，确认服务是否运行。');
          }
          // V17 新增：代码语法错误
          else if (lowerResult.includes('syntaxerror') && (lowerResult.includes('unexpected token') || lowerResult.includes('unexpected identifier'))) {
            suggestions.push('💡 建议：代码语法错误。检查括号/引号匹配，检查是否误用中文标点，用 file_read 重新读取确认。');
          } else if (lowerResult.includes('ts1005') || lowerResult.includes('ts1003')) {
            suggestions.push('💡 建议：TypeScript 编译错误。检查模板字符串反引号、语句结尾分号。');
          }
          // 通用超时
          else if (toolResult.includes('超时')) {
            suggestions.push('💡 建议：操作超时，可能是网络或系统响应慢，请换一种方法');
          }
          if (suggestions.length > 0) {
            enhancedResult = toolResult + '\n' + suggestions.join('\n');
          }
        }

        const toolDuration = Date.now() - toolStartTime;
        const isSuccess = !toolResult.startsWith('❌');
        console.log(`[ReAct] 工具结果 | 工具: ${tc.name} | 耗时: ${toolDuration}ms | 成功: ${isSuccess} | 结果长度: ${toolResult.length} | 预览: ${toolResult.substring(0, 150)}`);

        if (mainWindow && !mainWindow.isDestroyed()) {
          mainWindow.webContents.send('agent:stream', { type: 'tool_result', content: toolResult.substring(0, 500), toolName: tc.name, duration: toolDuration, success: isSuccess });
        }

        // 智能截断：错误消息不截断（通常很短且重要），成功结果按工具类型设置上限
        // P1-13 优化：think 内容不截断（推理内容很重要）；browser_operate 增加到 6000
        let finalToolResult = enhancedResult;
        const TOOL_RESULT_LIMITS = {
          file_read: 16000,
          file_write: 500,       // 写入结果通常很短
          web_search: 4000,      // 搜索结果增加到4000
          web_fetch: 10000,
          shell_execute: 8000,
          code_execute: 8000,
          browser_operate: 6000, // 浏览器操作结果需要更多空间
          app_operate: 2000,
          think: 5000,           // think 内容不截断（最多5000字符）
          complete: 500,
          file_list: 8000,        // 增强后含大小/日期/扩展名，每行约50字符，8000可显示约150个文件
          desktop_open: 1000,
          self_improve: 12000,   // 自我改进结果（搜索/读取内容）
          request_workspace_access: 1000, // 权限请求结果通常很短
        };
        const limit = TOOL_RESULT_LIMITS[tc.name] || 8000;
        if (finalToolResult.length > limit) {
          // P1-16 优化：为截断的结果添加摘要，帮助 LLM 快速理解
          const summary = generateResultSummary(tc.name, finalToolResult, limit);
          finalToolResult = summary + finalToolResult.substring(0, limit) + `\n\n[结果已截断：显示前 ${limit} 字符，共 ${finalToolResult.length} 字符]`;
        }
        messages.push({ role: 'tool', content: finalToolResult, tool_call_id: tc.id });
        fullContent += `\n${toolResult}`;

        // ===== 记录到工具调用历史（用于冗余检测和进度追踪）=====
        toolCallHistory.push({ name: tc.name, argsHash: JSON.stringify(toolArgs), skipped: false, failed: !isSuccess });

        // ===== V17: 连续失败检测 — 连续失败 N 次自动注入策略切换提示 =====
        if (isSuccess) {
          consecutiveFailures.delete(tc.name);
          totalConsecutiveFailures = 0;
        } else {
          const failCount = (consecutiveFailures.get(tc.name) || 0) + 1;
          consecutiveFailures.set(tc.name, failCount);
          totalConsecutiveFailures++;

          // 单个工具连续失败 2 次：提示换参数或换工具
          if (failCount >= 2) {
            const hint = `【系统提示】工具 ${tc.name} 已连续失败 ${failCount} 次。请：1)检查参数是否正确 2)换用其他工具 3)换一种完全不同的方法。不要重复调用相同工具相同参数。`;
            messages.push({ role: 'system', content: hint });
            if (mainWindow && !mainWindow.isDestroyed()) {
              mainWindow.webContents.send('agent:stream', { type: 'think', content: `⚠️ ${tc.name} 连续失败 ${failCount} 次，建议换方法` });
            }
          }

          // 总连续失败达到上限：强制注入策略切换提示
          if (totalConsecutiveFailures >= MAX_CONSECUTIVE_FAILURES) {
            const failedTools = [...consecutiveFailures.entries()].filter(([, c]) => c >= 2).map(([n]) => n);
            const strategyHint = `【系统提醒】工具已连续失败 ${totalConsecutiveFailures} 次${failedTools.length > 0 ? `（${failedTools.join(', ')} 重复失败）` : ''}。请尝试以下策略：\n1. 换一个不同的工具完成同样任务\n2. 调整工具参数重试\n3. 将任务分解为更小步骤\n4. 换一种完全不同的思路\n\n不要放弃，继续尝试执行任务。`;
            messages.push({ role: 'system', content: strategyHint });
            if (mainWindow && !mainWindow.isDestroyed()) {
              mainWindow.webContents.send('agent:stream', { type: 'think', content: `🔄 连续失败 ${totalConsecutiveFailures} 次，触发策略切换` });
            }
            // 重置计数，给新一轮机会
            totalConsecutiveFailures = 0;
            consecutiveFailures.clear();
          }
        }

        // P1-14 优化：缓存成功的结果，供重复调用时返回
        if (isSuccess && tc.name !== 'file_write' && tc.name !== 'file_edit' && tc.name !== 'shell_execute') {
          const cacheKey = `${tc.name}:${JSON.stringify(toolArgs)}`;
          toolResultCache.set(cacheKey, finalToolResult);
        }
        // file_write 记录路径计数
        if (tc.name === 'file_write' && toolArgs.path) {
          const normalizedPath = path.resolve(toolArgs.path).toLowerCase();
          writePathCount.set(normalizedPath, (writePathCount.get(normalizedPath) || 0) + 1);
          // 缓存失效：文件写入后目录结构和文件内容可能已变化，清除相关缓存
          for (const key of toolResultCache.keys()) {
            if (key.startsWith('file_list:') || key.startsWith('file_read:')) {
              toolResultCache.delete(key);
            }
          }
        }
        // V17 修复：file_edit 同样修改文件内容，必须清除 file_read/file_list 缓存
        if (tc.name === 'file_edit' && isSuccess) {
          for (const key of toolResultCache.keys()) {
            if (key.startsWith('file_read:') || key.startsWith('file_list:')) {
              toolResultCache.delete(key);
            }
          }
        }
      }
    }

    // 发送完成事件
    if (mainWindow && !mainWindow.isDestroyed()) {
      mainWindow.webContents.send('agent:stream', { type: 'done', fullContent });
    }

    return { success: true, content: fullContent };
  }

  /** Agent 聊天入口：优先连接 Agent 后端，不可用时回退到直接 API 调用 */
  async function handleAgentChat(_event, { message, history, model, attachments }) {
    // 优先尝试 Agent 后端
    try {
      const result = await streamFromAgentBackend(message, history, model);
      return result;
    } catch (err) {
      console.log(`[Agent] 后端不可用 (${err.message})，回退到直接 API 调用`);
    }

    // 回退到直接 OpenAI 调用（传递附件）
    try {
      return await directOpenAICall(message, history, model, attachments);
    } catch (error) {
      const errMsg = error.message || String(error);
      console.error('[Agent] 调用失败:', errMsg);
      // 发送错误事件
      if (mainWindow && !mainWindow.isDestroyed()) {
        mainWindow.webContents.send('agent:stream', { type: 'error', content: errMsg });
      }
      return { success: false, error: errMsg };
    }
  }

  // ----- Agent 通信 -----
  ipcMain.handle('agent:send', async (_event, message) => {
    return handleAgentChat(_event, { message, history: [], model: undefined });
  });

  // ----- Agent 聊天（流式） -----
  ipcMain.handle('agent:chat', async (_event, params) => {
    return handleAgentChat(_event, params);
  });

  // ----- 提示词优化 -----
  ipcMain.handle('agent:optimizePrompt', async (_event, text) => {
    try {
      if (!text || !text.trim()) return { success: false, error: '空文本' };
      const config = loadConfig();
      const duanConfig = loadDuanConfig();
      const provider = config.apiProvider || duanConfig.defaultProvider || 'deepseek';
      // loadConfig() 返回的是 config.apiKey（单数），不是 config.apiKeys（复数对象）
      const apiKey = config.apiKey || duanConfig.apiKey;
      const model = config.model || duanConfig.defaultModel || 'deepseek-chat';
      const baseURL = config.baseURL || duanConfig.baseURL || '';
      if (!apiKey) return { success: false, error: '未配置API Key，请在配置页面设置' };

      // 直接创建 OpenAI 客户端，不依赖 llm-providers 模块
      const OpenAI = require('openai').default;
      const openai = new OpenAI({
        apiKey,
        baseURL: baseURL || undefined,
        timeout: 15000,
        maxRetries: 1,
      });

      const response = await openai.chat.completions.create({
        model,
        messages: [
          { role: 'system', content: '你是一个提示词优化专家。将用户的简短输入优化为更清晰、更具体的提示词，让AI能更好地理解意图并给出高质量回答。只输出优化后的提示词，不要任何解释。保持中文，简洁有力。' },
          { role: 'user', content: `优化以下提示词：\n${text}` },
        ],
        max_tokens: 500,
        temperature: 0.7,
      });

      const optimized = response.choices?.[0]?.message?.content?.trim();
      if (optimized) {
        return { success: true, optimized };
      }
      return { success: false, error: '优化结果为空' };
    } catch (err) {
      return { success: false, error: err.message || '优化请求失败' };
    }
  });

  ipcMain.handle('agent:stop', async () => {
    try {
      stopAgent();
      return { success: true };
    } catch (err) {
      console.error('[IPC] agent:stop 失败:', err.message);
      return { success: false, error: err.message };
    }
  });

  // ----- 多Agent协作 -----
  safeHandle('agent:list', async () => {
    const duanConfig = loadDuanConfig();
    let profiles = duanConfig.profiles || [];
    if (!Array.isArray(profiles)) profiles = Object.entries(profiles).map(([id, p]) => ({ id, ...p }));
    const hasApiKey = profiles.some(p => p.apiKey);

    // 定义多Agent协作角色
    const agents = [
      {
        id: 'coordinator',
        name: '协调者',
        description: '任务分发与结果汇总，负责协调多个专业Agent协作完成复杂任务',
        expertise: ['任务分解', '结果汇总', '质量控制'],
        status: hasApiKey ? 'active' : 'inactive',
        role: 'coordinator',
      },
      {
        id: 'coder',
        name: '代码专家',
        description: '专注于代码生成、审查、重构和调试，支持多种编程语言',
        expertise: ['代码生成', '代码审查', 'Bug修复', '架构设计'],
        status: hasApiKey ? 'standby' : 'inactive',
        role: 'specialist',
      },
      {
        id: 'researcher',
        name: '研究助手',
        description: '负责信息搜索、网页浏览、数据分析和知识检索',
        expertise: ['网络搜索', '网页浏览', '数据分析', '信息提取'],
        status: hasApiKey ? 'standby' : 'inactive',
        role: 'specialist',
      },
      {
        id: 'executor',
        name: '执行助手',
        description: '执行终端命令、文件操作、系统控制和桌面自动化',
        expertise: ['终端执行', '文件操作', '系统控制', '应用操作'],
        status: hasApiKey ? 'standby' : 'inactive',
        role: 'specialist',
      },
    ];

    return { success: true, agents };
  });

  // ----- AUTO 智能路由 -----
  // 根据用户输入内容分析任务类型，选择最优API模型处理任务
  // 支持性能评估和供应商别名映射

  // 供应商别名解析：统一不同命名
  function resolveProviderAlias(provider) {
    const aliases = {
      'coding_plan': 'doubao-coding',
      'doubao-coding': 'coding_plan',
      'google': 'gemini',
      'gemini': 'google',
      'doubao': 'doubao-coding',
      'volcengine': 'doubao-coding',
    };
    return aliases[provider] || provider;
  }

  // 检查 provider 是否已配置（考虑别名）
  function isProviderConfigured(provider, configuredProviders) {
    if (configuredProviders.includes(provider)) return true;
    const alias = resolveProviderAlias(provider);
    return configuredProviders.includes(alias);
  }

  // 加载模型性能数据（从 ~/.duan/model-performance.json）
  function loadModelPerformance() {
    try {
      const perfPath = path.join(os.homedir(), '.duan', 'model-performance.json');
      if (fs.existsSync(perfPath)) {
        return JSON.parse(fs.readFileSync(perfPath, 'utf-8'));
      }
    } catch (e) {
      console.warn('[AUTO路由] 加载性能数据失败:', e.message);
    }
    return { models: {} };
  }

  // 保存模型性能数据
  function saveModelPerformance(perfData) {
    try {
      const perfPath = path.join(os.homedir(), '.duan', 'model-performance.json');
      const dir = path.dirname(perfPath);
      if (!fs.existsSync(dir)) fs.mkdirSync(dir, { recursive: true });
      fs.writeFileSync(perfPath, JSON.stringify(perfData, null, 2), 'utf-8');
    } catch (e) {
      console.warn('[AUTO路由] 保存性能数据失败:', e.message);
    }
  }

  // 记录模型性能（供后续路由参考）
  function recordModelPerformance(model, taskType, success, durationMs) {
    try {
      const perf = loadModelPerformance();
      if (!perf.models[model]) {
        perf.models[model] = { totalCalls: 0, successCount: 0, totalDurationMs: 0, taskTypes: {} };
      }
      const m = perf.models[model];
      m.totalCalls++;
      if (success) m.successCount++;
      m.totalDurationMs += durationMs;
      if (!m.taskTypes[taskType]) m.taskTypes[taskType] = { calls: 0, success: 0 };
      m.taskTypes[taskType].calls++;
      if (success) m.taskTypes[taskType].success++;
      m.lastUsed = Date.now();
      m.avgDuration = m.totalDurationMs / m.totalCalls;
      m.successRate = m.successCount / m.totalCalls;
      saveModelPerformance(perf);
    } catch (e) {
      console.warn('[AUTO路由] 记录性能失败:', e.message);
    }
  }

  // 根据性能数据对候选模型排序
  function rankModelsByPerformance(models, taskType, perfData) {
    if (!perfData || !perfData.models) return models;
    return models.map(m => {
      const perf = perfData.models[m.model];
      let score = 0.5; // 默认分数
      if (perf) {
        // 综合分数 = 成功率 * 0.6 + 速度分 * 0.4
        const successScore = perf.successRate || 0.5;
        const speedScore = perf.avgDuration ? Math.max(0, 1 - perf.avgDuration / 30000) : 0.5;
        // 任务类型匹配加成
        const taskPerf = perf.taskTypes?.[taskType];
        const taskBonus = taskPerf && taskPerf.calls > 0 ? (taskPerf.success / taskPerf.calls - 0.5) * 0.2 : 0;
        score = successScore * 0.6 + speedScore * 0.4 + taskBonus;
      }
      return { ...m, perfScore: score };
    }).sort((a, b) => b.perfScore - a.perfScore);
  }

  ipcMain.handle('agent:autoRoute', async (_event, { message, configuredProviders }) => {
    try {
      const msg = (message || '').toLowerCase();
      const providers = configuredProviders || [];
      const perfData = loadModelPerformance();

      // 任务类型检测规则（基于关键词匹配）
      const taskRules = [
        {
          type: '代码任务',
          keywords: ['代码', 'code', '函数', 'function', 'bug', '错误', 'error', '调试', 'debug', '编程', 'program', '实现', 'implement', '重构', 'refactor', 'api', '接口', '类', 'class', '方法', 'method', '算法', 'algorithm'],
          preferredModels: [
            { provider: 'doubao-coding', model: 'ark-code-latest' },
            { provider: 'doubao-coding', model: 'doubao-seed-2.0-code' },
            { provider: 'deepseek', model: 'deepseek-chat' },
            { provider: 'openai', model: 'gpt-4o' },
            { provider: 'qwen', model: 'qwen-plus' },
          ],
        },
        {
          type: '推理任务',
          keywords: ['分析', 'analyze', '推理', 'reason', '为什么', 'why', '解释', 'explain', '证明', 'prove', '逻辑', 'logic', '数学', 'math', '计算', 'calculate'],
          preferredModels: [
            { provider: 'deepseek', model: 'deepseek-reasoner' },
            { provider: 'openai', model: 'o3-mini' },
            { provider: 'deepseek', model: 'deepseek-chat' },
            { provider: 'zhipu', model: 'glm-4-plus' },
          ],
        },
        {
          type: '写作任务',
          keywords: ['写', 'write', '文章', 'article', '文案', 'copy', '故事', 'story', '邮件', 'email', '报告', 'report', '总结', 'summary', '翻译', 'translate'],
          preferredModels: [
            { provider: 'openai', model: 'gpt-4o' },
            { provider: 'deepseek', model: 'deepseek-chat' },
            { provider: 'qwen', model: 'qwen-plus' },
            { provider: 'zhipu', model: 'glm-4-plus' },
          ],
        },
        {
          type: '快速任务',
          keywords: ['快速', 'quick', '简单', 'simple', '列表', 'list', '格式', 'format', '转换', 'convert'],
          preferredModels: [
            { provider: 'openai', model: 'gpt-4o-mini' },
            { provider: 'zhipu', model: 'glm-4-flash' },
            { provider: 'qwen', model: 'qwen-turbo' },
            { provider: 'deepseek', model: 'deepseek-chat' },
          ],
        },
        {
          type: '搜索任务',
          keywords: ['搜索', 'search', '查找', 'find', '查询', 'query', '最新', 'latest', '新闻', 'news', '资料', 'information'],
          preferredModels: [
            { provider: 'deepseek', model: 'deepseek-chat' },
            { provider: 'openai', model: 'gpt-4o-mini' },
            { provider: 'qwen', model: 'qwen-turbo' },
          ],
        },
      ];

      // 检测任务类型
      let detectedType = '通用任务';
      let matchedRules = null;
      let maxMatches = 0;

      for (const rule of taskRules) {
        const matches = rule.keywords.filter(kw => msg.includes(kw)).length;
        if (matches > maxMatches) {
          maxMatches = matches;
          matchedRules = rule;
          detectedType = rule.type;
        }
      }

      // 收集所有已配置 provider 可用的候选模型
      let candidates = [];
      if (matchedRules) {
        for (const pref of matchedRules.preferredModels) {
          if (isProviderConfigured(pref.provider, providers)) {
            candidates.push(pref);
          }
        }
      }

      // 根据性能数据对候选模型排序
      let rankedCandidates = rankModelsByPerformance(candidates, detectedType, perfData);

      // 选择最优模型
      let selectedModel = rankedCandidates.length > 0 ? rankedCandidates[0].model : null;

      // 回退：如果没匹配到或匹配的provider都未配置，使用默认模型
      if (!selectedModel) {
        const duanConfig = loadDuanConfig();
        const defaultModel = duanConfig.defaultModel || 'deepseek-chat';
        selectedModel = defaultModel;
      }

      console.log(`[AUTO路由] 任务类型: ${detectedType} | 匹配数: ${maxMatches} | 候选: ${rankedCandidates.length} | 选择: ${selectedModel}${rankedCandidates.length > 0 ? ` (性能分: ${rankedCandidates[0].perfScore.toFixed(2)})` : ''}`);

      return {
        success: true,
        model: selectedModel,
        taskType: detectedType,
        confidence: maxMatches > 0 ? Math.min(maxMatches / 3, 1) : 0.3,
        candidates: rankedCandidates.slice(0, 5).map(c => ({
          model: c.model,
          provider: c.provider,
          perfScore: Number(c.perfScore.toFixed(2)),
          hasPerformanceData: !!(perfData.models && perfData.models[c.model]),
        })),
      };
    } catch (err) {
      console.error('[AUTO路由] 失败:', err.message);
      return { success: false, model: 'deepseek-chat', error: err.message };
    }
  });

  // 记录模型使用性能（供前端在任务完成后调用）
  ipcMain.handle('agent:recordPerformance', async (_event, { model, taskType, success, durationMs }) => {
    try {
      if (!model) return { success: false, error: '缺少 model 参数' };
      recordModelPerformance(model, taskType || '通用任务', !!success, durationMs || 0);
      return { success: true };
    } catch (err) {
      return { success: false, error: err.message };
    }
  });

  // 获取所有已配置供应商及其可用模型列表（供前端手动选择）
  ipcMain.handle('agent:listAvailableModels', async (_event, { configuredProviders }) => {
    try {
      const providers = configuredProviders || [];
      const perfData = loadModelPerformance();

      // 供应商到模型的映射表
      const providerModels = {
        'openai': ['gpt-4o', 'gpt-4o-mini', 'gpt-4-turbo', 'o3-mini'],
        'deepseek': ['deepseek-chat', 'deepseek-reasoner', 'deepseek-coder'],
        'qwen': ['qwen-plus', 'qwen-turbo', 'qwen-max'],
        'zhipu': ['glm-4-plus', 'glm-4-flash', 'glm-4-air'],
        'doubao-coding': ['ark-code-latest', 'doubao-seed-2.0-code', 'doubao-1.5-pro'],
        'coding_plan': ['ark-code-latest', 'doubao-seed-2.0-code'],
        'anthropic': ['claude-3-5-sonnet', 'claude-3-opus', 'claude-3-haiku'],
        'gemini': ['gemini-1.5-pro', 'gemini-1.5-flash'],
        'google': ['gemini-1.5-pro', 'gemini-1.5-flash'],
        'kimi': ['moonshot-v1-8k', 'moonshot-v1-32k', 'moonshot-v1-128k'],
        'minimax': ['abab6.5-chat', 'abab6.5s-chat'],
        'baidu': ['ernie-bot-4', 'ernie-bot-turbo'],
        'mistral': ['mistral-large', 'mistral-medium', 'mistral-small'],
        'groq': ['llama-3.3-70b', 'mixtral-8x7b'],
        'openrouter': ['auto', 'openai/gpt-4o', 'anthropic/claude-3.5-sonnet'],
        'ollama': ['llama3', 'qwen2', 'phi3'],
      };

      const result = [];
      for (const provider of providers) {
        const normalizedProvider = resolveProviderAlias(provider);
        const models = providerModels[normalizedProvider] || providerModels[provider] || [];
        for (const model of models) {
          const perf = perfData.models?.[model];
          result.push({
            provider,
            model,
            perfScore: perf ? Number(((perf.successRate || 0.5) * 0.6 + (perf.avgDuration ? Math.max(0, 1 - perf.avgDuration / 30000) : 0.5) * 0.4).toFixed(2)) : 0.5,
            successRate: perf?.successRate || 0,
            avgDuration: perf?.avgDuration || 0,
            totalCalls: perf?.totalCalls || 0,
            hasPerformanceData: !!perf,
          });
        }
      }

      // 按性能分数排序
      result.sort((a, b) => b.perfScore - a.perfScore);

      return { success: true, models: result };
    } catch (err) {
      console.error('[agent:listAvailableModels] 失败:', err.message);
      return { success: false, models: [], error: err.message };
    }
  });

  // ----- 浏览器窗口 -----
  safeHandle('browser:open', async (_event, url) => {
    // V17 安全修复：仅允许 http/https URL，防止 file:// 和 javascript: 协议
    if (!url || typeof url !== 'string' || !/^https?:\/\//i.test(url)) {
      return { success: false, error: '安全限制: 仅允许打开 http:// 或 https:// URL' };
    }
    // 不再弹出新窗口，改为在主窗口内激活浏览器面板
    if (mainWindow && !mainWindow.isDestroyed()) {
      mainWindow.webContents.send('browser:navigate-panel', url);
      mainWindow.webContents.send('tool:activate', 'browser');
      mainWindow.focus();
    }
    return { success: true };
  });

  safeHandle('browser:navigate', async (_event, url) => {
    // V17 安全修复：仅允许 http/https URL
    if (!url || typeof url !== 'string' || !/^https?:\/\//i.test(url)) {
      return { success: false, error: '安全限制: 仅允许导航到 http:// 或 https:// URL' };
    }
    if (browserWindow && !browserWindow.isDestroyed()) {
      try {
        await browserWindow.loadURL(url);
        return { success: true };
      } catch (err) {
        console.warn(`[browser:navigate] 加载失败: ${url}`, err?.message || err);
        return { success: false, error: `页面加载失败: ${err?.message || err}` };
      }
    }
    return { success: false, error: '浏览器窗口未打开' };
  });

  safeHandle('browser:close', async () => {
    if (browserWindow && !browserWindow.isDestroyed()) {
      browserWindow.close();
    }
    return { success: true };
  });

  // ----- 终端执行（P0-1/P0-3 修复：命令校验 + 跨平台支持 + cwd 连续性 + 流式输出）-----
  // 解析 cd 命令以维护 cwd 连续性（每命令新开 spawn，cd 不跨进程，故在主进程跟踪）
  const resolveNewCwd = (command, cwd) => {
    const trimmed = String(command || '').trim();
    let target = null;
    const simple = trimmed.match(/^cd\s+(.*)$/);
    if (simple) target = simple[1].trim().replace(/^["']|["']$/g, '');
    else {
      const comp = trimmed.match(/(?:^|&&|;)\s*cd\s+([^\s&;]+)/);
      if (comp) target = comp[1].replace(/^["']|["']$/g, '');
    }
    if (target === null) return cwd;
    if (target === '' || target === '~') return os.homedir();
    if (target === '-') return cwd;
    return path.resolve(cwd, target);
  };

  safeHandle('terminal:execute', async (_event, payload) => {
    // 兼容旧调用：字符串或 { command, cwd }
    const command = typeof payload === 'string' ? payload : (payload && payload.command);
    const cwd = (payload && typeof payload === 'object' && payload.cwd) ? payload.cwd : ROOT_DIR;
    // 安全校验：拒绝危险命令
    const validation = validateTerminalCommand(command);
    if (!validation.ok) {
      return { success: false, error: validation.error, stdout: '', stderr: '', cwd };
    }

    return new Promise((resolve) => {
      // 跨平台 shell 选择（P0-3 修复）
      const isWin = process.platform === 'win32';
      const shellCmd = isWin ? (process.env.ComSpec || 'cmd.exe') : '/bin/bash';
      const shellArgs = isWin ? ['/c', command] : ['-c', command];

      const proc = spawn(shellCmd, shellArgs, {
        cwd: cwd || ROOT_DIR,
        stdio: ['pipe', 'pipe', 'pipe'],
        shell: false,  // P0-1 修复：禁用 shell:true，避免二次解析
      });

      let stdout = '';
      let stderr = '';
      let settled = false;

      const done = (result) => {
        if (settled) return;
        settled = true;
        resolve(result);
      };

      proc.stdout.on('data', (data) => {
        const text = data.toString();
        stdout += text;
        if (mainWindow && !mainWindow.isDestroyed()) {
          mainWindow.webContents.send('terminal:output', { type: 'stdout', data: text });
        }
      });

      proc.stderr.on('data', (data) => {
        const text = data.toString();
        stderr += text;
        if (mainWindow && !mainWindow.isDestroyed()) {
          mainWindow.webContents.send('terminal:output', { type: 'stderr', data: text });
        }
      });

      proc.on('close', (code) => {
        // 计算命令执行后的 cwd（cd 命令会改变后续命令的工作目录）
        const newCwd = code === 0 ? resolveNewCwd(command, cwd) : cwd;
        done({ success: code === 0, exitCode: code, stdout, stderr, cwd: newCwd });
      });

      proc.on('error', (err) => {
        done({ success: false, error: err.message, stdout, stderr, cwd });
      });

      // 超时保护（120 秒）
      const timeoutTimer = setTimeout(() => {
        if (!settled) {
          try { proc.kill('SIGTERM'); } catch (_) {}
          done({ success: false, error: '命令执行超时（120秒）', stdout, stderr, cwd });
        }
      }, 120000);

      // P1 修复：进程结束后清理超时定时器，避免事件循环泄漏
      proc.on('close', () => clearTimeout(timeoutTimer));
      proc.on('error', () => clearTimeout(timeoutTimer));
    });
  });

  // 终端初始化：返回当前 cwd 与提示符，供前端 mount 时显示真实提示符
  safeHandle('terminal:hello', async () => {
    const cwd = ROOT_DIR;
    const prompt = process.platform === 'win32' ? `${cwd}>` : `${cwd} $`;
    return { cwd, prompt, shell: process.platform === 'win32' ? 'cmd.exe' : 'bash' };
  });

  // 终端注入（供 terminal_operate 工具调用，把命令/输出注入到前端面板）
  safeHandle('terminal:inject', async (_event, payload) => {
    if (mainWindow && !mainWindow.isDestroyed()) {
      mainWindow.webContents.send('terminal:inject', payload || {});
      return { success: true };
    }
    return { success: false, error: '主窗口不可用' };
  });

  // ----- 配置管理 -----
  // ----- 语音设置 -----
  // 语音配置存储在 ~/.duan/voice-config.json
  function loadVoiceConfig() {
    try {
      const voiceConfigPath = path.join(os.homedir(), '.duan', 'voice-config.json');
      if (fs.existsSync(voiceConfigPath)) {
        return JSON.parse(fs.readFileSync(voiceConfigPath, 'utf-8'));
      }
    } catch { /* ignore */ }
    return {
      enabled: false,
      voice: 'zh-CN-XiaoxiaoNeural',
      rate: 1.0,
      pitch: 0,
      volume: 1.0,
      autoPlay: false,
    };
  }

  function saveVoiceConfig(config) {
    try {
      const voiceConfigPath = path.join(os.homedir(), '.duan', 'voice-config.json');
      const dir = path.dirname(voiceConfigPath);
      if (!fs.existsSync(dir)) fs.mkdirSync(dir, { recursive: true });
      fs.writeFileSync(voiceConfigPath, JSON.stringify(config, null, 2), 'utf-8');
      return true;
    } catch { /* ignore */ }
    return false;
  }

  // 内置语音列表（Edge-TTS 免费语音，覆盖全球主流语言）
  const BUILTIN_VOICES = [
    // ===== 中文 =====
    // 中文女声
    { name: 'zh-CN-XiaoxiaoNeural', label: '晓晓（女·温柔亲切）', gender: 'female', language: 'zh-CN', style: '温柔' },
    { name: 'zh-CN-XiaoyiNeural', label: '晓伊（女·活泼俏皮）', gender: 'female', language: 'zh-CN', style: '活泼' },
    // 中文男声
    { name: 'zh-CN-YunjianNeural', label: '云健（男·沉稳厚重）', gender: 'male', language: 'zh-CN', style: '沉稳' },
    { name: 'zh-CN-YunxiNeural', label: '云希（男·阳光开朗）', gender: 'male', language: 'zh-CN', style: '阳光' },
    { name: 'zh-CN-YunxiaNeural', label: '云夏（男·少年清亮）', gender: 'male', language: 'zh-CN', style: '清亮' },
    { name: 'zh-CN-YunyangNeural', label: '云扬（男·专业沉稳）', gender: 'male', language: 'zh-CN', style: '新闻' },
