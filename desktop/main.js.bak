    slack: { type: 'slack', label: 'Slack', description: 'Slack Bot，支持 Socket Mode 和 Events API', fields: [
      { key: 'botToken', label: 'Bot Token (xoxb-)', type: 'password', required: true, help: 'Slack API→OAuth & Permissions→Bot User OAuth Token' },
      { key: 'signingSecret', label: 'Signing Secret', type: 'password', required: false, help: 'Slack API→Basic Information→Signing Secret' },
      { key: 'appToken', label: 'App Token (xapp-)', type: 'password', required: false, help: 'Slack API→Basic Information→App-Level Tokens（Socket Mode 必填）' },
      { key: 'channelId', label: '默认频道 ID', type: 'text', required: false, help: '默认发送消息的频道 ID' },
    ], accessControl: true },
